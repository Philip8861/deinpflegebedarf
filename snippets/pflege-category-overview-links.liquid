{% comment %}
  Gemeinsame Kategorielinks für Desktop-Leiste und Kategorienübersicht-Pop-up.
  Erwartet: variant ('rail' | 'modal'), url_*/active_* von sections/pflege-main-nav.liquid
  Nur Modal: url_pflegesets, active_pflegesets (Pflegesets erscheint nicht in der Desktop-Kategorie-Reihe)
{% endcomment %}
{%- liquid
  assign link_variant = variant | default: 'modal'
  assign icon_w = 22
  if link_variant == 'rail'
    assign icon_w = 20
  endif
-%}

<li{% if link_variant == 'rail' %} class="pflege-cat-rail__cell"{% endif %}>
  <a
    href="{{ url_free_care }}"
    {% if link_variant == 'rail' %}
      class="pflege-cat-rail__link{% if active_free_care %} pflege-cat-rail__link--active{% endif %}"
    {% else %}
      class="pflege-category-modal__link{% if active_free_care %} is-active{% endif %}"
      data-category-modal-close
    {% endif %}
    {% if active_free_care %}aria-current="page"{% endif %}
  >
    {% if link_variant == 'rail' %}
      <span class="pflege-cat-rail__icon" aria-hidden="true">{% render 'pflege-icon', icon: 'euro', width: icon_w %}</span>
      <span class="pflege-cat-rail__label">{{ 'sections.pflege_header_category_rail.cat_free_care' | t }}</span>
    {% else %}
      <span class="pflege-category-modal__link-icon" aria-hidden="true">{% render 'pflege-icon', icon: 'euro', width: icon_w %}</span>
      <span class="pflege-category-modal__link-label">{{ 'sections.pflege_header_category_rail.cat_free_care' | t }}</span>
    {% endif %}
  </a>
</li>

<li{% if link_variant == 'rail' %} class="pflege-cat-rail__cell pflege-cat-rail__cell--has-submenu{% if active_ink or active_ink_rezept %} is-active-context{% endif %}" data-pflege-cat-submenu-item{% else %} class="pflege-category-modal__item pflege-category-modal__item--has-submenu{% if active_ink or active_ink_rezept %} is-active-context{% endif %}" data-pflege-cat-submenu-item{% endif %}>
  {%- if link_variant == 'rail' -%}
    <button
      type="button"
      class="pflege-cat-rail__link pflege-cat-rail__link--submenu-toggle{% if active_ink or active_ink_rezept %} pflege-cat-rail__link--active{% endif %}"
      data-pflege-cat-submenu-toggle
      aria-expanded="false"
      aria-controls="PflegeCatInkSubmenu-rail"
    >
      <span class="pflege-cat-rail__icon" aria-hidden="true">{% render 'pflege-icon', icon: 'droplet', width: icon_w %}</span>
      <span class="pflege-cat-rail__label">{{ 'sections.pflege_header_category_rail.cat_ink' | t }}</span>
      <span class="pflege-cat-rail__submenu-chevron" aria-hidden="true">
        <svg width="12" height="12" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3.6 5.3 7 8.65 10.36 5.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </button>
    <ul
      class="pflege-cat-rail__submenu list-unstyled"
      id="PflegeCatInkSubmenu-rail"
      data-pflege-cat-submenu
      hidden
    >
      <li>
        <a
          href="{{ url_ink }}"
          class="pflege-cat-rail__sublink{% if active_ink %} is-active{% endif %}"
          {% if active_ink %}aria-current="page"{% endif %}
        >
          {{ 'sections.pflege_header_category_rail.cat_ink_products' | t }}
        </a>
      </li>
      <li>
        <a
          href="{{ url_ink_rezept }}"
          class="pflege-cat-rail__sublink{% if active_ink_rezept %} is-active{% endif %}"
          {% if active_ink_rezept %}aria-current="page"{% endif %}
        >
          {{ 'sections.pflege_header_category_rail.cat_ink_rezept' | t }}
        </a>
      </li>
    </ul>
  {%- else -%}
    <button
      type="button"
      class="pflege-category-modal__link pflege-category-modal__link--submenu-toggle{% if active_ink or active_ink_rezept %} is-active{% endif %}"
      data-pflege-cat-submenu-toggle
      aria-expanded="false"
      aria-controls="PflegeCatInkSubmenu"
    >
      <span class="pflege-category-modal__link-icon" aria-hidden="true">{% render 'pflege-icon', icon: 'droplet', width: icon_w %}</span>
      <span class="pflege-category-modal__link-label">{{ 'sections.pflege_header_category_rail.cat_ink' | t }}</span>
      <span class="pflege-category-modal__submenu-chevron" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3.6 5.3 7 8.65 10.36 5.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </button>
    <ul
      class="pflege-category-modal__submenu list-unstyled"
      id="PflegeCatInkSubmenu"
      data-pflege-cat-submenu
      hidden
    >
      <li>
        <a
          href="{{ url_ink }}"
          class="pflege-category-modal__sublink{% if active_ink %} is-active{% endif %}"
          data-category-modal-close
          {% if active_ink %}aria-current="page"{% endif %}
        >
          {{ 'sections.pflege_header_category_rail.cat_ink_products' | t }}
        </a>
      </li>
      <li>
        <a
          href="{{ url_ink_rezept }}"
          class="pflege-category-modal__sublink{% if active_ink_rezept %} is-active{% endif %}"
          data-category-modal-close
          {% if active_ink_rezept %}aria-current="page"{% endif %}
        >
          {{ 'sections.pflege_header_category_rail.cat_ink_rezept' | t }}
        </a>
      </li>
    </ul>
  {%- endif -%}
</li>


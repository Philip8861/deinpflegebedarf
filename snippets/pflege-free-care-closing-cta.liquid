{% comment %}
  Abschluss-CTA Pflegebox (Kategorie Kostenfreie Pflegehilfsmittel)
  Parameter: section_id, config_url, info_url
{% endcomment %}
{%- liquid
  assign closing_title_id = 'pfc-free-care-closing-title'
  if section_id != blank
    assign closing_title_id = closing_title_id | append: '-' | append: section_id
  endif
-%}
<section class="pfc-free-care__closing" aria-labelledby="{{ closing_title_id }}">
  <div class="pfc-free-care__closing-card">
    <h2 id="{{ closing_title_id }}" class="pfc-free-care__closing-title">
      {{ 'sections.pflege_collection_free_care.closing_title' | t }}
    </h2>
    <p class="pfc-free-care__closing-text">{{ 'sections.pflege_collection_free_care.closing_text' | t }}</p>
    <div class="pfc-free-care__actions pfc-free-care__actions--closing">
      <a class="pfc-free-care__btn pfc-free-care__btn--primary" href="{{ config_url | escape }}">
        {{ 'sections.pflege_collection_free_care.cta_configure_box' | t }}
      </a>
      <a class="pfc-free-care__btn pfc-free-care__btn--secondary" href="{{ info_url | escape }}">
        {{ 'sections.pflege_collection_free_care.cta_more_info_view' | t }}
      </a>
    </div>
  </div>
</section>

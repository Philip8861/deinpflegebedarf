{% comment %}
  Abschluss-CTA — gleiche Kopf-Optik wie Pflegebox-Artikel (Bestseller-Block), ohne Karten-Hintergrund.
  Parameter: section_id, config_url, info_url
{% endcomment %}
{%- liquid
  assign closing_title_id = 'pfc-free-care-closing-title'
  if section_id != blank
    assign closing_title_id = closing_title_id | append: '-' | append: section_id
  endif
-%}
<section
  class="pflege-bestseller pflege-bestseller--closing-cta pfc-free-care__closing"
  aria-labelledby="{{ closing_title_id }}"
>
  <div class="pflege-bestseller__shell">
    <div class="pflege-bestseller__panel">
      <header class="pflege-bestseller__head">
        <div class="pflege-bestseller__head-text">
          <h2 id="{{ closing_title_id }}" class="pflege-bestseller__title">
            {{ 'sections.pflege_collection_free_care.closing_title' | t }}
          </h2>
          <p class="pflege-bestseller__intro">
            {{ 'sections.pflege_collection_free_care.closing_text' | t }}
          </p>
        </div>
        <div class="pflege-bestseller__closing-actions">
          <a class="pflege-bestseller__closing-cta-primary" href="{{ config_url | escape }}">
            {{ 'sections.pflege_collection_free_care.cta_configure_box' | t }}
          </a>
          <a class="pflege-bestseller__closing-cta-secondary" href="{{ info_url | escape }}">
            {{ 'sections.pflege_collection_free_care.cta_more_info_view' | t }}
          </a>
        </div>
      </header>
    </div>
  </div>
</section>

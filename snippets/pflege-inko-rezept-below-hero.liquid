{% comment %}
  Unter dem Inkontinenz-Hero: Telefon-Beratung + 3 Schritte.
  Parameter: section (optional — Theme-Editor-Einstellungen)
{% endcomment %}
{%- liquid
  assign phone_intro = ''
  assign phone_number = ''
  assign phone_href = ''
  assign phone_hint = ''
  assign steps_title = ''
  assign steps_subtitle = ''
  if section != blank
    assign phone_intro = section.settings.phone_intro | strip
    assign phone_number = section.settings.phone_number | strip
    assign phone_href = section.settings.phone_link | strip
    assign phone_hint = section.settings.phone_hint | strip
    assign steps_title = section.settings.steps_title | strip
    assign steps_subtitle = section.settings.steps_subtitle | strip
  endif
  if phone_intro == blank
    assign phone_intro = 'sections.pflege_inko_rezept_landing.phone_intro' | t
  endif
  if phone_number == blank
    assign phone_number = 'sections.pflege_inko_rezept_landing.phone_number' | t
  endif
  if phone_href == blank
    assign phone_href = 'tel:+4983349893330'
  endif
  if phone_hint == blank
    assign phone_hint = 'sections.pflege_inko_rezept_landing.phone_hint' | t
  endif
  if steps_title == blank
    assign steps_title = 'sections.pflege_inko_rezept_landing.steps_title' | t
  endif
  if steps_subtitle == blank
    assign steps_subtitle = 'sections.pflege_inko_rezept_landing.steps_subtitle' | t
  endif

  assign steps_cta_label = ''
  if section != blank
    assign steps_cta_label = section.settings.button_label | strip
  endif
  if steps_cta_label == blank
    assign steps_cta_label = 'sections.pflege_inko_rezept_landing.button_label' | t
  endif

  assign title_suffix = 'passenden Inkontinenzprodukt'
  assign title_has_break = false
  if steps_title contains title_suffix
    assign title_has_break = true
    assign title_prefix = steps_title | remove: title_suffix | strip
  endif
-%}

<div class="pflege-inko-rezept-below">
  <div class="pflege-inko-rezept-below__backdrop">
    <div class="pflege-inko-rezept-below__shell">
    <div class="pflege-inko-rezept-phone">
      {% render 'pflege-contact-portrait', class: 'pflege-contact-portrait--phone', decorative: true %}
      <div class="pflege-inko-rezept-phone__copy">
        {%- if phone_intro != blank -%}
          <p class="pflege-inko-rezept-phone__label">{{ phone_intro | escape }}</p>
        {%- endif -%}
        <a class="pflege-inko-rezept-phone__number" href="{{ phone_href | escape }}">
          {{ phone_number | escape }}
        </a>
        {%- if phone_hint != blank -%}
          <p class="pflege-inko-rezept-phone__hint">{{ phone_hint | escape }}</p>
        {%- endif -%}
      </div>
    </div>

    <section
      class="pflege-inko-rezept-steps"
      aria-labelledby="pflege-inko-rezept-steps-title-{{ section.id | default: 'fallback' }}"
    >
      <header class="pflege-inko-rezept-steps__head">
        <h2
          id="pflege-inko-rezept-steps-title-{{ section.id | default: 'fallback' }}"
          class="pflege-inko-rezept-steps__title"
        >
          {%- if title_has_break -%}
            <span class="pflege-inko-rezept-steps__title-line">{{ title_prefix | escape }}</span>
            <span class="pflege-inko-rezept-steps__title-line">{{ title_suffix | escape }}</span>
          {%- else -%}
            {{ steps_title | escape }}
          {%- endif -%}
        </h2>
        {%- if steps_subtitle != blank -%}
          <p class="pflege-inko-rezept-steps__subtitle">{{ steps_subtitle | escape }}</p>
        {%- endif -%}
      </header>

      <div class="pflege-inko-rezept-steps__list-wrap">
        <ol class="pflege-inko-rezept-steps__list">
          {%- if section != blank and section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'step' -%}
                <li class="pflege-inko-rezept-steps__item" {{ block.shopify_attributes }}>
                  <article class="pflege-inko-rezept-steps__card">
                    <span class="pflege-inko-rezept-steps__num" aria-hidden="true">{{ forloop.index }}</span>
                    <span class="pflege-inko-rezept-steps__icon" aria-hidden="true">
                      {%- if block.settings.icon == 'headset' -%}
                        {% render 'pflege-icon', icon: 'headset', width: 60 %}
                      {%- elsif block.settings.icon == 'gift' -%}
                        {% render 'pflege-icon', icon: 'gift', width: 60 %}
                      {%- elsif block.settings.icon == 'package' -%}
                        {% render 'pflege-icon', icon: 'package', width: 60 %}
                      {%- elsif block.settings.icon == 'document' -%}
                        {% render 'pflege-icon', icon: 'document', width: 60 %}
                      {%- else -%}
                        {% render 'pflege-icon', icon: 'file-text', width: 60 %}
                      {%- endif -%}
                    </span>
                    <div class="pflege-inko-rezept-steps__copy">
                      <h3 class="pflege-inko-rezept-steps__card-title">{{ block.settings.title | escape }}</h3>
                      {%- if block.settings.text != blank -%}
                        <p class="pflege-inko-rezept-steps__card-text">{{ block.settings.text | escape }}</p>
                      {%- endif -%}
                    </div>
                  </article>
                </li>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            <li class="pflege-inko-rezept-steps__item">
              <article class="pflege-inko-rezept-steps__card">
                <span class="pflege-inko-rezept-steps__num" aria-hidden="true">1</span>
                <span class="pflege-inko-rezept-steps__icon" aria-hidden="true">
                  {% render 'pflege-icon', icon: 'document', width: 60 %}
                </span>
                <div class="pflege-inko-rezept-steps__copy">
                  <h3 class="pflege-inko-rezept-steps__card-title">{{ 'sections.pflege_inko_rezept_landing.step_1_title' | t }}</h3>
                  <p class="pflege-inko-rezept-steps__card-text">{{ 'sections.pflege_inko_rezept_landing.step_1_text' | t }}</p>
                </div>
              </article>
            </li>
            <li class="pflege-inko-rezept-steps__item">
              <article class="pflege-inko-rezept-steps__card">
                <span class="pflege-inko-rezept-steps__num" aria-hidden="true">2</span>
                <span class="pflege-inko-rezept-steps__icon" aria-hidden="true">
                  {% render 'pflege-icon', icon: 'headset', width: 60 %}
                </span>
                <div class="pflege-inko-rezept-steps__copy">
                  <h3 class="pflege-inko-rezept-steps__card-title">{{ 'sections.pflege_inko_rezept_landing.step_2_title' | t }}</h3>
                  <p class="pflege-inko-rezept-steps__card-text">{{ 'sections.pflege_inko_rezept_landing.step_2_text' | t }}</p>
                </div>
              </article>
            </li>
            <li class="pflege-inko-rezept-steps__item">
              <article class="pflege-inko-rezept-steps__card">
                <span class="pflege-inko-rezept-steps__num" aria-hidden="true">3</span>
                <span class="pflege-inko-rezept-steps__icon" aria-hidden="true">
                  {% render 'pflege-icon', icon: 'gift', width: 60 %}
                </span>
                <div class="pflege-inko-rezept-steps__copy">
                  <h3 class="pflege-inko-rezept-steps__card-title">{{ 'sections.pflege_inko_rezept_landing.step_3_title' | t }}</h3>
                  <p class="pflege-inko-rezept-steps__card-text">{{ 'sections.pflege_inko_rezept_landing.step_3_text' | t }}</p>
                </div>
              </article>
            </li>
          {%- endif -%}
        </ol>
      </div>

      {%- if steps_cta_label != blank -%}
        <div class="pflege-inko-rezept-steps__actions">
          <button
            type="button"
            class="pflege-hero__cta pflege-hero__cta--testpaket pflege-inko-rezept-steps__cta"
            data-pflege-inko-testpaket-open
          >
            <span class="pflege-hero__cta-icon" aria-hidden="true">
              {% render 'pflege-icon', icon: 'gift', width: 22 %}
            </span>
            {{ steps_cta_label | escape }}
          </button>
        </div>
      {%- endif -%}
    </section>
    </div>
  </div>
</div>

<style>
  /* Bis component-cart-notification.css lädt (Deferred über media=print): Modal ohne Styles = FOUC mit riesigem SVG */
  .cart-notification-wrapper:not(.is-active) #cart-notification {
    visibility: hidden !important;
    opacity: 0 !important;
  }
</style>
{% comment %}
  Renders cart notification

  Accepts:
  - color_scheme: {String} sets the color scheme of the notification (optional)
  - desktop_menu_type: {String} passes the desktop menu type which allows us to use the right css class (optional)

  Usage:
  {% render 'cart-notification' %}
{% endcomment %}

<cart-notification>
  {%- comment -%} Kein page-width: sonst schmaler Overlay-Bereich, Scrap/Unschärfe am Rand {%- endcomment -%}
  <div class="cart-notification-wrapper">
    <div
      class="cart-notification__backdrop"
      aria-hidden="true"
    ></div>
    <div
      id="cart-notification"
      class="cart-notification focus-inset"
      aria-modal="true"
      aria-labelledby="cart-notification-title"
      role="dialog"
      tabindex="-1"
    >
      <button
        type="button"
        class="cart-notification__close"
        aria-label="{{ 'accessibility.close' | t }}"
      >
        <span class="svg-wrapper" aria-hidden="true">
          {{- 'icon-close.svg' | inline_asset_content -}}
        </span>
      </button>

      <div class="cart-notification__title-row">
        <span class="cart-notification__check" aria-hidden="true">
          {{- 'icon-checkmark.svg' | inline_asset_content -}}
        </span>
        <div class="cart-notification__titles">
          <h2 id="cart-notification-title" class="cart-notification__headline">
            {{ 'general.cart.notification_heading' | t }}
          </h2>
          {%- assign cart_notification_sub = 'general.cart.notification_subtext' | t -%}
          {%- if cart_notification_sub != blank -%}
            <p class="cart-notification__subtext">{{ cart_notification_sub }}</p>
          {%- endif -%}
        </div>
      </div>

      <div id="cart-notification-product" class="cart-notification-product-host"></div>

      <div class="cart-notification__actions">
        <form action="{{ routes.cart_url }}" method="post" id="cart-notification-form" class="cart-notification__form-checkout">
          <button type="submit" class="cart-notification__btn cart-notification__btn--primary" name="checkout">
            <span>{{ 'general.cart.notification_checkout' | t }}</span>
            <span class="cart-notification__btn-arrow" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </button>
        </form>

        <a
          href="{{ routes.cart_url }}"
          id="cart-notification-button"
          class="cart-notification__btn cart-notification__btn--secondary"
        >
          {{- 'general.cart.view' | t: count: cart.item_count -}}
        </a>

        <button type="button" class="cart-notification__link-quiet">
          {{ 'general.cart.notification_continue' | t }}
        </button>
      </div>

      {%- if collections.all.products.size > 0 -%}
        <section class="cart-notification__recos" aria-labelledby="cart-notification-recos-title">
          <h3 id="cart-notification-recos-title" class="cart-notification__recos-heading">
            Produkte, die in keiner guten Pflege fehlen sollten
          </h3>
          <ul class="cart-notification__recos-grid list-unstyled" role="list">
            {%- for reco_product in collections.all.products limit: 4 -%}
              <li class="cart-notification__reco">
                <a
                  href="{{ reco_product.url }}"
                  class="cart-notification__reco-link"
                  aria-label="{{ reco_product.title | escape }} – Produktseite öffnen"
                >
                  <span class="cart-notification__reco-media">
                    {%- if reco_product.featured_image -%}
                      <img
                        src="{{ reco_product.featured_image | image_url: width: 280 }}"
                        srcset="{{ reco_product.featured_image | image_url: width: 200 }} 200w, {{ reco_product.featured_image | image_url: width: 320 }} 320w"
                        sizes="(min-width: 750px) 8rem, 40vw"
                        alt="{{ reco_product.featured_image.alt | default: reco_product.title | escape }}"
                        width="140"
                        height="140"
                        loading="lazy"
                      >
                    {%- else -%}
                      <span class="cart-notification__reco-placeholder" aria-hidden="true">
                        {{- 'product-1' | placeholder_svg_tag: 'placeholder-svg' -}}
                      </span>
                    {%- endif -%}
                  </span>
                  <span class="cart-notification__reco-name">{{ reco_product.title | escape }}</span>
                  <span class="cart-notification__reco-price">
                    {%- if reco_product.price_varies -%}
                      ab {{ reco_product.price_min | money }}
                    {%- else -%}
                      {{ reco_product.price | money }}
                    {%- endif -%}
                  </span>
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </section>
      {%- endif -%}

      <div class="cart-notification__trust" role="presentation">
        <div class="cart-notification__trust-item">
          <span class="cart-notification__trust-icon">
            {%- render 'pflege-icon', icon: 'lock', width: 24 -%}
          </span>
          <div class="cart-notification__trust-copy">
            <span class="cart-notification__trust-title">{{ 'general.cart.trust_pay_title' | t }}</span>
            <span class="cart-notification__trust-sub">{{ 'general.cart.trust_pay_sub' | t }}</span>
          </div>
        </div>
        <div class="cart-notification__trust-item">
          <span class="cart-notification__trust-icon">
            {%- render 'pflege-icon', icon: 'badge-check', width: 24 -%}
          </span>
          <div class="cart-notification__trust-copy">
            <span class="cart-notification__trust-title">{{ 'general.cart.trust_quality_title' | t }}</span>
            <span class="cart-notification__trust-sub">{{ 'general.cart.trust_quality_sub' | t }}</span>
          </div>
        </div>
        <div class="cart-notification__trust-item">
          <span class="cart-notification__trust-icon">
            {%- render 'pflege-icon', icon: 'truck', width: 24 -%}
          </span>
          <div class="cart-notification__trust-copy">
            <span class="cart-notification__trust-title">{{ 'general.cart.trust_ship_title' | t }}</span>
            <span class="cart-notification__trust-sub">{{ 'general.cart.trust_ship_sub' | t }}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</cart-notification>

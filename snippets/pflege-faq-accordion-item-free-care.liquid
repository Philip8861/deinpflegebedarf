{% comment %} PHM-Kollektion: feste Locale-Keys (1–14) {% endcomment %}
{%- liquid
  assign idx = index | plus: 0
  assign faq_q = ''
  assign faq_a = ''

  case idx
    when 1
      assign faq_q = 'sections.pflege_collection_free_care.faq_1_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_1_a' | t
    when 2
      assign faq_q = 'sections.pflege_collection_free_care.faq_2_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_2_a' | t
    when 3
      assign faq_q = 'sections.pflege_collection_free_care.faq_3_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_3_a' | t
    when 4
      assign faq_q = 'sections.pflege_collection_free_care.faq_4_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_4_a' | t
    when 5
      assign faq_q = 'sections.pflege_collection_free_care.faq_5_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_5_a' | t
    when 6
      assign faq_q = 'sections.pflege_collection_free_care.faq_6_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_6_a' | t
    when 7
      assign faq_q = 'sections.pflege_collection_free_care.faq_7_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_7_a' | t
    when 8
      assign faq_q = 'sections.pflege_collection_free_care.faq_8_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_8_a' | t
    when 9
      assign faq_q = 'sections.pflege_collection_free_care.faq_9_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_9_a' | t
    when 10
      assign faq_q = 'sections.pflege_collection_free_care.faq_10_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_10_a' | t
    when 11
      assign faq_q = 'sections.pflege_collection_free_care.faq_11_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_11_a' | t
    when 12
      assign faq_q = 'sections.pflege_collection_free_care.faq_12_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_12_a' | t
    when 13
      assign faq_q = 'sections.pflege_collection_free_care.faq_13_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_13_a' | t
    when 14
      assign faq_q = 'sections.pflege_collection_free_care.faq_14_q' | t
      assign faq_a = 'sections.pflege_collection_free_care.faq_14_a' | t
  endcase

  assign item_id = 'pflege-faq-' | append: section_id | append: '-' | append: idx
  assign trigger_id = item_id | append: '-trigger'
  assign panel_id = item_id | append: '-panel'
-%}
{%- if faq_q != blank -%}
  <div class="pflege-faq-accordion__item" role="listitem" data-faq-accordion-item id="{{ item_id }}">
    <h3 class="pflege-faq-accordion__question">
      <button
        type="button"
        class="pflege-faq-accordion__trigger"
        id="{{ trigger_id }}"
        data-faq-accordion-trigger
        aria-expanded="false"
        aria-controls="{{ panel_id }}"
      >
        <span class="pflege-faq-accordion__trigger-text">{{ faq_q }}</span>
        <span class="pflege-faq-accordion__chevron" aria-hidden="true"></span>
      </button>
    </h3>
    <div
      id="{{ panel_id }}"
      class="pflege-faq-accordion__panel"
      role="region"
      aria-labelledby="{{ trigger_id }}"
      data-faq-accordion-panel
      hidden
    >
      <div class="pflege-faq-accordion__answer rte">
        {%- if faq_a contains '<' -%}
          {{ faq_a }}
        {%- else -%}
          <p>{{ faq_a }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}

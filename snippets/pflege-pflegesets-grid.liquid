{% comment %}
  Pflegesets — zentrale 3-Kachel-Logik für Startseite und Pflegesets-Seite.

  Parameter:
  - pfs_section: Section-Objekt (settings)
  - card_style: "promo" | "category"
  - pflege_col: optional, bereits aufgelöste Kollektion

  Produkt-Auflösung (pro Slot S/L/M):
  1. Kollektion „pflegesets“ (Setting oder Shop-Kollektion)
  2. Produktauswahl product_1/2/3 im Theme-Editor
  3. Handle-Match in der Kollektion
  4. all_products[handle] (Startseite zuverlässiger als Pages)
{% endcomment %}
{%- liquid
  assign pfs = pfs_section.settings
  assign style = card_style | default: 'promo'
  assign col = pflege_col
  if col == blank
    assign col = pfs.pflegesets_collection
  endif
  if col == blank and collection != blank and collection.handle == 'pflegesets' and collection.all_products_count > 0
    assign col = collection
  endif
  if col == blank and collections['pflegesets'] != blank and collections['pflegesets'].all_products_count > 0
    assign col = collections['pflegesets']
  endif

  assign ha = pfs.handle_1 | default: 'pflegeset-grosse-s' | strip
  assign hb = pfs.handle_2 | default: 'pflegeset-grosse-l' | strip
  assign hc = pfs.handle_3 | default: 'pflegeset-grosse-m' | strip
  assign slot_handles = ha | append: '|||' | append: hb | append: '|||' | append: hc | split: '|||'

  assign badge_label = pfs.badge_text | strip
  if badge_label == blank
    assign badge_label = shop.metafields.pflegeshop.pflegesets_badge.value | strip
  endif
  if badge_label == blank
    assign badge_label = 'Sie sparen 10%'
  endif

  assign rendered_count = 0
-%}

{%- for handle_raw in slot_handles -%}
  {%- assign handle = handle_raw | strip -%}
  {%- liquid
    assign card_product = nil
    assign slot_index = forloop.index
    assign disp_title = ''
    assign slot_contents = ''
    assign slot_setting = ''

    case slot_index
      when 1
        if pfs.product_1 != blank
          assign card_product = pfs.product_1
        endif
        assign disp_title = pfs.display_title_1 | strip
        assign slot_setting = pfs.contents_1
      when 2
        if pfs.product_2 != blank
          assign card_product = pfs.product_2
        endif
        assign disp_title = pfs.display_title_2 | strip
        assign slot_setting = pfs.contents_2
      when 3
        if pfs.product_3 != blank
          assign card_product = pfs.product_3
        endif
        assign disp_title = pfs.display_title_3 | strip
        assign slot_setting = pfs.contents_3
    endcase

    if card_product == blank and col != blank
      for col_product in col.products
        if col_product.handle == handle
          assign card_product = col_product
          break
        endif
      endfor
    endif

    if card_product == blank and col != blank
      for col_product in col.products limit: 3
        if forloop.index == slot_index
          assign card_product = col_product
          break
        endif
      endfor
    endif

    if card_product == blank
      assign card_product = all_products[handle]
    endif
    if card_product == blank
      assign alt_h = handle | replace: 'grosse', 'groesse'
      if alt_h != handle
        assign card_product = all_products[alt_h]
      endif
    endif
    if card_product == blank
      assign alt_h = handle | replace: 'groesse', 'grosse'
      if alt_h != handle
        assign card_product = all_products[alt_h]
      endif
    endif
  -%}
  {%- capture slot_contents -%}
    {%- render 'pflege-pflegeset-resolve-contents',
      slot: slot_index,
      setting_value: slot_setting
    -%}
  {%- endcapture -%}
  {%- assign slot_contents = slot_contents | strip -%}

  {%- if style == 'category' and card_product != blank -%}
    {%- assign rendered_count = rendered_count | plus: 1 -%}
    {% render 'pflege-cat-card',
      card_product: card_product,
      list_item: false,
      card_title_override: disp_title
    %}
  {%- elsif style == 'promo' -%}
    {%- assign rendered_count = rendered_count | plus: 1 -%}
    {% render 'pflege-pflegeset-card',
      card_product: card_product,
      handle_fallback: handle,
      badge_label: badge_label,
      card_contents: slot_contents,
      card_title: disp_title
    %}
  {%- endif -%}
{%- endfor -%}

{%- if rendered_count == 0 -%}
  <div class="pflege-pflegesets__empty">
    <p class="pflege-pflegesets__empty-title">Pflegesets konnten nicht geladen werden</p>
    <p class="pflege-pflegesets__empty-text">
      Bitte legen Sie im Shopify-Admin eine Kollektion mit dem Handle <strong>pflegesets</strong> an,
      fügen Sie die drei Set-Produkte (S, L, M) hinzu und wählen Sie die Kollektion im Theme-Editor
      unter „Kollektion mit den Pflegesets“.
    </p>
  </div>
{%- endif -%}

{% comment %}
  Elektronische Widerrufsfunktion (§ 356a BGB) — zweistufiger Ablauf.
  Shopify-Kontaktformular → Shop-Benachrichtigung; Kunden-E-Mail via Shopify Flow (siehe scripts/shopify-flow-widerruf-setup.md).

  Parameter:
  - standalone: true auf /pages/vertrag-widerrufen (Formular immer sichtbar, ohne Aufklapper)
  - placement: 'top' | default (Layout auf Widerrufsbelehrung, falls eingebettet)
{% endcomment %}
{{ 'pflege-withdrawal-form.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign wd_standalone = standalone | default: false
  assign url_privacy = routes.root_url | append: 'pages/datenschutzerklaerung'
  if page.url != blank
    assign wd_return_to = shop.secure_url | append: page.url | append: '?widerruf=1'
  else
    assign wd_return_to = shop.secure_url | append: request.path | append: '?widerruf=1'
  endif
  assign wd_is_success = false
  if page.handle == 'vertrag-widerrufen' and form.posted_successfully?
    assign wd_is_success = true
  endif
  assign wd_tz = 'Europe/Berlin'
  assign wd_now_date = 'now' | date: '%d.%m.%Y'
  assign wd_now_time = 'now' | date: '%H:%M'
  assign wd_show_intro = true
  if wd_is_success or request.query_string contains 'widerruf'
    assign wd_show_intro = false
  endif
-%}

<div
  class="pflege-withdrawal{% if wd_standalone %} pflege-withdrawal--standalone{% endif %}{% if placement == 'top' %} pflege-withdrawal--top{% endif %}"
  id="pflege-withdrawal"
  data-pflege-withdrawal
  {% if wd_standalone %}data-pflege-withdrawal-standalone{% endif %}
  data-pflege-withdrawal-tz="{{ wd_tz | escape }}"
  {% if request.query_string contains 'widerruf' %}data-pflege-withdrawal-query-success{% endif %}
>
  {%- unless wd_standalone -%}
    <div class="pflege-withdrawal__intro">
      <h2 class="pflege-withdrawal__heading" id="pflege-withdrawal-heading">Elektronische Widerrufsfunktion</h2>
      <p class="pflege-withdrawal__lead">
        Sie können Ihren Widerruf auch direkt online erklären. Ein Widerrufsgrund ist nicht erforderlich.
      </p>
      <p class="pflege-withdrawal__lead pflege-withdrawal__lead--note">
        <a href="{{ routes.root_url }}pages/vertrag-widerrufen">Zur Seite „Vertrag widerrufen“</a>
      </p>
    </div>
  {%- endunless -%}

  {%- if wd_standalone and wd_show_intro -%}
    <p class="pflege-withdrawal__page-intro">
      Hier können Sie den Widerruf eines über unseren Onlineshop geschlossenen Vertrags erklären. Bitte geben Sie die
      erforderlichen Angaben ein, damit wir Ihre Bestellung zuordnen und Ihnen den Eingang des Widerrufs bestätigen
      können. Ein Widerrufsgrund ist nicht erforderlich.
    </p>
  {%- endif -%}

  {%- unless wd_standalone -%}
    <a href="{{ routes.root_url }}pages/vertrag-widerrufen" class="pflege-withdrawal__cta-link">
      Vertrag widerrufen
    </a>
  {%- else -%}
    <div
      class="pflege-withdrawal__panel pflege-withdrawal__panel--open"
      data-pflege-withdrawal-panel
      role="region"
      aria-labelledby="pflege-withdrawal-form-title"
    >
      {%- form 'contact', id: 'PflegeWithdrawalForm', class: 'pflege-withdrawal__form', data-pflege-withdrawal-form: '', aria-label: 'Widerrufsformular' -%}
        <input type="hidden" name="return_to" value="{{ wd_return_to | escape }}">
        <input type="hidden" name="contact[tags]" value="widerruf, deinpflegebedarf">
        <input type="hidden" name="contact[subject]" value="Widerrufserklärung — deinpflegebedarf.de">
        <input type="hidden" name="contact[Vorgangsnummer]" value="" data-pflege-withdrawal-case-id>
        <input type="hidden" name="contact[Submission-ID]" value="" data-pflege-withdrawal-submission-id>
        <input type="hidden" name="contact[Zeitzone]" value="{{ wd_tz | escape }}">
        <input
          type="hidden"
          name="contact[Erklaerungstext]"
          value="Hiermit widerrufe ich den von mir abgeschlossenen Vertrag über die angegebene Bestellung beziehungsweise die angegebenen Artikel."
          data-pflege-withdrawal-declaration
        >
        <input type="hidden" name="contact[Widerrufsumfang]" value="" data-pflege-withdrawal-scope-hidden>
        <input type="hidden" name="contact[Bestellangaben]" value="" data-pflege-withdrawal-order-hidden>
        <input type="hidden" name="contact[Betroffene Artikel]" value="" data-pflege-withdrawal-items-hidden>
        <input type="hidden" name="contact[Bestelldatum]" value="" data-pflege-withdrawal-date-hidden>
        <input type="hidden" name="contact[Zusatznachricht]" value="" data-pflege-withdrawal-message-hidden>
        <textarea name="contact[body]" class="pflege-withdrawal__body-hidden" data-pflege-withdrawal-body aria-hidden="true" tabindex="-1"></textarea>

        {%- if form.posted_successfully? and page.handle == 'vertrag-widerrufen' -%}
          <div class="pflege-withdrawal__success" data-pflege-withdrawal-success role="status" tabindex="-1">
            <h2 class="pflege-withdrawal__success-title">Ihr Widerruf wurde übermittelt</h2>
            <p class="pflege-withdrawal__success-lead">
              Wir haben Ihre Widerrufserklärung am <strong>{{ wd_now_date }}</strong> um <strong>{{ wd_now_time }} Uhr ({{ wd_tz }})</strong> erhalten.
              {%- if form.email != blank -%}
                Eine Eingangsbestätigung wurde an <strong>{{ form.email | escape }}</strong> gesendet.
              {%- endif -%}
            </p>
            <p class="pflege-withdrawal__success-case" data-pflege-withdrawal-success-case>
              <strong>Vorgangsnummer:</strong> <span data-pflege-withdrawal-case-display></span>
            </p>
            <p class="pflege-withdrawal__success-note">
              Diese Bestätigung bezieht sich ausschließlich auf den Eingang Ihrer Erklärung — nicht auf eine rechtliche
              Prüfung oder die Rückabwicklung des Vertrags.
            </p>
            <article class="pflege-withdrawal__receipt" aria-labelledby="pflege-withdrawal-receipt-title">
              <h3 id="pflege-withdrawal-receipt-title" class="pflege-withdrawal__receipt-title">Ihre übermittelten Angaben</h3>
              {%- if form.body != blank -%}
                <pre class="pflege-withdrawal__receipt-pre">{{ form.body | escape }}</pre>
              {%- endif -%}
              <button type="button" class="pflege-withdrawal__print" data-pflege-withdrawal-print>
                Bestätigung drucken / als PDF speichern
              </button>
            </article>
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <div class="pflege-withdrawal__alert pflege-withdrawal__alert--error" role="alert" data-pflege-withdrawal-errors>
              <p><strong>Bitte prüfen Sie die markierten Felder.</strong></p>
            </div>
          {%- endif -%}

          <p class="pflege-withdrawal__required-note">
            Alle mit <abbr title="Pflichtfeld" class="pflege-withdrawal__req">*</abbr> markierten Felder sind Pflichtfelder.
          </p>

          <div class="pflege-withdrawal__step" data-pflege-withdrawal-step="1">
            <h2 class="pflege-withdrawal__step-title" id="pflege-withdrawal-form-title">Ihre Angaben</h2>

            <div class="pflege-withdrawal__fields">
              <div class="pflege-withdrawal__field">
                <label class="pflege-withdrawal__label" for="PflegeWithdrawal-name">
                  Vor- und Nachname
                  <abbr title="Pflichtfeld" class="pflege-withdrawal__req">*</abbr>
                </label>
                <input
                  class="pflege-withdrawal__input"
                  type="text"
                  id="PflegeWithdrawal-name"
                  name="contact[name]"
                  autocomplete="name"
                  required
                  aria-required="true"
                  data-pflege-withdrawal-name
                  value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                >
                <p class="pflege-withdrawal__field-error" data-pflege-withdrawal-error="name" hidden role="alert"></p>
              </div>

              <div class="pflege-withdrawal__field">
                <label class="pflege-withdrawal__label" for="PflegeWithdrawal-email">
                  E-Mail-Adresse für die Eingangsbestätigung
                  <abbr title="Pflichtfeld" class="pflege-withdrawal__req">*</abbr>
                </label>
                <input
                  class="pflege-withdrawal__input"
                  type="email"
                  id="PflegeWithdrawal-email"
                  name="contact[email]"
                  autocomplete="email"
                  spellcheck="false"
                  autocapitalize="off"
                  required
                  aria-required="true"
                  data-pflege-withdrawal-email
                  value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                  {% if form.errors contains 'email' %}aria-invalid="true"{% endif %}
                >
                <p class="pflege-withdrawal__field-error" data-pflege-withdrawal-error="email" hidden role="alert"></p>
              </div>

              <div class="pflege-withdrawal__field pflege-withdrawal__field--full">
                <label class="pflege-withdrawal__label" for="PflegeWithdrawal-order-info">
                  Angaben zur Bestellung
                  <abbr title="Pflichtfeld" class="pflege-withdrawal__req">*</abbr>
                </label>
                <p class="pflege-withdrawal__hint" id="PflegeWithdrawal-order-hint">
                  Geben Sie möglichst Ihre Bestellnummer an. Falls Ihnen diese nicht vorliegt, nennen Sie bitte das
                  Bestelldatum und die bestellten Artikel.
                </p>
                <textarea
                  class="pflege-withdrawal__textarea"
                  id="PflegeWithdrawal-order-info"
                  rows="3"
                  required
                  aria-required="true"
                  aria-describedby="PflegeWithdrawal-order-hint"
                  data-pflege-withdrawal-order-info
                ></textarea>
                <p class="pflege-withdrawal__field-error" data-pflege-withdrawal-error="order-info" hidden role="alert"></p>
              </div>

              <fieldset class="pflege-withdrawal__field pflege-withdrawal__field--full pflege-withdrawal__fieldset" data-pflege-withdrawal-scope-group>
                <legend class="pflege-withdrawal__label">
                  Umfang des Widerrufs
                  <abbr title="Pflichtfeld" class="pflege-withdrawal__req">*</abbr>
                </legend>
                <div class="pflege-withdrawal__radios">
                  <label class="pflege-withdrawal__radio">
                    <input type="radio" name="pflege-withdrawal-scope" value="full" data-pflege-withdrawal-scope required aria-required="true">
                    <span>Ich widerrufe die gesamte Bestellung</span>
                  </label>
                  <label class="pflege-withdrawal__radio">
                    <input type="radio" name="pflege-withdrawal-scope" value="partial" data-pflege-withdrawal-scope>
                    <span>Ich widerrufe nur einen Teil der Bestellung</span>
                  </label>
                </div>
                <p class="pflege-withdrawal__field-error" data-pflege-withdrawal-error="scope" hidden role="alert"></p>
              </fieldset>

              <div class="pflege-withdrawal__field pflege-withdrawal__field--full" data-pflege-withdrawal-partial-wrap hidden>
                <label class="pflege-withdrawal__label" for="PflegeWithdrawal-partial-items">
                  Welche Artikel möchten Sie widerrufen?
                  <abbr title="Pflichtfeld" class="pflege-withdrawal__req">*</abbr>
                </label>
                <p class="pflege-withdrawal__hint" id="PflegeWithdrawal-partial-hint">
                  Bitte nennen Sie die betreffenden Artikel und, falls relevant, die jeweilige Menge.
                </p>
                <textarea
                  class="pflege-withdrawal__textarea"
                  id="PflegeWithdrawal-partial-items"
                  rows="3"
                  aria-describedby="PflegeWithdrawal-partial-hint"
                  data-pflege-withdrawal-partial-items
                ></textarea>
                <p class="pflege-withdrawal__field-error" data-pflege-withdrawal-error="partial-items" hidden role="alert"></p>
              </div>

              <div class="pflege-withdrawal__field pflege-withdrawal__field--half">
                <label class="pflege-withdrawal__label" for="PflegeWithdrawal-order-date">
                  Bestelldatum <span class="pflege-withdrawal__optional">(optional)</span>
                </label>
                <input
                  class="pflege-withdrawal__input"
                  type="date"
                  id="PflegeWithdrawal-order-date"
                  data-pflege-withdrawal-order-date
                >
              </div>

              <div class="pflege-withdrawal__field pflege-withdrawal__field--full">
                <label class="pflege-withdrawal__label" for="PflegeWithdrawal-message">
                  Zusätzliche Nachricht <span class="pflege-withdrawal__optional">(optional)</span>
                </label>
                <textarea
                  class="pflege-withdrawal__textarea"
                  id="PflegeWithdrawal-message"
                  rows="2"
                  data-pflege-withdrawal-message
                ></textarea>
              </div>
            </div>

            <p class="pflege-withdrawal__privacy">
              Hinweise zur Verarbeitung Ihrer Angaben finden Sie in unserer
              <a href="{{ url_privacy }}">Datenschutzerklärung</a>.
            </p>

            <button type="button" class="pflege-withdrawal__submit" data-pflege-withdrawal-review>
              Angaben prüfen
            </button>
          </div>

          <div class="pflege-withdrawal__step" data-pflege-withdrawal-step="2" hidden>
            <h2 class="pflege-withdrawal__step-title">Widerruf prüfen und bestätigen</h2>
            <dl class="pflege-withdrawal__summary" data-pflege-withdrawal-summary aria-live="polite"></dl>
            <p class="pflege-withdrawal__declaration-preview" data-pflege-withdrawal-declaration-preview>
              „Hiermit widerrufe ich den von mir abgeschlossenen Vertrag über die angegebene Bestellung beziehungsweise die
              angegebenen Artikel.“
            </p>
            <div class="pflege-withdrawal__step-actions">
              <button type="button" class="pflege-withdrawal__secondary" data-pflege-withdrawal-edit>
                Angaben bearbeiten
              </button>
              <button type="submit" class="pflege-withdrawal__submit" data-pflege-withdrawal-confirm disabled>
                Widerruf bestätigen
              </button>
            </div>
            <p class="pflege-withdrawal__submit-status" data-pflege-withdrawal-submit-status hidden role="status" aria-live="polite"></p>
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  {%- endunless -%}
</div>
<script src="{{ 'pflege-withdrawal-form.js' | asset_url }}" defer="defer"></script>

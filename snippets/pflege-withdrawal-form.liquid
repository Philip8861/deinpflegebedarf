{% comment %}
  Elektronische Widerrufsfunktion (§ 312g BGB i. V. m. Art. 246a EGBGB).
  Shopify-Kontaktformular → Shop-Benachrichtigung; Bestätigung an Kunden per E-Mail durch den Händler.
  Zieladresse: info@alltagshilfe-sued.de (Shopify Admin → Einstellungen → Allgemein / Benachrichtigungen).
{% endcomment %}
{{ 'pflege-withdrawal-form.css' | asset_url | stylesheet_tag }}

<div class="pflege-withdrawal" id="pflege-withdrawal" data-pflege-withdrawal>
  <div class="pflege-withdrawal__intro">
    <h2 class="pflege-withdrawal__heading" id="pflege-withdrawal-heading">Elektronische Widerrufsfunktion</h2>
    <p class="pflege-withdrawal__lead">
      Sie können Ihren Widerruf unmittelbar über das folgende Formular erklären. Alternativ genügen weiterhin Brief oder
      E-Mail an die oben genannten Kontaktdaten. Ein Widerrufsgrund ist nicht erforderlich.
    </p>
  </div>

  <button
    type="button"
    class="pflege-withdrawal__toggle"
    data-pflege-withdrawal-toggle
    aria-expanded="false"
    aria-controls="pflege-withdrawal-panel"
  >
    Vertrag widerrufen
  </button>

  <div
    id="pflege-withdrawal-panel"
    class="pflege-withdrawal__panel"
    data-pflege-withdrawal-panel
    role="region"
    aria-labelledby="pflege-withdrawal-heading"
    hidden
  >
    {%- form 'contact', id: 'PflegeWithdrawalForm', class: 'pflege-withdrawal__form', data-pflege-withdrawal-form: '', aria-label: 'Widerrufsformular' -%}
      <input type="hidden" name="contact[tags]" value="widerruf, deinpflegebedarf">
      <input type="hidden" name="contact[subject]" value="Widerrufserklärung — deinpflegebedarf.de">
      <textarea
        class="visually-hidden"
        name="contact[body]"
        id="PflegeWithdrawal-body"
        rows="8"
        data-pflege-withdrawal-body
        aria-hidden="true"
        tabindex="-1"
      >{% if form.body %}{{ form.body }}{% endif %}</textarea>

      {%- if form.posted_successfully? -%}
        {%- assign receipt_timestamp = 'now' | date: '%d.%m.%Y, %H:%M' -%}
        <div class="pflege-withdrawal__alert pflege-withdrawal__alert--success" role="status" tabindex="-1" data-pflege-withdrawal-success>
          Ihr Widerruf wurde übermittelt. Ihre Eingangsbestätigung finden Sie direkt darunter — bitte speichern oder ausdrucken.
        </div>

        <article
          class="pflege-withdrawal__receipt"
          id="pflege-withdrawal-receipt"
          data-pflege-withdrawal-receipt
          aria-labelledby="pflege-withdrawal-receipt-title"
        >
          <h3 id="pflege-withdrawal-receipt-title" class="pflege-withdrawal__receipt-title">
            Eingangsbestätigung Ihres Widerrufs
          </h3>
          <p class="pflege-withdrawal__receipt-meta">
            <strong>deinpflegebedarf.de</strong> — V. Maucher und Philip Sonntag GbR, Alltagshilfe Süd<br>
            Eingang am {{ receipt_timestamp }} Uhr (Shop-Zeit)
          </p>
          <p class="pflege-withdrawal__receipt-lead">
            Wir bestätigen den Eingang Ihrer Widerrufserklärung. Ein Widerrufsgrund war nicht erforderlich.
          </p>
          <dl class="pflege-withdrawal__receipt-dl">
            {%- if form.name != blank -%}
              <div class="pflege-withdrawal__receipt-row">
                <dt>Name</dt>
                <dd>{{ form.name | escape }}</dd>
              </div>
            {%- endif -%}
            {%- if form.email != blank -%}
              <div class="pflege-withdrawal__receipt-row">
                <dt>E-Mail</dt>
                <dd>{{ form.email | escape }}</dd>
              </div>
            {%- endif -%}
          </dl>
          {%- if form.body != blank -%}
            <div class="pflege-withdrawal__receipt-body">
              <p class="pflege-withdrawal__receipt-body-label">Ihre Angaben:</p>
              <pre class="pflege-withdrawal__receipt-pre">{{ form.body | escape }}</pre>
            </div>
          {%- endif -%}
          <p class="pflege-withdrawal__receipt-hint">
            Diese Bestätigung können Sie als Nachweis speichern (z. B. Drucken → „Als PDF speichern“).
          </p>
          <button type="button" class="pflege-withdrawal__print" data-pflege-withdrawal-print>
            Bestätigung drucken / als PDF speichern
          </button>
        </article>

        {%- if form.email != blank -%}
          <p class="pflege-withdrawal__email-note" data-pflege-withdrawal-email-note>
            Zusätzlich senden wir eine E-Mail-Bestätigung an <strong>{{ form.email | escape }}</strong>, sobald Ihr
            Widerruf bei uns verarbeitet wurde.
          </p>
        {%- endif -%}
      {%- elsif form.errors -%}
        <div class="pflege-withdrawal__alert pflege-withdrawal__alert--error" role="alert" tabindex="-1">
          <p><strong>Bitte prüfen Sie die markierten Felder.</strong></p>
          {%- if form.errors contains 'email' -%}
            <p class="pflege-withdrawal__field-error">
              <a href="#PflegeWithdrawal-email">{{ form.errors.messages.email }}</a>
            </p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- unless form.posted_successfully? -%}
        <div class="pflege-withdrawal__fields">
          <div class="pflege-withdrawal__field">
            <label class="pflege-withdrawal__label" for="PflegeWithdrawal-name">
              Vorname und Nachname
              <abbr title="Pflichtfeld" class="pflege-withdrawal__req">*</abbr>
            </label>
            <input
              class="pflege-withdrawal__input"
              type="text"
              id="PflegeWithdrawal-name"
              name="contact[name]"
              autocomplete="name"
              required
              aria-required="true"
              data-pflege-withdrawal-name
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            >
          </div>

          <div class="pflege-withdrawal__field">
            <label class="pflege-withdrawal__label" for="PflegeWithdrawal-email">
              E-Mail-Adresse
              <abbr title="Pflichtfeld" class="pflege-withdrawal__req">*</abbr>
            </label>
            <input
              class="pflege-withdrawal__input"
              type="email"
              id="PflegeWithdrawal-email"
              name="contact[email]"
              autocomplete="email"
              spellcheck="false"
              autocapitalize="off"
              required
              aria-required="true"
              data-pflege-withdrawal-email
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              {% if form.errors contains 'email' %}aria-invalid="true"{% endif %}
            >
          </div>

          <div class="pflege-withdrawal__field">
            <label class="pflege-withdrawal__label" for="PflegeWithdrawal-order">
              Bestellnummer
              <abbr title="Pflichtfeld" class="pflege-withdrawal__req">*</abbr>
            </label>
            <input
              class="pflege-withdrawal__input"
              type="text"
              id="PflegeWithdrawal-order"
              autocomplete="off"
              required
              aria-required="true"
              data-pflege-withdrawal-order
            >
          </div>

          <div class="pflege-withdrawal__field pflege-withdrawal__field--half">
            <label class="pflege-withdrawal__label" for="PflegeWithdrawal-ordered">
              Bestelldatum <span class="pflege-withdrawal__optional">(optional)</span>
            </label>
            <input
              class="pflege-withdrawal__input"
              type="date"
              id="PflegeWithdrawal-ordered"
              data-pflege-withdrawal-ordered
            >
          </div>

          <div class="pflege-withdrawal__field pflege-withdrawal__field--half">
            <label class="pflege-withdrawal__label" for="PflegeWithdrawal-received">
              Erhalten am <span class="pflege-withdrawal__optional">(optional)</span>
            </label>
            <input
              class="pflege-withdrawal__input"
              type="date"
              id="PflegeWithdrawal-received"
              data-pflege-withdrawal-received
            >
          </div>

          <div class="pflege-withdrawal__field">
            <label class="pflege-withdrawal__label" for="PflegeWithdrawal-items">
              Artikel oder Beschreibung der Ware
              <abbr title="Pflichtfeld" class="pflege-withdrawal__req">*</abbr>
            </label>
            <textarea
              class="pflege-withdrawal__textarea"
              id="PflegeWithdrawal-items"
              rows="3"
              required
              aria-required="true"
              data-pflege-withdrawal-items
            ></textarea>
          </div>

          <div class="pflege-withdrawal__field">
            <label class="pflege-withdrawal__label" for="PflegeWithdrawal-message">
              Nachricht <span class="pflege-withdrawal__optional">(optional)</span>
            </label>
            <textarea
              class="pflege-withdrawal__textarea"
              id="PflegeWithdrawal-message"
              rows="2"
              data-pflege-withdrawal-message
            ></textarea>
          </div>

          <div class="pflege-withdrawal__field pflege-withdrawal__field--check">
            <input
              class="pflege-withdrawal__checkbox"
              type="checkbox"
              id="PflegeWithdrawal-confirm"
              value="1"
              required
              aria-required="true"
              data-pflege-withdrawal-confirm
            >
            <label class="pflege-withdrawal__check-label" for="PflegeWithdrawal-confirm">
              Ich möchte den Vertrag widerrufen.
            </label>
          </div>
        </div>

        <button type="submit" class="pflege-withdrawal__submit">
          Widerruf absenden
        </button>
        <p class="pflege-withdrawal__fineprint">
          Mit dem Absenden übermitteln Sie eine eindeutige Widerrufserklärung. Wir bestätigen den Eingang unverzüglich, in
          der Regel per E-Mail an die von Ihnen angegebene Adresse.
        </p>
      {%- endunless -%}
    {%- endform -%}
  </div>
</div>
<script src="{{ 'pflege-withdrawal-form.js' | asset_url }}" defer></script>

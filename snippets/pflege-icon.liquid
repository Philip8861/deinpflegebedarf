{%- comment -%}
  Inline SVG icons for PflegeShop sections (stroke, currentColor).
  Accepts: icon (string), class (string, optional), width (number, default 20)
{%- endcomment -%}
{%- liquid
  assign icon_id = icon | default: 'package'
  assign svg_class = class | default: ''
  assign w = width | default: 20
-%}
<span class="pflege-icon {{ svg_class }}" aria-hidden="true">
  {%- case icon_id -%}
    {%- when 'truck' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
    {%- when 'document' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="m9 15 2 2 4-4"/></svg>
    {%- when 'ticket' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg>
    {%- when 'star' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    {%- when 'headset' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1v-3"/><path d="M3 19a2 2 0 0 0 2 2h1v-3"/><path d="M12 12v0"/></svg>
    {%- when 'shield' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
    {%- when 'package' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m21 16-7.43-5-7.43 5"/><path d="M3 16V8a2 2 0 0 1 1.07-1.76l7.43-4a2 2 0 0 1 1.86 0l7.43 4A2 2 0 0 1 21 8v8"/><path d="m12 4-8.57 5"/><path d="m12 12 9-5"/><path d="M12 12v10"/></svg>
    {%- when 'menu' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round"><path d="M5 7h14"/><path d="M5 12h14"/><path d="M5 17h14"/></svg>
    {%- when 'bandage' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="10" rx="2" transform="rotate(-12 12 12)"/><path d="m7.8 10.2 2.4 2.4"/><path d="m10 8 2.4 2.4"/><path d="m12.6 10.6 2.4 2.4"/><path d="m15 8.2 2.2 2.2"/></svg>
    {%- when 'cross-medical' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
    {%- when 'bowl' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12c1.5 4.5 5.5 8 7 8s5.5-3.5 7-8"/><path d="M4 12h16"/><path d="M8 7c1-1.2 2.5-2 4-2s3 .8 4 2"/></svg>
    {%- when 'hand' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M8 10V7a2 2 0 0 1 2-2v0a2 2 0 0 1 2 2v11"/><path d="M10 7V6a2 2 0 0 1 4 0v1"/><path d="M12 5V4a2 2 0 0 1 4 0v9"/><path d="M14 7v10"/><path d="M16 11a2 2 0 0 1 2 2v1a4 4 0 0 1-4 4h-5a4 4 0 0 1-4-4v-1a3 3 0 0 1 6 0"/><path d="M17 13h1a3 3 0 0 1 3 3v1"/></svg>
    {%- when 'accessibility' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="5" r="1.75"/><path d="M12 21V10"/><path d="m17 21-5-6-5 6"/></svg>
    {%- when 'sparkles' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.265 1.265L3 12l5.835 1.935a2 2 0 0 1 1.265 1.265L12 21l1.935-5.8a2 2 0 0 1 1.265-1.265L21 12l-5.8-1.935a2 2 0 0 1-1.265-1.265Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 21h4"/></svg>
    {%- when 'droplet' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-6-7-13-7-13S5 9 5 15a7 7 0 0 0 7 7z"/></svg>
    {%- when 'heart' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78Z"/></svg>
    {%- when 'cart' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
    {%- when 'rotate-ccw' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
    {%- when 'phone' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    {%- when 'mail' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
    {%- when 'clock' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
    {%- when 'lock' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    {%- when 'badge-check' -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/></svg>
    {%- else -%}
      <svg xmlns="http://www.w3.org/2000/svg" width="{{ w }}" height="{{ w }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
  {%- endcase -%}
</span>

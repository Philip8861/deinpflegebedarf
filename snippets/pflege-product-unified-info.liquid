{%- comment -%}
  Einheitlicher Informationsblock. show_placeholders: leere Felder mit Übersetzungs-Platzhaltern füllen.
{%- endcomment -%}
{%- liquid
  assign show_placeholders = show_placeholders | default: false
  assign show_extras = show_extras | default: false
  assign open_first = false
  assign any_accordion = false
  if has_beschr or has_anw or has_prop or show_placeholders
    assign any_accordion = true
  endif
  assign show_extras_block = false
  if show_extras
    if has_hilf_line or has_pdf or show_placeholders
      assign show_extras_block = true
    endif
  endif
-%}
<div
  class="pflege-pdp-unified"
  id="pflege-pdp-unified-detail"
  aria-label="{{ 'products.product.pflege_pdp.unified_info_aria' | t }}"
>
  {%- if any_accordion -%}
    <div class="pflege-pdp-tabs">
      {%- if has_beschr or show_placeholders -%}
        <details
          id="pflege-pdp-panel-beschreibung"
          class="pflege-pdp-tabs__panel"
          {% if open_first %}
            open
          {% endif %}
        >
          <summary class="pflege-pdp-tabs__summary">
            <span class="pflege-pdp-tabs__summary-text">{{ label_beschreibung | escape }}</span>
            <span class="pflege-pdp-tabs__chev" aria-hidden="true">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </summary>
          <div class="pflege-pdp-tabs__body rte">
            {%- if has_beschr -%}
              {{- mf_beschreibung | metafield_tag -}}
            {%- elsif show_placeholders -%}
              <p class="pflege-pdp-placeholder">{{ 'products.product.pflege_pdp.unified_placeholder_beschreibung' | t }}</p>
            {%- endif -%}
          </div>
        </details>
        {%- assign open_first = false -%}
      {%- endif -%}

      {%- if has_anw or show_placeholders -%}
        <details
          id="pflege-pdp-panel-anwendung"
          class="pflege-pdp-tabs__panel"
          {% if open_first %}
            open
          {% endif %}
        >
          <summary class="pflege-pdp-tabs__summary">
            <span class="pflege-pdp-tabs__summary-text">{{ label_anwendung | escape }}</span>
            <span class="pflege-pdp-tabs__chev" aria-hidden="true">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </summary>
          <div class="pflege-pdp-tabs__body rte">
            {%- if has_anw -%}
              {{- mf_anwendung | metafield_tag -}}
            {%- elsif show_placeholders -%}
              <p class="pflege-pdp-placeholder">{{ 'products.product.pflege_pdp.unified_placeholder_anwendung' | t }}</p>
            {%- endif -%}
          </div>
        </details>
        {%- assign open_first = false -%}
      {%- endif -%}

      {%- if has_prop or show_placeholders -%}
        <details
          id="pflege-pdp-panel-eigenschaften"
          class="pflege-pdp-tabs__panel"
          {% if open_first %}
            open
          {% endif %}
        >
          <summary class="pflege-pdp-tabs__summary">
            <span class="pflege-pdp-tabs__summary-text">{{ label_produkteigenschaften | escape }}</span>
            <span class="pflege-pdp-tabs__chev" aria-hidden="true">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </summary>
          <div class="pflege-pdp-tabs__body rte">
            {%- if has_prop -%}
              {{- mf_produkteigenschaften | metafield_tag -}}
            {%- elsif show_placeholders -%}
              <p class="pflege-pdp-placeholder">
                {{ 'products.product.pflege_pdp.unified_placeholder_produkteigenschaften' | t }}
              </p>
            {%- endif -%}
          </div>
        </details>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if show_extras_block -%}
    <div class="pflege-pdp-unified__extras" id="pflege-pdp-panel-extras">
      {%- if has_hilf_line -%}
        <p class="pflege-pdp-unified__hilf">
          <span class="pflege-pdp-unified__hilf-label">{{ 'products.product.pflege_pdp.hilfsmittelnummer_label' | t }}</span>
          <span class="pflege-pdp-unified__hilf-value">{{ hilfsmittel_display | escape }}</span>
        </p>
      {%- elsif show_placeholders -%}
        <p class="pflege-pdp-unified__hilf">
          <span class="pflege-pdp-unified__hilf-label">{{ 'products.product.pflege_pdp.hilfsmittelnummer_label' | t }}</span>
          <span class="pflege-pdp-unified__hilf-value pflege-pdp-placeholder">{{ 'products.product.pflege_pdp.unified_placeholder_hilfsmittel' | t }}</span>
        </p>
      {%- endif -%}

      {%- if has_pdf and pdf_url != blank -%}
        <p class="pflege-pdp-unified__pdf">
          <a
            href="{{ pdf_url }}"
            class="pflege-pdp-unified__pdf-link link link--text"
            target="_blank"
            rel="noopener noreferrer"
            {% if pdf_filename != blank %}
              download="{{ pdf_filename | escape }}"
            {% endif %}
          >
            {{- 'products.product.pflege_pdp.product_sheet_download' | t -}}
          </a>
        </p>
      {%- elsif show_placeholders -%}
        <p class="pflege-pdp-unified__pdf pflege-pdp-placeholder">
          {{ 'products.product.pflege_pdp.unified_placeholder_pdf' | t }}
        </p>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{%- comment -%}
  Konto-Link für Gäste vs. eingeloggte Kunden.
  Neue Kundenkonten: routes.account_login_url / routes.account_url (kein Theme-Landing).
  Accepts: login_page_url (optional, nur klassische Konten / Override)
{%- endcomment -%}
{%- if customer -%}
  {{ routes.account_url }}
{%- else -%}
  {%- liquid
    assign guest_login_url = routes.account_login_url
    capture is_new_accounts
      render 'pflege-customer-accounts-mode'
    endcapture
    assign is_new_accounts = is_new_accounts | strip
    if login_page_url != blank and is_new_accounts != 'true'
      assign guest_login_url = login_page_url
    endif
  -%}
  {{ guest_login_url }}
{%- endif -%}

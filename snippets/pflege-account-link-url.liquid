{%- comment -%}
  Konto-Link für Gäste vs. eingeloggte Kunden.
  Gäste → Theme Account-Landing (/pages/mein-konto).
  Eingeloggte Kunden → Shopify-Kundenbereich (routes.account_url).
  Accepts: login_page_url (optional, aus Section-Settings)
{%- endcomment -%}
{%- if customer -%}
  {{ routes.account_url }}
{%- else -%}
  {%- liquid
    assign guest_login_url = routes.account_login_url
    if login_page_url != blank
      assign guest_login_url = login_page_url
    elsif guest_login_url contains 'shopify.com' or guest_login_url contains 'customer_authentication'
      assign guest_login_url = '/pages/mein-konto'
    endif
  -%}
  {{ guest_login_url }}
{%- endif -%}

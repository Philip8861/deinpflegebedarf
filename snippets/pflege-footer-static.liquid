{% comment %}
  PflegeShop Footer — rein über Code (layout/theme.liquid), ohne Section / Theme-Editor.
  Texte & Links hier anpassen.
{% endcomment %}
{{ 'section-pflege-footer.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign root = routes.root_url

  if shop.terms_of_service != blank and shop.terms_of_service.url != blank
    assign url_agb = shop.terms_of_service.url
  else
    assign url_agb = root | append: 'pages/agb'
  endif

  assign url_impressum = root | append: 'pages/impressum'

  if shop.refund_policy != blank and shop.refund_policy.url != blank
    assign url_widerruf = shop.refund_policy.url
  else
    assign url_widerruf = root | append: 'pages/widerrufsrecht'
  endif

  if shop.privacy_policy != blank and shop.privacy_policy.url != blank
    assign url_datenschutz = shop.privacy_policy.url
  else
    assign url_datenschutz = root | append: 'pages/datenschutz'
  endif

  assign url_cookie = root | append: 'pages/cookie-einstellungen'
-%}

<footer id="pflege-footer-root" class="pflege-footer pflege-footer--v2 pflege-footer__section-padding" role="contentinfo">
  <div class="pflege-footer__band">
  <div class="pflege-footer__surface">
    <div class="pflege-footer__inner pflege-footer__inner--main">
      <div class="pflege-footer__grid-primary">
        <div class="pflege-footer__brand">
          <a href="{{ routes.root_url }}" class="pflege-footer__brand-logo-link">
            {% render 'pflege-logo-webp',
              img_class: 'pflege-footer__brand-logo',
              logo_width: 150,
              logo_height: 33,
              loading: 'lazy'
            %}
          </a>
          <div class="pflege-footer__brand-copy rte">
            <p>
              Pflegeprodukte, die den Pflegealltag erleichtern. Vertrauensvoll, persönlich und mit Herz – für Sie und Ihre
              Liebsten.
            </p>
          </div>
          <ul class="pflege-footer__contact" role="list">
            <li class="pflege-footer__contact-row">
              <span class="pflege-footer__contact-ic" aria-hidden="true">
                {% render 'pflege-icon', icon: 'phone', width: 20 %}
              </span>
              <span class="pflege-footer__contact-body">
                <a class="pflege-footer__contact-line pflege-footer__contact-line--phone" href="tel:+4983349893330">08334 / 9893330</a>
              </span>
            </li>
            <li class="pflege-footer__contact-row">
              <span class="pflege-footer__contact-ic" aria-hidden="true">
                {% render 'pflege-icon', icon: 'mail', width: 18 %}
              </span>
              <span class="pflege-footer__contact-body">
                <a class="pflege-footer__contact-line" href="mailto:deinpflegebedarf@alltagshilfe-sued.de">deinpflegebedarf@alltagshilfe-sued.de</a>
              </span>
            </li>
            <li class="pflege-footer__contact-row">
              <span class="pflege-footer__contact-ic" aria-hidden="true">
                {% render 'pflege-icon', icon: 'clock', width: 20 %}
              </span>
              <span class="pflege-footer__contact-body">
                <span class="pflege-footer__contact-line pflege-footer__contact-line--hours">Mo.–Fr. 08:30 – 16:00 Uhr</span>
              </span>
            </li>
          </ul>
        </div>

        <div class="pflege-footer__menus">
          <nav class="pflege-footer__menu-col" aria-labelledby="pflege-ft-ks">
            <h2 id="pflege-ft-ks" class="pflege-footer__menu-heading">Kundenservice</h2>
            <ul class="pflege-footer__menu-list" role="list">
              <li><a href="{{ root }}pages/kontakt">Kontakt</a></li>
              <li><a href="{{ root }}pages/faq">FAQ</a></li>
              <li><a href="{{ root }}pages/versand-zahlung">Versand &amp; Zahlung</a></li>
              <li><a href="{{ root }}pages/bestellstatus">Bestellstatus</a></li>
              <li><a href="{{ root }}pages/retouren">Retouren</a></li>
            </ul>
          </nav>

          <nav class="pflege-footer__menu-col" aria-labelledby="pflege-ft-r">
            <h2 id="pflege-ft-r" class="pflege-footer__menu-heading">Rechtliches</h2>
            <ul class="pflege-footer__menu-list" role="list">
              <li><a href="{{ url_agb }}">AGB</a></li>
              <li><a href="{{ url_impressum }}">Impressum</a></li>
              <li><a href="{{ url_widerruf }}">Widerrufsrecht</a></li>
              <li><a href="{{ url_datenschutz }}">Datenschutzerklärung</a></li>
              <li><a href="{{ url_cookie }}">Cookie-Einstellungen</a></li>
            </ul>
          </nav>

          <nav class="pflege-footer__menu-col" aria-labelledby="pflege-ft-u">
            <h2 id="pflege-ft-u" class="pflege-footer__menu-heading">Über uns</h2>
            <ul class="pflege-footer__menu-list" role="list">
              <li><a href="{{ root }}pages/unsere-mission">Unsere Mission</a></li>
              <li><a href="{{ root }}pages/ueber-uns">Über PflegeShop</a></li>
              <li><a href="{{ root }}pages/warum-wir">Warum wir</a></li>
              <li><a href="{{ root }}pages/pflegewissen">Pflegewissen</a></li>
            </ul>
          </nav>
        </div>

        <div class="pflege-footer__newsletter-card">
          <h2 class="pflege-footer__newsletter-heading">Newsletter abonnieren</h2>
          <p class="pflege-footer__newsletter-lead">
            Exklusive Angebote, neue Produkte und Pflegetipps direkt in Ihr Postfach.
          </p>
          {%- form 'customer', id: 'PflegeFooterStaticForm', class: 'pflege-footer__news-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="pflege-footer__news-field">
              <label class="visually-hidden" for="PflegeFooterStaticEmail">E-Mail für Newsletter</label>
              <input
                id="PflegeFooterStaticEmail"
                type="email"
                name="contact[email]"
                class="pflege-footer__news-input"
                value="{{ form.email }}"
                autocomplete="email"
                autocapitalize="off"
                autocorrect="off"
                placeholder="E-Mail-Adresse eingeben"
                required
                {% if form.errors %}
                  aria-invalid="true"
                  aria-describedby="PflegeFooterStaticErr"
                {% endif %}
              >
            </div>
            <button type="submit" class="pflege-footer__news-submit" name="commit">Jetzt anmelden</button>
            {%- if form.errors -%}
              <p class="pflege-footer__news-error" id="PflegeFooterStaticErr" role="alert">
                {{ form.errors.messages.email }}
              </p>
            {%- endif -%}
            {%- if form.posted_successfully? -%}
              <p class="pflege-footer__news-success" role="status">{{ 'newsletter.success' | t }}</p>
            {%- endif -%}
          {%- endform -%}
          <p class="pflege-footer__news-note">
            <span class="pflege-footer__news-check" aria-hidden="true">
              {% render 'pflege-icon', icon: 'badge-check', width: 16 %}
            </span>
            Jederzeit abbestellbar.
          </p>
          <p class="pflege-footer__news-privacy">
            Weitere Informationen in unserer <a href="{{ url_datenschutz }}">Datenschutzerklärung</a>.
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="pflege-footer__trust-strip">
    <div class="pflege-footer__inner pflege-footer__inner--trust">
      <div class="pflege-footer__trust-col pflege-footer__trust-col--pay">
        <p class="pflege-footer__trust-heading">Sicher bezahlen</p>
        <ul class="pflege-footer__pay-badges" role="list">
          <li class="pflege-footer__pay-badge pflege-footer__pay-badge--logo">
            <img
              src="{{ 'Visa_logo.webp' | asset_url }}"
              alt="Visa"
              class="pflege-footer__pay-logo"
              width="65"
              height="40"
              loading="lazy"
              decoding="async"
            >
          </li>
          <li class="pflege-footer__pay-badge pflege-footer__pay-badge--logo">
            <img
              src="{{ 'Mastercard.webp' | asset_url }}"
              alt="Mastercard"
              class="pflege-footer__pay-logo"
              width="65"
              height="40"
              loading="lazy"
              decoding="async"
            >
          </li>
          <li class="pflege-footer__pay-badge pflege-footer__pay-badge--logo">
            <a
              href="https://www.paypal.com/de/webapps/mpp/paypal-popup"
              target="_blank"
              rel="noopener noreferrer"
              title="So funktioniert PayPal"
              aria-label="PayPal — So funktioniert PayPal (neues Fenster)"
              class="pflege-footer__pay-logo-link"
            >
              <img
                src="{{ 'paypal-logo.png' | asset_url }}"
                alt="PayPal"
                class="pflege-footer__pay-logo pflege-footer__pay-logo--wide"
                width="100"
                height="26"
                loading="lazy"
                decoding="async"
              >
            </a>
          </li>
          <li class="pflege-footer__pay-badge pflege-footer__pay-badge--logo">
            <img
              src="{{ 'google-pay.svg' | asset_url }}"
              alt="Google Pay"
              class="pflege-footer__pay-logo pflege-footer__pay-logo--wide"
              width="82"
              height="34"
              loading="lazy"
              decoding="async"
            >
          </li>
          <li class="pflege-footer__pay-badge pflege-footer__pay-badge--logo">
            <img
              src="{{ 'klarna.svg' | asset_url }}"
              alt="Klarna"
              class="pflege-footer__pay-logo pflege-footer__pay-logo--wide"
              width="90"
              height="38"
              loading="lazy"
              decoding="async"
            >
          </li>
        </ul>
      </div>

      <div class="pflege-footer__trust-col pflege-footer__trust-col--block">
        <span class="pflege-footer__trust-ic" aria-hidden="true">
          {% render 'pflege-icon', icon: 'shield', width: 24 %}
        </span>
        <div>
          <p class="pflege-footer__trust-title">Käuferschutz</p>
          <p class="pflege-footer__trust-text">Sicher einkaufen mit unserem Käuferschutz.</p>
        </div>
      </div>

      <div class="pflege-footer__trust-col pflege-footer__trust-col--block">
        <span class="pflege-footer__trust-ic" aria-hidden="true">
          {% render 'pflege-icon', icon: 'badge-check', width: 24 %}
        </span>
        <div>
          <p class="pflege-footer__trust-title">Trusted Shops</p>
          <p class="pflege-footer__trust-text">Zertifizierter Shop mit Käuferschutz.</p>
        </div>
      </div>

      <div class="pflege-footer__trust-col pflege-footer__trust-col--block">
        <span class="pflege-footer__trust-ic" aria-hidden="true">
          {% render 'pflege-icon', icon: 'lock', width: 24 %}
        </span>
        <div>
          <p class="pflege-footer__trust-title">Ihre Daten sind sicher</p>
          <p class="pflege-footer__trust-text">SSL-Verschlüsselung für einen sicheren Einkauf.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="pflege-footer__bottom-bar">
    <div class="pflege-footer__inner pflege-footer__inner--bottom">
      <p class="pflege-footer__copy">
        © {{ 'now' | date: '%Y' }}
        {{ shop.name | escape }}. Alle Rechte vorbehalten.
      </p>
      <nav class="pflege-footer__bottom-nav" aria-label="Rechtliche Kurzlinks">
        <ul class="pflege-footer__bottom-list" role="list">
          <li><a href="{{ url_agb }}">AGB</a></li>
          <li><a href="{{ url_impressum }}">Impressum</a></li>
          <li><a href="{{ url_datenschutz }}">Datenschutz</a></li>
          <li><a href="{{ url_cookie }}">Cookie-Einstellungen</a></li>
        </ul>
      </nav>
    </div>
  </div>
  </div>
</footer>

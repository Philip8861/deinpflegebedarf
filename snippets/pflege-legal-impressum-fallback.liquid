{% comment %}
  Impressum auf Standard-Vorlage (page) — schlicht, nur Text.
{% endcomment %}
{{ 'section-pflege-legal-page.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign root = routes.root_url
  assign url_impressum = root | append: 'pages/impressum'
  assign url_widerruf = root | append: 'pages/widerrufsbelehrung'
  assign url_agb = root | append: 'pages/agb'
  assign url_datenschutz = root | append: 'pages/datenschutz'
-%}

{%- style -%}
  .pflege-legal--fallback-padding {
    padding-top: 40px;
    padding-bottom: 56px;
  }
  @media screen and (min-width: 750px) {
    .pflege-legal--fallback-padding {
      padding-top: 52px;
      padding-bottom: 72px;
    }
  }
{%- endstyle -%}

{% render 'pflege-legal-page-view',
  padding_class: 'pflege-legal--fallback-padding',
  color_scheme: 'scheme-1',
  legal_title_fallback: 'Impressum',
  legal_meta_date: 'Mai 2026',
  current_handle: 'impressum',
  url_impressum: url_impressum,
  url_widerruf: url_widerruf,
  url_agb: url_agb,
  url_datenschutz: url_datenschutz,
  use_impressum_body: true,
  legal_plain: true
%}

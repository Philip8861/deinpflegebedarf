{{ 'section-pflege-category-filtered.css' | asset_url | stylesheet_tag }}
{{ 'pflege-cat-card-layout.css' | asset_url | stylesheet_tag }}
<style>
  /* Preis mittig + Mobil-2-Spalten — inline, damit alte CDN-CSS nicht überschreibt */
  .pflege-cat-card .pflege-cat-card__footer {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.35rem;
    width: 100%;
    margin-top: auto;
  }

  .pflege-cat-card .pflege-cat-card__footer .pflege-cat-card__price-row {
    display: block !important;
    width: 100% !important;
    margin: 0 !important;
    text-align: center !important;
  }

  .pflege-cat-card .pflege-cat-card__footer .pflege-cat-card__price,
  .pflege-cat-card .pflege-cat-card__footer .pflege-cat-card__unit {
    display: block !important;
    width: 100% !important;
    text-align: center !important;
  }

  @media screen and (max-width: 749px) {
    .pflege-cat-filtered__grid,
    .pflege-bestseller__grid,
    .pflege-pflegesets__grid,
    .pflege-pflegesets__cat-grid {
      display: grid !important;
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      gap: clamp(0.5rem, 2.2vw, 0.75rem) !important;
      width: 100% !important;
      max-width: 100% !important;
    }
  }
</style>

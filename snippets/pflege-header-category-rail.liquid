{% comment %}
  Horizontale Kategorie-Pille unter der Pflege-Hauptleiste (teil des sticky Headers).
{% endcomment %}
{{ 'pflege-header-category-rail.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign root = routes.root_url

  if collections['inkontinenzversorgung'] != blank
    assign url_ink = collections['inkontinenzversorgung'].url
  elsif collections['inkontinenz'] != blank
    assign url_ink = collections['inkontinenz'].url
  else
    assign url_ink = root | append: 'collections/inkontinenzversorgung'
  endif

  if collections['korperpflege'] != blank
    assign url_body = collections['korperpflege'].url
  elsif collections['koerperpflege'] != blank
    assign url_body = collections['koerperpflege'].url
  else
    assign url_body = root | append: 'collections/korperpflege'
  endif

  if collections['hautpflege'] != blank
    assign url_skin = collections['hautpflege'].url
  elsif collections['hautschutz-hautpflege'] != blank
    assign url_skin = collections['hautschutz-hautpflege'].url
  else
    assign url_skin = root | append: 'collections/hautpflege'
  endif

  if collections['schutz-handschuhe'] != blank
    assign url_gloves = collections['schutz-handschuhe'].url
  elsif collections['schutz-und-handschuhe'] != blank
    assign url_gloves = collections['schutz-und-handschuhe'].url
  elsif collections['handschuhe'] != blank
    assign url_gloves = collections['handschuhe'].url
  else
    assign url_gloves = root | append: 'collections/schutz-handschuhe'
  endif

  if collections['verbrauchsartikel'] != blank
    assign url_ver = collections['verbrauchsartikel'].url
  else
    assign url_ver = root | append: 'collections/verbrauchsartikel'
  endif

  assign active_ink = false
  assign active_body = false
  assign active_skin = false
  assign active_gloves = false
  assign active_ver = false

  if request.page_type == 'collection'
    case collection.handle
      when 'inkontinenzversorgung', 'inkontinenz'
        assign active_ink = true
      when 'korperpflege', 'koerperpflege'
        assign active_body = true
      when 'hautpflege', 'hautschutz-hautpflege', 'hauschutz-hautpflege'
        assign active_skin = true
      when 'schutz-handschuhe', 'schutz-und-handschuhe', 'handschuhe'
        assign active_gloves = true
      when 'verbrauchsartikel'
        assign active_ver = true
    endcase
  endif

  if request.page_type == 'product' and product != blank
    assign rail_cat = ''
    for c in product.collections
      if c.handle == 'inkontinenzversorgung' or c.handle == 'inkontinenz'
        assign rail_cat = 'ink'
        break
      endif
    endfor
    if rail_cat == ''
      for c in product.collections
        if c.handle == 'korperpflege' or c.handle == 'koerperpflege'
          assign rail_cat = 'body'
          break
        endif
      endfor
    endif
    if rail_cat == ''
      for c in product.collections
        if c.handle == 'hautpflege' or c.handle == 'hautschutz-hautpflege' or c.handle == 'hauschutz-hautpflege'
          assign rail_cat = 'skin'
          break
        endif
      endfor
    endif
    if rail_cat == ''
      for c in product.collections
        if c.handle == 'schutz-handschuhe' or c.handle == 'schutz-und-handschuhe' or c.handle == 'handschuhe'
          assign rail_cat = 'gloves'
          break
        endif
      endfor
    endif
    if rail_cat == ''
      for c in product.collections
        if c.handle == 'verbrauchsartikel'
          assign rail_cat = 'ver'
          break
        endif
      endfor
    endif
    case rail_cat
      when 'ink'
        assign active_ink = true
      when 'body'
        assign active_body = true
      when 'skin'
        assign active_skin = true
      when 'gloves'
        assign active_gloves = true
      when 'ver'
        assign active_ver = true
    endcase
  endif
-%}

<nav class="pflege-cat-rail" aria-label="{{ 'sections.pflege_header_category_rail.nav_aria' | t }}">
  <div class="pflege-cat-rail__outer page-width">
    <div class="pflege-cat-rail__inner">
      <ul class="pflege-cat-rail__list list-unstyled" role="list">
        <li class="pflege-cat-rail__cell">
          <a
            href="{{ url_ink }}"
            class="pflege-cat-rail__link{% if active_ink %} pflege-cat-rail__link--active{% endif %}"
            {% if active_ink %}aria-current="page"{% endif %}
          >
            <span class="pflege-cat-rail__icon" aria-hidden="true">{% render 'pflege-icon', icon: 'droplet', width: 20 %}</span>
            <span class="pflege-cat-rail__label">{{ 'sections.pflege_header_category_rail.cat_ink' | t }}</span>
          </a>
        </li>
        <li class="pflege-cat-rail__cell">
          <a
            href="{{ url_body }}"
            class="pflege-cat-rail__link{% if active_body %} pflege-cat-rail__link--active{% endif %}"
            {% if active_body %}aria-current="page"{% endif %}
          >
            <span class="pflege-cat-rail__icon" aria-hidden="true">{% render 'pflege-icon', icon: 'user', width: 20 %}</span>
            <span class="pflege-cat-rail__label">{{ 'sections.pflege_header_category_rail.cat_body' | t }}</span>
          </a>
        </li>
        <li class="pflege-cat-rail__cell">
          <a
            href="{{ url_skin }}"
            class="pflege-cat-rail__link{% if active_skin %} pflege-cat-rail__link--active{% endif %}"
            {% if active_skin %}aria-current="page"{% endif %}
          >
            <span class="pflege-cat-rail__icon" aria-hidden="true">{% render 'pflege-icon', icon: 'heart', width: 20 %}</span>
            <span class="pflege-cat-rail__label">{{ 'sections.pflege_header_category_rail.cat_skin' | t }}</span>
          </a>
        </li>
        <li class="pflege-cat-rail__cell">
          <a
            href="{{ url_gloves }}"
            class="pflege-cat-rail__link{% if active_gloves %} pflege-cat-rail__link--active{% endif %}"
            {% if active_gloves %}aria-current="page"{% endif %}
          >
            <span class="pflege-cat-rail__icon" aria-hidden="true">{% render 'pflege-icon', icon: 'hand', width: 20 %}</span>
            <span class="pflege-cat-rail__label">{{ 'sections.pflege_header_category_rail.cat_gloves' | t }}</span>
          </a>
        </li>
        <li class="pflege-cat-rail__cell">
          <a
            href="{{ url_ver }}"
            class="pflege-cat-rail__link{% if active_ver %} pflege-cat-rail__link--active{% endif %}"
            {% if active_ver %}aria-current="page"{% endif %}
          >
            <span class="pflege-cat-rail__icon" aria-hidden="true">{% render 'pflege-icon', icon: 'shopping-bag', width: 20 %}</span>
            <span class="pflege-cat-rail__label">{{ 'sections.pflege_header_category_rail.cat_consumables' | t }}</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

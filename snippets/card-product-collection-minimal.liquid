{% comment %}
  Schlankes Produktkarten-Markup für Kollektionen.

    Akzeptiert:
    - card_product: Produkt
    - lazy_load – Boolean
    - media_aspect_ratio – 'adapt', 'square', 'portrait'
{% endcomment %}
{%- liquid
  assign prod = card_product | default: product
  assign ratio_calc = 1
  if prod.featured_media and media_aspect_ratio == 'portrait'
    assign ratio_calc = 0.8
  elsif prod.featured_media and media_aspect_ratio == 'adapt'
    assign ratio_calc = prod.featured_media.aspect_ratio
  endif
  if ratio_calc == 0 or ratio_calc == blank
    assign ratio_calc = 1
  endif
  assign ratio_visual = ratio_calc | times: 1.0
  if ratio_visual < 0.72
    assign ratio_visual = 0.72
  elsif ratio_visual > 1.42
    assign ratio_visual = 1.42
  endif
  assign subtitle = prod.metafields.pflege.card_subtitle.value | strip
  if subtitle == blank and prod.type != blank
    assign subtitle = prod.type
  endif
-%}
<article class="pflege-coll-card product-card-wrapper">
  <div
    class="pflege-coll-card__inner"
    style="--pflege-coll-ratio: {{ ratio_visual }};"
  >
    <div class="pflege-coll-card__media">
      {%- if prod.featured_media -%}
        <a href="{{ prod.url }}" class="pflege-coll-card__media-visual">
          {% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
          <img
            class="pflege-coll-card__media-img"
            src="{{ prod.featured_media | image_url: width: 720 }}"
            srcset="
              {%- if prod.featured_media.width >= 165 -%}{{ prod.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
              {%- if prod.featured_media.width >= 360 -%}{{ prod.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
              {%- if prod.featured_media.width >= 533 -%}{{ prod.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
              {%- if prod.featured_media.width >= 720 -%}{{ prod.featured_media | image_url: width: 720 }} 720w,{%- endif -%}
              {%- if prod.featured_media.width >= 940 -%}{{ prod.featured_media | image_url: width: 940 }} 940w,{%- endif -%}
              {{ prod.featured_media | image_url }} {{ prod.featured_media.width }}w
            "
            sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
            alt="{{ prod.featured_media.alt | default: prod.title | escape }}"
            {% if lazy_load %}
              loading="lazy"
            {% endif %}
            width="{{ prod.featured_media.width }}"
            height="{{ prod.featured_media.height }}"
          >
          {% comment %}theme-check-enable ImgLazyLoading{% endcomment %}
          {%- if prod.available == false -%}
            <span class="pflege-coll-card__badge">{{ 'products.product.sold_out' | t }}</span>
          {%- endif -%}
        </a>
      {%- else -%}
        <a
          href="{{ prod.url }}"
          class="pflege-coll-card__media-visual pflege-coll-card__media-visual--placeholder"
          style="--pflege-coll-ratio: {{ ratio_visual }};"
        >
          {{- 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg pflege-coll-card__media-img' -}}
        </a>
      {%- endif -%}
    </div>
    <div class="pflege-coll-card__body">
      <h3 class="pflege-coll-card__title">
        <a href="{{ prod.url }}">{{ prod.title | escape }}</a>
      </h3>
      {%- if subtitle != blank -%}
        <p class="pflege-coll-card__sub">{{ subtitle | escape }}</p>
      {%- endif -%}
      <a
        href="{{ prod.url }}"
        class="pflege-coll-card__cta"
        aria-label="{{ 'sections.pflege_collection.view_details_aria' | t: title: prod.title }}"
      >
        {{- 'sections.pflege_collection.view_details' | t -}}
      </a>
    </div>
  </div>
</article>

{% comment %}
  Rechtliches-Leiste — wird aus theme.liquid gerendert (theme settings),
  damit die Links immer im DOM sind (nicht abhängig von Section-JSON).
{% endcomment %}
{{ 'section-pflege-footer-legal.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign h = settings.pflege_legal_heading | strip
  if h == blank
    assign h = 'footer_pflege.legal_heading' | t
  endif

  assign label_agb = 'footer_pflege.link_agb' | t
  assign label_impressum = 'footer_pflege.link_impressum' | t
  assign label_widerruf = 'footer_pflege.link_widerruf' | t
  assign label_versand = 'footer_pflege.link_versand' | t
  assign label_datenschutz = 'footer_pflege.link_datenschutz' | t

  assign url_agb = settings.pflege_legal_url_agb
  if url_agb == blank and shop.terms_of_service != blank and shop.terms_of_service.url != blank
    assign url_agb = shop.terms_of_service.url
  endif

  assign url_impressum = settings.pflege_legal_url_impressum

  assign url_widerruf = settings.pflege_legal_url_widerruf
  if url_widerruf == blank and shop.refund_policy != blank and shop.refund_policy.url != blank
    assign url_widerruf = shop.refund_policy.url
  endif

  assign url_versand = settings.pflege_legal_url_versand
  if url_versand == blank and shop.shipping_policy != blank and shop.shipping_policy.url != blank
    assign url_versand = shop.shipping_policy.url
  endif

  assign url_datenschutz = settings.pflege_legal_url_datenschutz
  if url_datenschutz == blank and shop.privacy_policy != blank and shop.privacy_policy.url != blank
    assign url_datenschutz = shop.privacy_policy.url
  endif

  assign legal_scheme = settings.pflege_legal_color_scheme | default: 'scheme-1'
-%}

<div class="pflege-footer-legal color-{{ legal_scheme }} gradient">
  <div class="pflege-footer-legal__shell">
    <div class="pflege-footer-legal__inner">
      <p class="pflege-footer-legal__title">{{ h | escape }}</p>
      <ul class="pflege-footer-legal__list list-unstyled" role="list">
        <li class="pflege-footer-legal__item">
          {%- if url_agb != blank -%}
            <a class="pflege-footer-legal__link" href="{{ url_agb }}">{{ label_agb | escape }}</a>
          {%- else -%}
            <span class="pflege-footer-legal__pending">{{ label_agb | escape }}</span>
          {%- endif -%}
        </li>
        <li class="pflege-footer-legal__item">
          {%- if url_impressum != blank -%}
            <a class="pflege-footer-legal__link" href="{{ url_impressum }}">{{ label_impressum | escape }}</a>
          {%- else -%}
            <span class="pflege-footer-legal__pending">{{ label_impressum | escape }}</span>
          {%- endif -%}
        </li>
        <li class="pflege-footer-legal__item">
          {%- if url_widerruf != blank -%}
            <a class="pflege-footer-legal__link" href="{{ url_widerruf }}">{{ label_widerruf | escape }}</a>
          {%- else -%}
            <span class="pflege-footer-legal__pending">{{ label_widerruf | escape }}</span>
          {%- endif -%}
        </li>
        <li class="pflege-footer-legal__item">
          {%- if url_versand != blank -%}
            <a class="pflege-footer-legal__link" href="{{ url_versand }}">{{ label_versand | escape }}</a>
          {%- else -%}
            <span class="pflege-footer-legal__pending">{{ label_versand | escape }}</span>
          {%- endif -%}
        </li>
        <li class="pflege-footer-legal__item">
          {%- if url_datenschutz != blank -%}
            <a class="pflege-footer-legal__link" href="{{ url_datenschutz }}">{{ label_datenschutz | escape }}</a>
          {%- else -%}
            <span class="pflege-footer-legal__pending">{{ label_datenschutz | escape }}</span>
          {%- endif -%}
        </li>
      </ul>
    </div>
  </div>
</div>

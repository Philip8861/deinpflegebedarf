{% comment %}
  FAQ-Eintrag — leitet je locale_root an spezialisiertes Snippet weiter
  Parameter: section_id, index, locale_root
{% endcomment %}
{%- if locale_root == 'sections.pflege_collection_free_care' -%}
  {% render 'pflege-faq-accordion-item-free-care', section_id: section_id, index: index %}
{%- else -%}
  {%- liquid
    assign idx = index | plus: 0
    assign faq_q = ''
    assign faq_a = ''

    if locale_root == 'pflegeboxi'
      assign faq_q = 'pflegeboxi.faq_' | append: idx | append: '_q' | t
      assign faq_a = 'pflegeboxi.faq_' | append: idx | append: '_a' | t
    elsif locale_root == 'sections.pflege_faq_accordion'
      assign faq_q = 'sections.pflege_faq_accordion.faq_' | append: idx | append: '_q' | t
      assign faq_a = 'sections.pflege_faq_accordion.faq_' | append: idx | append: '_a' | t
    endif

    assign item_id = 'pflege-faq-' | append: section_id | append: '-' | append: idx
    assign trigger_id = item_id | append: '-trigger'
    assign panel_id = item_id | append: '-panel'
  -%}
  {%- if faq_q != blank -%}
    <div class="pflege-faq-accordion__item" role="listitem" data-faq-accordion-item id="{{ item_id }}">
      <h3 class="pflege-faq-accordion__question">
        <button
          type="button"
          class="pflege-faq-accordion__trigger"
          id="{{ trigger_id }}"
          data-faq-accordion-trigger
          aria-expanded="false"
          aria-controls="{{ panel_id }}"
        >
          <span class="pflege-faq-accordion__trigger-text">{{ faq_q }}</span>
          <span class="pflege-faq-accordion__chevron" aria-hidden="true"></span>
        </button>
      </h3>
      <div
        id="{{ panel_id }}"
        class="pflege-faq-accordion__panel"
        role="region"
        aria-labelledby="{{ trigger_id }}"
        data-faq-accordion-panel
        hidden
      >
        <div class="pflege-faq-accordion__answer rte">
          {%- if faq_a contains '<' -%}
            {{ faq_a }}
          {%- else -%}
            <p>{{ faq_a }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}
{%- endif -%}

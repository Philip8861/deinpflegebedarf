          >
          <span class="pflege-advantages-us__text">{{ 'sections.pflege_collection_free_care.advantages_us_left_3' | t }}</span>
        </li>
        <li class="pflege-advantages-us__item">
          <img
            class="pflege-advantages-us__check"

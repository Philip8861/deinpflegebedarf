          >
          <span class="pflege-advantages-us__text">{{ 'sections.pflege_collection_free_care.advantages_us_left_2' | t }}</span>
        </li>
        <li class="pflege-advantages-us__item">
          <img
            class="pflege-advantages-us__check"
            src="{{ 'haken.webp' | asset_url }}"
            alt=""

{% comment %}
  Hero-Kachel mit Theme-Asset als Hintergrund (wie startseite_main auf der Startseite).
  Parameter: asset_file, image_alt, badge, heading_line1, heading_line2, subheading,
  button_label, button_link, title_id
{% endcomment %}
<div class="pflege-hero__panel pflege-hero__panel--asset-bg">
  <div class="pflege-hero__asset-zoom">
    <img
      class="pflege-hero__asset-photo"
      src="{{ asset_file | asset_url }}"
      alt="{{ image_alt | escape }}"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    >
  </div>
  <div class="pflege-hero__grid pflege-hero__grid--asset-bg">
    <div class="pflege-hero__content">
      {%- if badge != blank -%}
        <p class="pflege-hero__badge">{{ badge | escape }}</p>
      {%- endif -%}
      {%- if title_id != blank -%}
        <h1 id="{{ title_id }}" class="pflege-hero__title">
          {{- heading_line1 | escape -}}
          {%- if heading_line2 != blank -%}
            <br><span>{{ heading_line2 | escape }}</span>
          {%- endif -%}
        </h1>
      {%- else -%}
        <h1 class="pflege-hero__title">
          {{- heading_line1 | escape -}}
          {%- if heading_line2 != blank -%}
            <br><span>{{ heading_line2 | escape }}</span>
          {%- endif -%}
        </h1>
      {%- endif -%}
      {%- if subheading != blank -%}
        <p class="pflege-hero__sub">{{ subheading | escape }}</p>
      {%- endif -%}
      {%- if button_label != blank and button_link != blank -%}
        <a class="pflege-hero__cta" href="{{ button_link | escape }}">
          {{- button_label | escape -}}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{%- comment -%}
  Akkordeon-Tabs: product.description + Metafields (Anwendung, Inhaltsstoffe, Merkmale).
  Kein zweites product-form; keine variantenabhängigen Werte.
  Argumente: siehe render-Aufruf in pflege-product-detail-body.liquid
{%- endcomment -%}
<div class="pflege-pdp-tabs" role="region" aria-label="Produktinformationen">
  {%- if has_desc -%}
    <details class="pflege-pdp-tabs__panel" open>
      <summary class="pflege-pdp-tabs__summary">
        <span class="pflege-pdp-tabs__summary-text">{{ label_desc | escape }}</span>
        <span class="pflege-pdp-tabs__chev" aria-hidden="true">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </summary>
      <div class="pflege-pdp-tabs__body rte" id="PflegePDP-acc-desc-{{ section_id }}">
        {{ product.description }}
      </div>
    </details>
  {%- endif -%}

  {%- if has_app -%}
    <details class="pflege-pdp-tabs__panel"{%- unless has_desc -%} open{%- endunless -%}>
      <summary class="pflege-pdp-tabs__summary">
        <span class="pflege-pdp-tabs__summary-text">{{ label_app | escape }}</span>
        <span class="pflege-pdp-tabs__chev" aria-hidden="true">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </summary>
      <div class="pflege-pdp-tabs__body rte" id="PflegePDP-acc-app-{{ section_id }}">
        {%- if mf_app.value != blank -%}
          {{ mf_app.value }}
        {%- else -%}
          {{ mf_app | metafield_text }}
        {%- endif -%}
      </div>
    </details>
  {%- endif -%}

  {%- if has_ing -%}
    <details class="pflege-pdp-tabs__panel"{%- unless has_desc or has_app -%} open{%- endunless -%}>
      <summary class="pflege-pdp-tabs__summary">
        <span class="pflege-pdp-tabs__summary-text">{{ label_ing | escape }}</span>
        <span class="pflege-pdp-tabs__chev" aria-hidden="true">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </summary>
      <div class="pflege-pdp-tabs__body rte" id="PflegePDP-acc-ing-{{ section_id }}">
        {%- if mf_ing.value != blank -%}
          {{ mf_ing.value }}
        {%- else -%}
          {{ mf_ing | metafield_text }}
        {%- endif -%}
      </div>
    </details>
  {%- endif -%}

  {%- if has_feat -%}
    <details class="pflege-pdp-tabs__panel"{%- unless has_desc or has_app or has_ing -%} open{%- endunless -%}>
      <summary class="pflege-pdp-tabs__summary">
        <span class="pflege-pdp-tabs__summary-text">{{ label_feat | escape }}</span>
        <span class="pflege-pdp-tabs__chev" aria-hidden="true">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
      </summary>
      <div class="pflege-pdp-tabs__body rte" id="PflegePDP-acc-feat-{{ section_id }}">
        {%- if mf_feat.value != blank -%}
          {{ mf_feat.value }}
        {%- else -%}
          {{ mf_feat | metafield_text }}
        {%- endif -%}
      </div>
    </details>
  {%- endif -%}
</div>

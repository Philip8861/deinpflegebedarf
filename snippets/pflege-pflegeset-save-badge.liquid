{% comment %}
  Spar-Badge für Pflegeset-Produkte (S 10%, M 15%, L 20%).
  Parameter: card_product, handle_fallback (optional)
{% endcomment %}
{%- liquid
  capture save_percent_raw
    render 'pflege-pflegeset-save-percent', card_product: card_product, handle_fallback: handle_fallback
  endcapture
  assign save_percent = save_percent_raw | strip | plus: 0

  if save_percent == 10
    assign save_badge = 'Sie sparen 10%'
  elsif save_percent == 15
    assign save_badge = 'Sie sparen 15%'
  elsif save_percent == 20
    assign save_badge = 'Sie sparen 20%'
  endif
-%}{{ save_badge }}

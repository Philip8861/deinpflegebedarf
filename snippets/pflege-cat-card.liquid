{% comment %}
  Produktkarte wie Kategorieseiten (Hautpflege, Desinfektion).

  Parameter:
  - card_product: Produkt
  - card_layout: optional „horizontal“ (Startseite Bestseller)
  - list_item: optional, Standard true (<li>); false für <div> im Raster
  - show_tip_badge: optional, „Unser Tipp!“ oben auf der Karte (Bestseller)
{% endcomment %}
{%- liquid
  assign p = card_product
  assign card_variant = p.selected_or_first_available_variant
  assign is_horizontal = false
  if card_layout == 'horizontal'
    assign is_horizontal = true
  endif
  assign use_li = list_item
  if use_li == nil
    assign use_li = true
  endif
  assign show_tip = show_tip_badge

  assign subtitle = p.metafields.pflege.card_subtitle.value | strip
  if subtitle == blank
    assign subtitle = p.metafields.custom.beschreibung.value | strip_html | strip | truncate: 120
  endif
  if subtitle == blank and p.type != blank
    assign subtitle = p.type
  endif

  if settings.currency_code_enabled
    assign price_label = p.price_min | money_with_currency
  else
    assign price_label = p.price_min | money
  endif

  assign unit_price_label = ''
  if card_variant.unit_price_measurement
    assign unit_price_label = card_variant.unit_price | money | append: ' / '
    if card_variant.unit_price_measurement.reference_unit != blank
      assign unit_price_label = unit_price_label | append: card_variant.unit_price_measurement.reference_unit
    endif
  endif

  assign show_rezept_badge = false
  assign tags_joined = p.tags | join: ' ' | downcase
  if tags_joined contains 'rezept' or tags_joined contains 'pflegebox' or tags_joined contains 'pflegehilfsmittel'
    assign show_rezept_badge = true
  endif

  assign card_classes = 'pflege-cat-card'
  if is_horizontal
    assign card_classes = card_classes | append: ' pflege-cat-card--horizontal'
  endif
-%}
{%- if use_li -%}
<li class="{{ card_classes }}">
{%- else -%}
<div class="{{ card_classes }}">
{%- endif -%}
  <article class="pflege-cat-card__inner">
    {%- if show_tip -%}
      <div class="pflege-cat-card__corner-badges" aria-hidden="true">
        <span class="pflege-cat-card__badge pflege-cat-card__badge--tip">Unser Tipp!</span>
      </div>
    {%- endif -%}
    <div class="pflege-cat-card__media">
      {%- if show_rezept_badge -%}
        <div class="pflege-cat-card__badges">
          <span class="pflege-cat-card__badge pflege-cat-card__badge--blue">Rezeptfähig</span>
        </div>
      {%- endif -%}
      {%- if p.featured_media -%}
        <a href="{{ p.url }}" class="pflege-cat-card__media-link">
          {{
            p.featured_media
            | image_url: width: 960
            | image_tag:
              class: 'pflege-cat-card__img',
              loading: 'lazy',
              widths: '320, 480, 640, 960',
              sizes: '(min-width: 990px) 368px, (min-width: 600px) 55vw, 68vw',
              alt: p.featured_media.alt | default: p.title | escape
          }}
        </a>
      {%- else -%}
        <a href="{{ p.url }}" class="pflege-cat-card__media-link pflege-cat-card__media-link--placeholder">
          <span class="pflege-cat-card__placeholder">Produktbild</span>
        </a>
      {%- endif -%}
    </div>
    <div class="pflege-cat-card__body">
      <h3 class="pflege-cat-card__title">
        <a href="{{ p.url }}">{{ p.title | escape }}</a>
      </h3>
      {%- if subtitle != blank -%}
        <p class="pflege-cat-card__desc">{{ subtitle | escape }}</p>
      {%- else -%}
        <p class="pflege-cat-card__desc pflege-cat-card__desc--empty">&nbsp;</p>
      {%- endif -%}
      <div class="pflege-cat-card__price-row">
        <span class="pflege-cat-card__price">{{ price_label }}</span>
        {%- if unit_price_label != blank -%}
          <span class="pflege-cat-card__unit">{{ unit_price_label }}</span>
        {%- endif -%}
      </div>
      {%- if p.available and p.variants.size <= 1 and card_variant -%}
        <button
          type="button"
          class="pflege-cat-card__cart"
          data-variant-id="{{ card_variant.id }}"
        >
          <span class="pflege-cat-card__cart-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          </span>
          <span>In den Warenkorb</span>
        </button>
      {%- else -%}
        <a href="{{ p.url }}" class="pflege-cat-card__cart pflege-cat-card__cart--link">
          <span class="pflege-cat-card__cart-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          </span>
          <span>{%- if p.available -%}Optionen wählen{%- else -%}Ausverkauft{%- endif -%}</span>
        </a>
      {%- endif -%}
    </div>
  </article>
{%- if use_li -%}
</li>
{%- else -%}
</div>
{%- endif -%}

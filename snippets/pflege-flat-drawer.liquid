{% comment %}
  Mobil-Menü — Kategorien identisch mit Desktop, fest verdrahtet (kein externes Snippet).
{% endcomment %}
{%- liquid
  assign root = routes.root_url

  if collections.desinfektion != blank
    assign url_des = collections.desinfektion.url
  else
    assign url_des = root | append: 'collections/desinfektion'
  endif
  if collections.pflegeartikel != blank
    assign url_pf = collections.pflegeartikel.url
  else
    assign url_pf = root | append: 'collections/pflegeartikel'
  endif
  if collections['hautschutz-hautpflege'] != blank
    assign url_hh = collections['hautschutz-hautpflege'].url
  elsif collections['hauschutz-hautpflege'] != blank
    assign url_hh = collections['hauschutz-hautpflege'].url
  else
    assign url_hh = root | append: 'collections/hautschutz-hautpflege'
  endif
  if collections.verbrauchsartikel != blank
    assign url_ver = collections.verbrauchsartikel.url
  else
    assign url_ver = root | append: 'collections/verbrauchsartikel'
  endif

  assign active_des = false
  assign active_pf = false
  assign active_hh = false
  assign active_ver = false
  if request.page_type == 'collection'
    if collection.handle == 'desinfektion'
      assign active_des = true
    elsif collection.handle == 'pflegeartikel'
      assign active_pf = true
    elsif collection.handle == 'hautschutz-hautpflege' or collection.handle == 'hauschutz-hautpflege'
      assign active_hh = true
    elsif collection.handle == 'verbrauchsartikel'
      assign active_ver = true
    endif
  endif
-%}
<header-drawer data-breakpoint="tablet">
  <details id="Details-menu-drawer-container-pflege" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {{- 'icon-hamburger.svg' | inline_asset_content -}}
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </summary>
    <div id="menu-drawer-pflege" class="gradient menu-drawer motion-reduce color-{{ section.settings.menu_color_scheme }}">
      <div class="menu-drawer__inner-container">
        <div class="menu-drawer__navigation-container">
          <nav class="menu-drawer__navigation">
            <ul class="menu-drawer__menu has-submenu list-menu" role="list">
              <li>
                <a
                  href="{{ url_des }}"
                  class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if active_des %} menu-drawer__menu-item--active{% endif %}"
                  {% if active_des %}aria-current="page"{% endif %}
                >Desinfektion</a>
              </li>
              <li>
                <a
                  href="{{ url_pf }}"
                  class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if active_pf %} menu-drawer__menu-item--active{% endif %}"
                  {% if active_pf %}aria-current="page"{% endif %}
                >Pflegeartikel</a>
              </li>
              <li>
                <a
                  href="{{ url_hh }}"
                  class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if active_hh %} menu-drawer__menu-item--active{% endif %}"
                  {% if active_hh %}aria-current="page"{% endif %}
                >Hautschutz &amp; Hautpflege</a>
              </li>
              <li>
                <a
                  href="{{ url_ver }}"
                  class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if active_ver %} menu-drawer__menu-item--active{% endif %}"
                  {% if active_ver %}aria-current="page"{% endif %}
                >Verbrauchsartikel</a>
              </li>
            </ul>
          </nav>
          <div class="menu-drawer__utility-links">
            {%- if shop.customer_accounts_enabled -%}
              <a
                href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
                class="menu-drawer__account link focus-inset h5 medium-hide large-up-hide"
                rel="nofollow"
              >
                <span class="svg-wrapper">
                  {{- 'icon-account.svg' | inline_asset_content -}}
                </span>
                {%- liquid
                  if customer
                    echo 'customer.account_fallback' | t
                  else
                    echo 'customer.log_in' | t
                  endif
                -%}
              </a>
            {%- endif -%}
            {%- if localization.available_countries or localization.available_languages -%}
              <div class="menu-drawer__localization header-localization">
                {%- if localization.available_countries and localization.available_countries.size > 1 -%}
                  <localization-form>
                    {%- form 'localization', id: 'PflegeHeaderCountryMobileForm', class: 'localization-form' -%}
                      <div>
                        <h2 class="visually-hidden" id="PflegeHeaderCountryMobileLabel">
                          {{ 'localization.country_label' | t }}
                        </h2>
                        {%- render 'country-localization', localPosition: 'PflegeCountryMobile' -%}
                      </div>
                    {%- endform -%}
                  </localization-form>
                {% endif %}

                {%- if localization.available_languages and localization.available_languages.size > 1 -%}
                  <localization-form>
                    {%- form 'localization', id: 'PflegeHeaderLanguageMobileForm', class: 'localization-form' -%}
                      <div>
                        <h2 class="visually-hidden" id="PflegeHeaderLanguageMobileLabel">
                          {{ 'localization.language_label' | t }}
                        </h2>
                        {%- render 'language-localization', localPosition: 'PflegeLanguageMobile' -%}
                      </div>
                    {%- endform -%}
                  </localization-form>
                {%- endif -%}
              </div>
            {%- endif -%}
            <ul class="list list-social list-unstyled" role="list">
              {%- if settings.social_twitter_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_twitter_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-twitter.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.twitter' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_facebook_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_facebook_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-facebook.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.facebook' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_pinterest_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_pinterest_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-pinterest.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.pinterest' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_instagram_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_instagram_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-instagram.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.instagram' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_tiktok_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-tiktok.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.tiktok' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_tumblr_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_tumblr_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-tumblr.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.tumblr' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_snapchat_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_snapchat_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-snapchat.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.snapchat' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_youtube_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_youtube_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-youtube.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.youtube' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_vimeo_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_vimeo_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-vimeo.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.vimeo' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </details>
</header-drawer>

{% comment %}
  PflegeShop — Seite „Empfohlene Artikel“
  Liest Antworten aus sessionStorage (pflegefinder_answers) und zeigt passende Kategorien.
{% endcomment %}

{{ 'section-pflege-finder-quiz.css' | asset_url | stylesheet_tag }}
{{ 'section-pflege-empfohlene-artikel.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pflege-finder-shared.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'pflege-empfohlene-artikel.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="pflege-empfohlene-artikel section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient"
  data-pflege-empfohlene-artikel
  aria-labelledby="pflege-empfohlene-title-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="pflege-empfohlene-artikel__shell">
    <noscript>
      <p class="pflege-finder-quiz__nojs">
        Diese Seite benötigt JavaScript. Bitte aktivieren Sie JavaScript oder starten Sie den
        <a href="#pflege-finder-open">Produktfinder</a>.
      </p>
    </noscript>

    <div class="pflege-empfohlene-artikel__viewport" data-pflege-empfohlene-viewport></div>
  </div>

  {% render 'pflege-finder-data' %}
</section>

{% schema %}
{
  "name": "Empfohlene Artikel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 88
    }
  ],
  "presets": [
    {
      "name": "Empfohlene Artikel"
    }
  ]
}
{% endschema %}

{{ 'section-pflege-bestseller-row.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign use_collection = false
  if section.settings.data_source == 'collection' and section.settings.collection != blank and section.settings.collection.all_products_count > 0
    assign use_collection = true
  endif

  assign view_all_href = section.settings.view_all_link
  if view_all_href == blank and section.settings.collection != blank
    assign view_all_href = section.settings.collection.url
  endif
  if view_all_href == blank
    assign view_all_href = routes.all_products_collection_url
  endif

  assign limit_products = section.settings.products_to_show | default: 6
-%}

<section class="pflege-bestseller">
  <div class="pflege-bestseller__shell">
    <div class="pflege-bestseller__head">
      <h2 class="pflege-bestseller__title">{{ section.settings.title | escape }}</h2>
      {%- if section.settings.view_all_label != blank -%}
        <a class="pflege-bestseller__view-all" href="{{ view_all_href }}">
          {{- section.settings.view_all_label | escape -}}
        </a>
      {%- endif -%}
    </div>
    <div class="pflege-bestseller__grid">
      {%- if use_collection -%}
        {%- for card_product in section.settings.collection.products limit: limit_products -%}
          {% render 'pflege-bestseller-card', card_context: 'collection', card_product: card_product %}
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {% render 'pflege-bestseller-card', card_context: 'manual_block', block: block %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PflegeShop Bestseller",
  "tag": "section",
  "class": "pflege-bestseller-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Überschrift",
      "default": "Bestseller"
    },
    {
      "type": "select",
      "id": "data_source",
      "label": "Produkte",
      "options": [
        {
          "value": "collection",
          "label": "Aus Kollektion (Shopify-Produkte)"
        },
        {
          "value": "manual",
          "label": "Manuell (Blöcke unten)"
        }
      ],
      "default": "collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion",
      "info": "z. B. „Alle Produkte“ oder eine eigene Bestseller-Kollektion. Nur bei „Aus Kollektion“."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Anzahl Produkte",
      "info": "Nur bei „Aus Kollektion“."
    },
    {
      "type": "checkbox",
      "id": "show_collection_rating",
      "label": "Sterne bei Kollektion anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Link rechts",
      "default": "Alle ansehen →"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "Link-Ziel „Alle ansehen“",
      "info": "Leer = bei Kollektion die Kollektions-URL, sonst Alle Produkte."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Produkt",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produkt"
        },
        {
          "type": "text",
          "id": "manual_title",
          "label": "Demo-Titel (ohne Produkt)",
          "default": "Seni Care Feuchttücher Aqua"
        },
        {
          "type": "text",
          "id": "manual_subtitle",
          "label": "Demo-Unterzeile",
          "default": "48 Stk. | Packung"
        },
        {
          "type": "text",
          "id": "manual_price_display",
          "label": "Demo-Preis als Text",
          "default": "4,49 €",
          "info": "Nur wenn kein Produkt gewählt. Sonst Shopify-Preis."
        },
        {
          "type": "number",
          "id": "manual_price_cents",
          "label": "Demo-Preis (Cent)",
          "info": "Optional; sonst Textfeld „Demo-Preis“ nutzen."
        },
        {
          "type": "text",
          "id": "manual_review_count",
          "label": "Bewertungsanzahl Text",
          "default": "128"
        },
        {
          "type": "checkbox",
          "id": "show_rating",
          "label": "Sterne anzeigen",
          "default": true
        },
        {
          "type": "url",
          "id": "manual_link",
          "label": "Demo-Link",
          "info": "Ohne Produkt: wohin soll die Karte führen?"
        },
        {
          "type": "image_picker",
          "id": "placeholder_image",
          "label": "Demo-Bild"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PflegeShop Bestseller",
      "settings": {
        "data_source": "collection",
        "products_to_show": 6,
        "show_collection_rating": true
      },
      "blocks": [
        {
          "type": "product",
          "settings": {
            "manual_title": "Seni Care Feuchttücher Aqua",
            "manual_subtitle": "48 Stk. | Packung",
            "manual_price_display": "4,49 €",
            "manual_review_count": "128"
          }
        },
        {
          "type": "product",
          "settings": {
            "manual_title": "Seni Care Waschschaum ohne Wasser",
            "manual_subtitle": "500 ml | Flasche",
            "manual_price_display": "7,99 €",
            "manual_review_count": "94"
          }
        },
        {
          "type": "product",
          "settings": {
            "manual_title": "Seni San Premium Plus Größe M",
            "manual_subtitle": "30 Stk. | Packung",
            "manual_price_display": "16,99 €",
            "manual_review_count": "210"
          }
        },
        {
          "type": "product",
          "settings": {
            "manual_title": "Seni Care Schutzcreme mit Arginin",
            "manual_subtitle": "100 ml | Tube",
            "manual_price_display": "6,49 €",
            "manual_review_count": "76"
          }
        },
        {
          "type": "product",
          "settings": {
            "manual_title": "Seni Care Händedesinfektion Gel",
            "manual_subtitle": "500 ml | Flasche",
            "manual_price_display": "6,39 €",
            "manual_review_count": "54"
          }
        },
        {
          "type": "product",
          "settings": {
            "manual_title": "Seni Care Einmalwaschlappen Soft Care",
            "manual_subtitle": "50 Stk. | Packung",
            "manual_price_display": "3,99 €",
            "manual_review_count": "61"
          }
        }
      ]
    }
  ]
}
{% endschema %}

{{ 'section-pflege-bestseller-row.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign limit_products = section.settings.products_to_show | default: 6
  assign show_section = false

  if section.settings.data_source == 'collection'
    if section.settings.collection != blank and section.settings.collection.all_products_count > 0
      assign show_section = true
    endif
  else
    for block in section.blocks
      if block.settings.product != blank
        assign show_section = true
      endif
    endfor
  endif

  assign view_all_href = section.settings.view_all_link
  if view_all_href == blank and section.settings.collection != blank
    assign view_all_href = section.settings.collection.url
  endif
  if view_all_href == blank
    assign view_all_href = routes.all_products_collection_url
  endif
-%}

{%- if show_section -%}
  <section class="pflege-bestseller">
    <div class="pflege-bestseller__shell">
      <div class="pflege-bestseller__panel">
        <div class="pflege-bestseller__head">
          <h2 class="pflege-bestseller__title">{{ section.settings.title | escape }}</h2>
          {%- if section.settings.view_all_label != blank -%}
            <a class="pflege-bestseller__view-all" href="{{ view_all_href }}">
              {{- section.settings.view_all_label | escape -}}
            </a>
          {%- endif -%}
        </div>
        <div class="pflege-bestseller__grid">
          {%- if section.settings.data_source == 'collection' -%}
            {%- for card_product in section.settings.collection.products limit: limit_products -%}
              {% render 'pflege-bestseller-card', card_context: 'collection', card_product: card_product %}
            {%- endfor -%}
          {%- else -%}
            {%- for block in section.blocks -%}
              {%- if block.settings.product != blank -%}
                {% render 'pflege-bestseller-card', card_context: 'manual_block', block: block %}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "PflegeShop Bestseller",
  "tag": "section",
  "class": "pflege-bestseller-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Überschrift",
      "default": "Bestseller"
    },
    {
      "type": "select",
      "id": "data_source",
      "label": "Produkte",
      "options": [
        {
          "value": "collection",
          "label": "Aus Kollektion (Shopify-Produkte)"
        },
        {
          "value": "manual",
          "label": "Manuell (Blöcke unten)"
        }
      ],
      "default": "collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion",
      "info": "z. B. „Alle Produkte“. Ohne Kollektion oder ohne Artikel im Shop wird diese Section nicht angezeigt — keine Platzhalter."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Anzahl Produkte",
      "info": "Nur bei „Aus Kollektion“."
    },
    {
      "type": "checkbox",
      "id": "show_collection_rating",
      "label": "Sterne bei Kollektion anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Link rechts",
      "default": "Alle ansehen →"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "Link-Ziel „Alle ansehen“",
      "info": "Leer = bei Kollektion die Kollektions-URL, sonst Alle Produkte."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Produkt",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produkt"
        },
        {
          "type": "text",
          "id": "manual_title",
          "label": "Fallback-Titel",
          "info": "Nur wenn oben kein Produkt gewählt ist. Ohne Produkt wird die Karte nicht angezeigt."
        },
        {
          "type": "text",
          "id": "manual_subtitle",
          "label": "Fallback-Unterzeile"
        },
        {
          "type": "text",
          "id": "manual_price_display",
          "label": "Fallback-Preis als Text",
          "info": "Nur ohne gewähltes Produkt (selten). Mit Produkt: Shop-Preis."
        },
        {
          "type": "number",
          "id": "manual_price_cents",
          "label": "Fallback-Preis (Cent)",
          "info": "Nur ohne Produkt."
        },
        {
          "type": "text",
          "id": "manual_review_count",
          "label": "Bewertungsanzahl (Text)",
          "info": "Nur bei manueller Zeile mit Produkt, wenn Sterne aktiv sind."
        },
        {
          "type": "checkbox",
          "id": "show_rating",
          "label": "Sterne anzeigen",
          "default": true
        },
        {
          "type": "url",
          "id": "manual_link",
          "label": "Fallback-Link",
          "info": "Nur ohne gewähltes Produkt."
        },
        {
          "type": "image_picker",
          "id": "placeholder_image",
          "label": "Fallback-Bild",
          "info": "Nur ohne gewähltes Produkt."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PflegeShop Bestseller",
      "settings": {
        "data_source": "collection",
        "products_to_show": 6,
        "show_collection_rating": true
      }
    }
  ]
}
{% endschema %}

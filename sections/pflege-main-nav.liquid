{{ 'section-pflege-main-nav.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign root = routes.root_url

  if collections.desinfektion != blank
    assign url_des = collections.desinfektion.url
  else
    assign url_des = root | append: 'collections/desinfektion'
  endif
  if collections.pflegeartikel != blank
    assign url_pf = collections.pflegeartikel.url
  else
    assign url_pf = root | append: 'collections/pflegeartikel'
  endif
  if collections['hautschutz-hautpflege'] != blank
    assign url_hh = collections['hautschutz-hautpflege'].url
  elsif collections['hauschutz-hautpflege'] != blank
    assign url_hh = collections['hauschutz-hautpflege'].url
  else
    assign url_hh = root | append: 'collections/hautschutz-hautpflege'
  endif
  if collections.verbrauchsartikel != blank
    assign url_ver = collections.verbrauchsartikel.url
  else
    assign url_ver = root | append: 'collections/verbrauchsartikel'
  endif

  assign active_des = false
  assign active_pf = false
  assign active_hh = false
  assign active_ver = false
  if request.page_type == 'collection'
    if collection.handle == 'desinfektion'
      assign active_des = true
    elsif collection.handle == 'pflegeartikel'
      assign active_pf = true
    elsif collection.handle == 'hautschutz-hautpflege'
      assign active_hh = true
    elsif collection.handle == 'hauschutz-hautpflege'
      assign active_hh = true
    elsif collection.handle == 'verbrauchsartikel'
      assign active_ver = true
    endif
  endif
-%}

{%- comment -%}
  Robustes Critical-CSS direkt in der Section: garantiert vor section-pflege-main-nav.css aktiv,
  damit der „Kategorien“-Bereich nie leer ist und die Grid-Spalten nie kollabieren.
  Sync-Marker v3 (2026-05-06): inline-Kategorien.
{%- endcomment -%}
<style id="pflege-main-nav-critical-{{ section.id }}">
  .pflege-main-nav-section .pflege-main-nav__grid {
    width: 100%;
    box-sizing: border-box;
  }
  .pflege-main-nav-section .pflege-main-nav__categories {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .pflege-main-nav-section .pflege-main-nav__category-link {
    color: #0b2347;
    -webkit-text-fill-color: #0b2347;
    text-decoration: none;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
  }
  @media screen and (min-width: 750px) {
    .pflege-main-nav-section .pflege-main-nav__grid {
      display: grid !important;
      grid-template-columns:
        auto
        minmax(min(22rem, 36vw), 1fr)
        minmax(15rem, min(40rem, 37.33vw))
        auto !important;
      grid-template-areas: 'logo nav search actions' !important;
      align-items: center !important;
      column-gap: clamp(0.6rem, 1.6vw, 1.4rem) !important;
      row-gap: 0 !important;
    }
    .pflege-main-nav-section .pflege-main-nav__drawer-slot {
      display: none !important;
    }
    .pflege-main-nav-section .pflege-main-nav__logo {
      grid-area: logo !important;
      justify-self: start !important;
      transform: translateY(-0.85rem) !important;
    }
    .pflege-main-nav-section .pflege-main-nav__nav {
      grid-area: nav !important;
      display: block !important;
      visibility: visible !important;
      opacity: 1 !important;
      width: 100% !important;
      min-width: 0 !important;
      margin: 0 !important;
      padding: 0 clamp(0.1rem, 0.45vw, 0.4rem) !important;
    }
    .pflege-main-nav-section .pflege-main-nav__categories {
      display: flex !important;
      flex-direction: row !important;
      flex-wrap: nowrap !important;
      align-items: center !important;
      justify-content: space-evenly !important;
      gap: clamp(0.4rem, 1.2vw, 1rem) !important;
      width: 100% !important;
    }
    .pflege-main-nav-section .pflege-main-nav__categories > li {
      flex: 0 1 auto !important;
      min-width: max-content !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
    }
    .pflege-main-nav-section .pflege-main-nav__category-link {
      display: inline-block !important;
      font-size: clamp(0.85rem, 0.35rem + 0.95vw, 1.32rem) !important;
      padding: 0.35rem 0.25rem !important;
    }
    .pflege-main-nav-section predictive-search.pflege-main-nav__search-host {
      grid-area: search !important;
      display: block !important;
      width: 100% !important;
      max-width: min(40rem, 37.33vw) !important;
      min-width: 15rem !important;
      justify-self: stretch !important;
    }
    .pflege-main-nav-section .pflege-main-nav__grid > form.pflege-main-nav__search {
      grid-area: search !important;
      width: 100% !important;
      max-width: min(40rem, 37.33vw) !important;
      min-width: 15rem !important;
      justify-self: stretch !important;
    }
    .pflege-main-nav-section .pflege-main-nav__actions {
      grid-area: actions !important;
      justify-self: end !important;
    }
  }
  @media screen and (max-width: 749px) {
    .pflege-main-nav-section .pflege-main-nav__nav {
      display: none !important;
    }
  }
</style>

<div class="header-wrapper pflege-main-nav pflege-main-nav--full-bleed color-{{ section.settings.color_scheme }} gradient">
  <div class="pflege-main-nav__grid">
    <div class="pflege-main-nav__drawer-slot">
      {% render 'pflege-flat-drawer' %}
    </div>

    <div class="pflege-main-nav__logo">
      <a href="{{ routes.root_url }}" class="pflege-main-nav__logo-link">
        {% render 'pflege-logo-webp',
          img_class: 'pflege-main-nav__logo-img',
          logo_width: section.settings.logo_width,
          logo_height: section.settings.logo_height
        %}
      </a>
    </div>

    <nav
      class="pflege-main-nav__nav"
      aria-label="{{ section.settings.menu_label | escape }}"
      data-pflege-nav="inline-fixed-v2"
    >
      <ul class="pflege-main-nav__categories">
        <li>
          <a
            href="{{ url_des }}"
            class="pflege-main-nav__category-link{% if active_des %} is-active{% endif %}"
            {% if active_des %}aria-current="page"{% endif %}
          >Desinfektion</a>
        </li>
        <li>
          <a
            href="{{ url_pf }}"
            class="pflege-main-nav__category-link{% if active_pf %} is-active{% endif %}"
            {% if active_pf %}aria-current="page"{% endif %}
          >Pflegeartikel</a>
        </li>
        <li>
          <a
            href="{{ url_hh }}"
            class="pflege-main-nav__category-link{% if active_hh %} is-active{% endif %}"
            {% if active_hh %}aria-current="page"{% endif %}
          >Hautschutz &amp; Hautpflege</a>
        </li>
        <li>
          <a
            href="{{ url_ver }}"
            class="pflege-main-nav__category-link{% if active_ver %} is-active{% endif %}"
            {% if active_ver %}aria-current="page"{% endif %}
          >Verbrauchsartikel</a>
        </li>
      </ul>
    </nav>

    {%- if settings.predictive_search_enabled -%}
      <predictive-search class="pflege-main-nav__search-host" data-loading-text="{{ 'accessibility.loading' | t }}">
    {%- endif -%}
    <form class="pflege-main-nav__search" action="{{ routes.search_url }}" method="get" role="search">
      <input type="hidden" name="options[prefix]" value="last">
      <label class="visually-hidden" for="PflegeMainNavSearch-{{ section.id }}">
        {{- section.settings.search_placeholder | escape -}}
      </label>
      <input
        id="PflegeMainNavSearch-{{ section.id }}"
        class="pflege-main-nav__search-input"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ section.settings.search_placeholder | escape }}"
        autocomplete="off"
        {%- if settings.predictive_search_enabled -%}
          role="combobox"
          aria-expanded="false"
          aria-owns="predictive-search-results"
          aria-controls="predictive-search-results"
          aria-haspopup="listbox"
          aria-autocomplete="list"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
        {%- endif -%}
      >
      {%- if settings.predictive_search_enabled -%}
        <button
          type="reset"
          class="pflege-main-nav__search-reset{% if search.terms == blank %} hidden{% endif %}"
          aria-label="{{ 'general.search.reset' | t }}"
        >
          <span class="svg-wrapper">{{ 'icon-reset.svg' | inline_asset_content }}</span>
        </button>
      {%- endif -%}
      <button type="submit" class="pflege-main-nav__search-submit" aria-label="{{ 'general.search.search' | t }}">
        <span class="svg-wrapper">{{ 'icon-search.svg' | inline_asset_content }}</span>
      </button>
    </form>
    {%- if settings.predictive_search_enabled -%}
      <div
        class="predictive-search predictive-search--header pflege-main-nav__predictive-panel"
        tabindex="-1"
        data-predictive-search
      >
        {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}
      </div>
      <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
      </predictive-search>
    {%- endif -%}

    <div class="pflege-main-nav__actions">
      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="pflege-main-nav__action pflege-main-nav__action--account link focus-inset"
          rel="nofollow"
        >
          <span class="pflege-main-nav__action-icon">
            <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
          </span>
          <span class="pflege-main-nav__stack">
            <strong class="pflege-main-nav__stack-title">{{ section.settings.account_heading | escape }}</strong>
            <span class="pflege-main-nav__stack-sub">
              {%- liquid
                if customer
                  echo 'customer.account_fallback' | t
                else
                  echo section.settings.account_sub_guest | escape
                endif
              -%}
            </span>
          </span>
        </a>
      {%- endif -%}

      <div class="pflege-main-nav__action pflege-main-nav__action--cart">
        <a
          href="{{ routes.cart_url }}"
          id="pflege-cart-icon-bubble"
          class="pflege-main-nav__cart-hit pflege-main-nav__cart-icon link focus-inset"
        >
          <span id="pflege-cart-icon-contents" class="pflege-main-nav__cart-graphic">
            {% render 'pflege-cart-icon-inner' %}
          </span>
          <div class="pflege-main-nav__stack">
            <strong class="pflege-main-nav__stack-title">{{ section.settings.cart_heading | escape }}</strong>
            <span class="pflege-main-nav__cart-total" data-pflege-cart-total>{{ cart.total_price | money }}</span>
          </div>
        </a>
      </div>
    </div>
  </div>
</div>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification', color_scheme: section.settings.color_scheme, desktop_menu_type: 'dropdown' -%}
{%- endif -%}

<div class="visually-hidden" aria-hidden="true">
  <a href="{{ routes.cart_url }}" id="cart-icon-bubble">{% render 'pflege-cart-icon-inner' %}</a>
</div>

{% schema %}
{
  "name": "PflegeShop Hauptleiste",
  "tag": "section",
  "class": "pflege-main-nav-section section-header",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "menu_color_scheme",
      "label": "Farbschema Mobil-Menü (Drawer)",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "menu_label",
      "label": "Navigations-Beschriftung (aria)",
      "default": "Produktbereiche"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Suchfeld Platzhalter",
      "default": "Produkte suchen..."
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 320,
      "step": 4,
      "unit": "px",
      "label": "Logo Breite",
      "default": 240
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Logo Höhe (Attribut)",
      "default": 52
    },
    {
      "type": "text",
      "id": "account_heading",
      "label": "Konto Überschrift",
      "default": "Mein Konto"
    },
    {
      "type": "text",
      "id": "account_sub_guest",
      "label": "Konto Unterzeile (Gast)",
      "default": "Anmelden"
    },
    {
      "type": "text",
      "id": "cart_heading",
      "label": "Warenkorb Überschrift",
      "default": "Warenkorb"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "PflegeShop Hauptleiste"
    }
  ]
}
{% endschema %}

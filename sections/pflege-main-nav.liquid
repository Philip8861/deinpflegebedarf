{{ 'section-pflege-main-nav.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Kritisches CSS: Desktop = Grid-Spalte »nav« mit minmax(), damit die 4 Kategorien zwischen Logo und Suche nie auf 0px kollabieren.
{%- endcomment -%}
<style id="pflege-main-nav-critical-{{ section.id }}">
  @media screen and (min-width: 750px) {
    .header-wrapper.pflege-main-nav .pflege-main-nav__grid {
      display: grid !important;
      grid-template-columns:
        auto
        minmax(17rem, 1fr)
        minmax(11rem, min(30rem, 28vw))
        auto !important;
      grid-template-areas: 'logo nav search actions' !important;
      align-items: center !important;
      column-gap: clamp(0.55rem, 1.6vw, 1.35rem) !important;
      row-gap: 0 !important;
      width: 100% !important;
      box-sizing: border-box !important;
    }
    .header-wrapper.pflege-main-nav .pflege-main-nav__drawer-slot--phones-only {
      display: none !important;
    }
    .header-wrapper.pflege-main-nav .pflege-main-nav__logo {
      grid-area: logo !important;
      justify-self: start !important;
      max-width: none !important;
    }
    .header-wrapper.pflege-main-nav .pflege-main-nav__nav--desktop-inline {
      grid-area: nav !important;
      display: flex !important;
      align-items: center !important;
      justify-self: stretch !important;
      position: relative !important;
      z-index: 4 !important;
      isolation: isolate !important;
      min-width: 0 !important;
      width: 100% !important;
      margin: 0 !important;
      padding: 0 clamp(0.1rem, 0.45vw, 0.45rem) !important;
      overflow: visible !important;
      visibility: visible !important;
      opacity: 1 !important;
      color: #0b2347 !important;
    }
    .header-wrapper.pflege-main-nav .pflege-main-nav__nav--desktop-inline .pflege-main-nav__menu {
      display: flex !important;
      flex-direction: row !important;
      flex-wrap: nowrap !important;
      align-items: center !important;
      justify-content: space-evenly !important;
      gap: clamp(0.2rem, 1vw, 0.75rem) !important;
      width: 100% !important;
      margin: 0 !important;
      padding: 0 !important;
      list-style: none !important;
    }
    .header-wrapper.pflege-main-nav .pflege-main-nav__nav--desktop-inline .pflege-main-nav__menu > li {
      flex: 1 1 0 !important;
      min-width: 0 !important;
      display: flex !important;
      justify-content: center !important;
    }
    .header-wrapper.pflege-main-nav .pflege-main-nav__nav--desktop-inline .pflege-main-nav__menu-link {
      display: block !important;
      color: #0b2347 !important;
      -webkit-text-fill-color: #0b2347 !important;
      font-size: clamp(0.78rem, 0.32rem + 0.95vw, 1.28rem) !important;
      font-weight: 500 !important;
      text-decoration: none !important;
      text-align: center !important;
      white-space: nowrap !important;
      overflow: visible !important;
      text-overflow: clip !important;
      max-width: 100% !important;
      mix-blend-mode: normal !important;
      opacity: 1 !important;
      visibility: visible !important;
    }
    .header-wrapper.pflege-main-nav predictive-search.pflege-main-nav__search-host {
      grid-area: search !important;
      display: block !important;
      position: relative !important;
      z-index: 1 !important;
      width: 100% !important;
      max-width: min(30rem, 28vw) !important;
      min-width: 11rem !important;
      justify-self: stretch !important;
      box-sizing: border-box !important;
    }
    .header-wrapper.pflege-main-nav .pflege-main-nav__grid > form.pflege-main-nav__search {
      grid-area: search !important;
      display: flex !important;
      width: 100% !important;
      max-width: min(30rem, 28vw) !important;
      min-width: 11rem !important;
      justify-self: stretch !important;
      box-sizing: border-box !important;
    }
    .header-wrapper.pflege-main-nav .pflege-main-nav__actions {
      grid-area: actions !important;
      justify-self: end !important;
    }
  }
  @media screen and (max-width: 749px) {
    .header-wrapper.pflege-main-nav .pflege-main-nav__nav--desktop-inline {
      display: none !important;
    }
  }
</style>

<div class="header-wrapper pflege-main-nav pflege-main-nav--full-bleed color-{{ section.settings.color_scheme }} gradient">
  <div class="pflege-main-nav__grid">
    <div class="pflege-main-nav__drawer-slot pflege-main-nav__drawer-slot--phones-only">
      {% render 'pflege-flat-drawer' %}
    </div>

    <div class="pflege-main-nav__logo">
      <a href="{{ routes.root_url }}" class="pflege-main-nav__logo-link">
        {% render 'pflege-logo-webp',
          img_class: 'pflege-main-nav__logo-img',
          logo_width: section.settings.logo_width,
          logo_height: section.settings.logo_height
        %}
      </a>
    </div>

    <nav
      class="pflege-main-nav__nav pflege-main-nav__nav--desktop-inline"
      aria-label="{{ section.settings.menu_label | escape }}"
    >
      <ul class="pflege-main-nav__menu" data-pflege-nav-categories="inline-desktop-grid-v1">
        {% render 'pflege-shop-kategorien', variant: 'desktop' %}
      </ul>
    </nav>

    {%- if settings.predictive_search_enabled -%}
      <predictive-search class="pflege-main-nav__search-host" data-loading-text="{{ 'accessibility.loading' | t }}">
    {%- endif -%}
    <form class="pflege-main-nav__search" action="{{ routes.search_url }}" method="get" role="search">
      <input type="hidden" name="options[prefix]" value="last">
      <label class="visually-hidden" for="PflegeMainNavSearch-{{ section.id }}">
        {{- section.settings.search_placeholder | escape -}}
      </label>
      <input
        id="PflegeMainNavSearch-{{ section.id }}"
        class="pflege-main-nav__search-input"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ section.settings.search_placeholder | escape }}"
        autocomplete="off"
        {%- if settings.predictive_search_enabled -%}
          role="combobox"
          aria-expanded="false"
          aria-owns="predictive-search-results"
          aria-controls="predictive-search-results"
          aria-haspopup="listbox"
          aria-autocomplete="list"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
        {%- endif -%}
      >
      {%- if settings.predictive_search_enabled -%}
        <button
          type="reset"
          class="pflege-main-nav__search-reset{% if search.terms == blank %} hidden{% endif %}"
          aria-label="{{ 'general.search.reset' | t }}"
        >
          <span class="svg-wrapper">{{ 'icon-reset.svg' | inline_asset_content }}</span>
        </button>
      {%- endif -%}
      <button type="submit" class="pflege-main-nav__search-submit" aria-label="{{ 'general.search.search' | t }}">
        <span class="svg-wrapper">{{ 'icon-search.svg' | inline_asset_content }}</span>
      </button>
    </form>
    {%- if settings.predictive_search_enabled -%}
      <div
        class="predictive-search predictive-search--header pflege-main-nav__predictive-panel"
        tabindex="-1"
        data-predictive-search
      >
        {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}
      </div>
      <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
      </predictive-search>
    {%- endif -%}

    <div class="pflege-main-nav__actions">
      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="pflege-main-nav__action pflege-main-nav__action--account link focus-inset"
          rel="nofollow"
        >
          <span class="pflege-main-nav__action-icon">
            <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
          </span>
          <span class="pflege-main-nav__stack">
            <strong class="pflege-main-nav__stack-title">{{ section.settings.account_heading | escape }}</strong>
            <span class="pflege-main-nav__stack-sub">
              {%- liquid
                if customer
                  echo 'customer.account_fallback' | t
                else
                  echo section.settings.account_sub_guest | escape
                endif
              -%}
            </span>
          </span>
        </a>
      {%- endif -%}

      <div class="pflege-main-nav__action pflege-main-nav__action--cart">
        <a
          href="{{ routes.cart_url }}"
          id="pflege-cart-icon-bubble"
          class="pflege-main-nav__cart-hit pflege-main-nav__cart-icon link focus-inset"
        >
          <span id="pflege-cart-icon-contents" class="pflege-main-nav__cart-graphic">
            {% render 'pflege-cart-icon-inner' %}
          </span>
          <div class="pflege-main-nav__stack">
            <strong class="pflege-main-nav__stack-title">{{ section.settings.cart_heading | escape }}</strong>
            <span class="pflege-main-nav__cart-total" data-pflege-cart-total>{{ cart.total_price | money }}</span>
          </div>
        </a>
      </div>
    </div>
  </div>
</div>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification', color_scheme: section.settings.color_scheme, desktop_menu_type: 'dropdown' -%}
{%- endif -%}

<div class="visually-hidden" aria-hidden="true">
  <a href="{{ routes.cart_url }}" id="cart-icon-bubble">{% render 'pflege-cart-icon-inner' %}</a>
</div>

{% schema %}
{
  "name": "PflegeShop Hauptleiste",
  "tag": "section",
  "class": "pflege-main-nav-section section-header",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "menu_color_scheme",
      "label": "Farbschema Mobil-Menü (Drawer)",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "menu_label",
      "label": "Navigations-Beschriftung (aria)",
      "default": "Produktbereiche"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Suchfeld Platzhalter",
      "default": "Produkte suchen..."
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 320,
      "step": 4,
      "unit": "px",
      "label": "Logo Breite",
      "default": 242
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Logo Höhe (Attribut)",
      "default": 52
    },
    {
      "type": "text",
      "id": "account_heading",
      "label": "Konto Überschrift",
      "default": "Mein Konto"
    },
    {
      "type": "text",
      "id": "account_sub_guest",
      "label": "Konto Unterzeile (Gast)",
      "default": "Anmelden"
    },
    {
      "type": "text",
      "id": "cart_heading",
      "label": "Warenkorb Überschrift",
      "default": "Warenkorb"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "PflegeShop Hauptleiste"
    }
  ]
}
{% endschema %}

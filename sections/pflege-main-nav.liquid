<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

{{ 'section-pflege-main-nav.css' | asset_url | stylesheet_tag }}

<div class="header-wrapper pflege-main-nav pflege-main-nav--full-bleed color-{{ section.settings.color_scheme }} gradient">
  <div class="pflege-main-nav__grid">
    <div class="pflege-main-nav__drawer-slot large-up-hide">
      {% render 'pflege-flat-drawer' %}
    </div>

    <div class="pflege-main-nav__logo">
      <a href="{{ routes.root_url }}" class="pflege-main-nav__logo-link">
        {% render 'pflege-logo-webp',
          img_class: 'pflege-main-nav__logo-img',
          logo_width: section.settings.logo_width,
          logo_height: section.settings.logo_height
        %}
      </a>
    </div>

    <nav class="pflege-main-nav__nav" aria-label="{{ section.settings.menu_label | escape }}">
      {%- comment -%} Feste vier Kategorien (Snippet) — nicht über Theme-Blöcke {%- endcomment -%}
      <ul class="pflege-main-nav__menu" data-pflege-nav-categories="v4">
        {% render 'pflege-category-nav', variant: 'desktop' %}
      </ul>
    </nav>

    {%- if settings.predictive_search_enabled -%}
      <predictive-search class="pflege-main-nav__search-host" data-loading-text="{{ 'accessibility.loading' | t }}">
    {%- endif -%}
    <form class="pflege-main-nav__search" action="{{ routes.search_url }}" method="get" role="search">
      <input type="hidden" name="options[prefix]" value="last">
      <label class="visually-hidden" for="PflegeMainNavSearch-{{ section.id }}">
        {{- section.settings.search_placeholder | escape -}}
      </label>
      <input
        id="PflegeMainNavSearch-{{ section.id }}"
        class="pflege-main-nav__search-input"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ section.settings.search_placeholder | escape }}"
        autocomplete="off"
        {%- if settings.predictive_search_enabled -%}
          role="combobox"
          aria-expanded="false"
          aria-owns="predictive-search-results"
          aria-controls="predictive-search-results"
          aria-haspopup="listbox"
          aria-autocomplete="list"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
        {%- endif -%}
      >
      {%- if settings.predictive_search_enabled -%}
        <button
          type="reset"
          class="pflege-main-nav__search-reset{% if search.terms == blank %} hidden{% endif %}"
          aria-label="{{ 'general.search.reset' | t }}"
        >
          <span class="svg-wrapper">{{ 'icon-reset.svg' | inline_asset_content }}</span>
        </button>
      {%- endif -%}
      <button type="submit" class="pflege-main-nav__search-submit" aria-label="{{ 'general.search.search' | t }}">
        <span class="svg-wrapper">{{ 'icon-search.svg' | inline_asset_content }}</span>
      </button>
    </form>
    {%- if settings.predictive_search_enabled -%}
      <div
        class="predictive-search predictive-search--header pflege-main-nav__predictive-panel"
        tabindex="-1"
        data-predictive-search
      >
        {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}
      </div>
      <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
      </predictive-search>
    {%- endif -%}

    <div class="pflege-main-nav__actions">
      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="pflege-main-nav__action pflege-main-nav__action--account link focus-inset"
          rel="nofollow"
        >
          <span class="pflege-main-nav__action-icon">
            <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
          </span>
          <span class="pflege-main-nav__stack">
            <strong class="pflege-main-nav__stack-title">{{ section.settings.account_heading | escape }}</strong>
            <span class="pflege-main-nav__stack-sub">
              {%- liquid
                if customer
                  echo 'customer.account_fallback' | t
                else
                  echo section.settings.account_sub_guest | escape
                endif
              -%}
            </span>
          </span>
        </a>
      {%- endif -%}

      <div class="pflege-main-nav__action pflege-main-nav__action--cart">
        <a
          href="{{ routes.cart_url }}"
          id="pflege-cart-icon-bubble"
          class="pflege-main-nav__cart-hit pflege-main-nav__cart-icon link focus-inset"
        >
          <span id="pflege-cart-icon-contents" class="pflege-main-nav__cart-graphic">
            {% render 'pflege-cart-icon-inner' %}
          </span>
          <div class="pflege-main-nav__stack">
            <strong class="pflege-main-nav__stack-title">{{ section.settings.cart_heading | escape }}</strong>
            <span class="pflege-main-nav__cart-total" data-pflege-cart-total>{{ cart.total_price | money }}</span>
          </div>
        </a>
      </div>
    </div>
  </div>
</div>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification', color_scheme: section.settings.color_scheme, desktop_menu_type: 'dropdown' -%}
{%- endif -%}

<div class="visually-hidden" aria-hidden="true">
  <a href="{{ routes.cart_url }}" id="cart-icon-bubble">{% render 'pflege-cart-icon-inner' %}</a>
</div>

{% schema %}
{
  "name": "PflegeShop Hauptleiste",
  "tag": "section",
  "class": "pflege-main-nav-section section-header",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "menu_color_scheme",
      "label": "Farbschema Mobil-Menü (Drawer)",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "menu_label",
      "label": "Navigations-Beschriftung (aria)",
      "default": "Produktbereiche"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Suchfeld Platzhalter",
      "default": "Produkte suchen..."
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 320,
      "step": 4,
      "unit": "px",
      "label": "Logo Breite",
      "default": 242
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Logo Höhe (Attribut)",
      "default": 52
    },
    {
      "type": "text",
      "id": "account_heading",
      "label": "Konto Überschrift",
      "default": "Mein Konto"
    },
    {
      "type": "text",
      "id": "account_sub_guest",
      "label": "Konto Unterzeile (Gast)",
      "default": "Anmelden"
    },
    {
      "type": "text",
      "id": "cart_heading",
      "label": "Warenkorb Überschrift",
      "default": "Warenkorb"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigations-Link",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Bezeichnung",
          "default": "Kategorie"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Leer lassen für „Alle Produkte“."
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "PflegeShop Hauptleiste",
      "blocks": [
        {
          "type": "nav_link",
          "settings": {
            "title": "Desinfektion",
            "link": "shopify://collections/desinfektion"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "title": "Pflegeartikel",
            "link": "shopify://collections/pflegeartikel"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "title": "Hauschutz & Hautpflege",
            "link": "shopify://collections/hauschutz-hautpflege"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "title": "Verbrauchsartikel",
            "link": "shopify://collections/verbrauchsartikel"
          }
        }
      ]
    }
  ]
}
{% endschema %}

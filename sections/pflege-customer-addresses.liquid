{{ 'pflege-customer-shared.css' | asset_url | stylesheet_tag }}
{{ 'section-pflege-customer-login.css' | asset_url | stylesheet_tag }}
{{ 'section-pflege-customer-account.css' | asset_url | stylesheet_tag }}
<script src="{{ 'customer.js' | asset_url }}" defer></script>

{%- paginate customer.addresses by 5 -%}
<section class="pflege-customer-account-page customer addresses" aria-labelledby="pflege-addresses-title">
  <div class="pflege-customer-account-page__backdrop">
    <div class="pflege-customer-account-page__inner" data-customer-addresses>
      <a href="{{ routes.account_url }}" class="pflege-customer-account-page__back">
        ← {{ 'customer.account.return' | t }}
      </a>

      <header class="pflege-customer-account-page__header">
        <div>
          <h1 id="pflege-addresses-title" class="pflege-customer-account-page__greeting">
            {{ section.settings.title | escape }}
          </h1>
          <p class="pflege-customer-account-page__greeting-sub">
            {{ section.settings.subtitle | escape }}
          </p>
        </div>
      </header>

      <div class="pflege-customer-account-page__panel" data-address>
        <button
          type="button"
          class="pflege-customer-account-page__btn pflege-customer-account-page__btn--secondary"
          aria-expanded="false"
          aria-controls="AddAddress"
        >
          {% render 'pflege-icon', icon: 'user-plus', width: 18 %}
          {{ 'customer.addresses.add_new' | t }}
        </button>

        <div id="AddAddress" class="pflege-customer-account-page__address-form">
          <h2 id="AddressNewHeading" class="pflege-customer-account-page__panel-title">
            {{ 'customer.addresses.add_new' | t }}
          </h2>
          {%- form 'customer_address', customer.new_address, aria-labelledBy: 'AddressNewHeading' -%}
            <div class="pflege-customer-account-page__form-grid">
              <div class="pflege-customer-login__field">
                <label class="pflege-customer-login__label" for="AddressFirstNameNew">{{ 'customer.addresses.first_name' | t }}</label>
                <input type="text" id="AddressFirstNameNew" name="address[first_name]" value="{{ form.first_name }}" autocomplete="given-name" class="pflege-customer-login__input" placeholder="{{ 'customer.addresses.first_name' | t }}">
              </div>
              <div class="pflege-customer-login__field">
                <label class="pflege-customer-login__label" for="AddressLastNameNew">{{ 'customer.addresses.last_name' | t }}</label>
                <input type="text" id="AddressLastNameNew" name="address[last_name]" value="{{ form.last_name }}" autocomplete="family-name" class="pflege-customer-login__input" placeholder="{{ 'customer.addresses.last_name' | t }}">
              </div>
              <div class="pflege-customer-login__field pflege-customer-account-page__form-grid--full">
                <label class="pflege-customer-login__label" for="AddressCompanyNew">{{ 'customer.addresses.company' | t }}</label>
                <input type="text" id="AddressCompanyNew" name="address[company]" value="{{ form.company }}" autocomplete="organization" class="pflege-customer-login__input" placeholder="{{ 'customer.addresses.company' | t }}">
              </div>
              <div class="pflege-customer-login__field pflege-customer-account-page__form-grid--full">
                <label class="pflege-customer-login__label" for="AddressAddress1New">{{ 'customer.addresses.address1' | t }}</label>
                <input type="text" id="AddressAddress1New" name="address[address1]" value="{{ form.address1 }}" autocomplete="address-line1" class="pflege-customer-login__input" placeholder="{{ 'customer.addresses.address1' | t }}">
              </div>
              <div class="pflege-customer-login__field pflege-customer-account-page__form-grid--full">
                <label class="pflege-customer-login__label" for="AddressAddress2New">{{ 'customer.addresses.address2' | t }}</label>
                <input type="text" id="AddressAddress2New" name="address[address2]" value="{{ form.address2 }}" autocomplete="address-line2" class="pflege-customer-login__input" placeholder="{{ 'customer.addresses.address2' | t }}">
              </div>
              <div class="pflege-customer-login__field">
                <label class="pflege-customer-login__label" for="AddressCityNew">{{ 'customer.addresses.city' | t }}</label>
                <input type="text" id="AddressCityNew" name="address[city]" value="{{ form.city }}" autocomplete="address-level2" class="pflege-customer-login__input" placeholder="{{ 'customer.addresses.city' | t }}">
              </div>
              <div class="pflege-customer-login__field">
                <label class="pflege-customer-login__label" for="AddressZipNew">{{ 'customer.addresses.zip' | t }}</label>
                <input type="text" id="AddressZipNew" name="address[zip]" value="{{ form.zip }}" autocapitalize="characters" autocomplete="postal-code" class="pflege-customer-login__input" placeholder="{{ 'customer.addresses.zip' | t }}">
              </div>
              <div class="pflege-customer-account-page__select-wrap pflege-customer-account-page__form-grid--full">
                <label class="pflege-customer-account-page__select-label" for="AddressCountryNew">{{ 'customer.addresses.country' | t }}</label>
                <select id="AddressCountryNew" name="address[country]" data-default="{{ form.country }}" autocomplete="country" class="pflege-customer-account-page__select">
                  {{ all_country_option_tags }}
                </select>
              </div>
              <div id="AddressProvinceContainerNew" class="pflege-customer-account-page__select-wrap pflege-customer-account-page__form-grid--full" style="display: none">
                <label class="pflege-customer-account-page__select-label" for="AddressProvinceNew">{{ 'customer.addresses.province' | t }}</label>
                <select id="AddressProvinceNew" name="address[province]" data-default="{{ form.province }}" autocomplete="address-level1" class="pflege-customer-account-page__select"></select>
              </div>
              <div class="pflege-customer-login__field pflege-customer-account-page__form-grid--full">
                <label class="pflege-customer-login__label" for="AddressPhoneNew">{{ 'customer.addresses.phone' | t }}</label>
                <input type="tel" id="AddressPhoneNew" name="address[phone]" value="{{ form.phone }}" autocomplete="tel" class="pflege-customer-login__input" placeholder="{{ 'customer.addresses.phone' | t }}">
              </div>
            </div>
            <div class="pflege-customer-account-page__checkbox-row">
              {{ form.set_as_default_checkbox }}
              <label for="address_default_address_new">{{ 'customer.addresses.set_default' | t }}</label>
            </div>
            <div class="pflege-customer-account-page__form-actions">
              <button type="submit" class="pflege-customer-account-page__btn">{{ 'customer.addresses.add' | t }}</button>
              <button type="reset" class="pflege-customer-account-page__btn pflege-customer-account-page__btn--secondary">{{ 'customer.addresses.cancel' | t }}</button>
            </div>
          {%- endform -%}
        </div>
      </div>

      <div class="pflege-customer-account-page__address-grid">
        {%- for address in customer.addresses -%}
          <div
            class="pflege-customer-account-page__address-card{% if address == customer.default_address %} pflege-customer-account-page__address-card--default{% endif %}"
            data-address
          >
            {%- if address == customer.default_address -%}
              <span class="pflege-customer-account-page__address-default-badge">{{ 'customer.addresses.default' | t }}</span>
            {%- endif -%}
            <p class="pflege-customer-account-page__address-text">{{ address | format_address }}</p>
            <div class="pflege-customer-account-page__address-actions">
              <button
                type="button"
                class="pflege-customer-account-page__btn pflege-customer-account-page__btn--secondary"
                id="EditFormButton_{{ address.id }}"
                aria-label="{{ 'customer.addresses.edit_address' | t }} {{ forloop.index }}"
                aria-controls="EditAddress_{{ address.id }}"
                aria-expanded="false"
                data-address-id="{{ address.id }}"
              >
                {{ 'customer.addresses.edit' | t }}
              </button>
              <button
                type="button"
                class="pflege-customer-account-page__btn pflege-customer-account-page__btn--secondary"
                aria-label="{{ 'customer.addresses.delete' | t }} {{ forloop.index }}"
                data-target="{{ address.url }}"
                data-confirm-message="{{ 'customer.addresses.delete_confirm' | t }}"
              >
                {{ 'customer.addresses.delete' | t }}
              </button>
            </div>

            <div id="EditAddress_{{ address.id }}" class="pflege-customer-account-page__address-form">
              <h2 class="pflege-customer-account-page__panel-title">{{ 'customer.addresses.edit_address' | t }}</h2>
              {%- form 'customer_address', address -%}
                <div class="pflege-customer-account-page__form-grid">
                  <div class="pflege-customer-login__field">
                    <label class="pflege-customer-login__label" for="AddressFirstName_{{ form.id }}">{{ 'customer.addresses.first_name' | t }}</label>
                    <input type="text" id="AddressFirstName_{{ form.id }}" name="address[first_name]" value="{{ form.first_name }}" autocomplete="given-name" class="pflege-customer-login__input">
                  </div>
                  <div class="pflege-customer-login__field">
                    <label class="pflege-customer-login__label" for="AddressLastName_{{ form.id }}">{{ 'customer.addresses.last_name' | t }}</label>
                    <input type="text" id="AddressLastName_{{ form.id }}" name="address[last_name]" value="{{ form.last_name }}" autocomplete="family-name" class="pflege-customer-login__input">
                  </div>
                  <div class="pflege-customer-login__field pflege-customer-account-page__form-grid--full">
                    <label class="pflege-customer-login__label" for="AddressCompany_{{ form.id }}">{{ 'customer.addresses.company' | t }}</label>
                    <input type="text" id="AddressCompany_{{ form.id }}" name="address[company]" value="{{ form.company }}" autocomplete="organization" class="pflege-customer-login__input">
                  </div>
                  <div class="pflege-customer-login__field pflege-customer-account-page__form-grid--full">
                    <label class="pflege-customer-login__label" for="AddressAddress1_{{ form.id }}">{{ 'customer.addresses.address1' | t }}</label>
                    <input type="text" id="AddressAddress1_{{ form.id }}" name="address[address1]" value="{{ form.address1 }}" autocomplete="address-line1" class="pflege-customer-login__input">
                  </div>
                  <div class="pflege-customer-login__field pflege-customer-account-page__form-grid--full">
                    <label class="pflege-customer-login__label" for="AddressAddress2_{{ form.id }}">{{ 'customer.addresses.address2' | t }}</label>
                    <input type="text" id="AddressAddress2_{{ form.id }}" name="address[address2]" value="{{ form.address2 }}" autocomplete="address-line2" class="pflege-customer-login__input">
                  </div>
                  <div class="pflege-customer-login__field">
                    <label class="pflege-customer-login__label" for="AddressCity_{{ form.id }}">{{ 'customer.addresses.city' | t }}</label>
                    <input type="text" id="AddressCity_{{ form.id }}" name="address[city]" value="{{ form.city }}" autocomplete="address-level2" class="pflege-customer-login__input">
                  </div>
                  <div class="pflege-customer-login__field">
                    <label class="pflege-customer-login__label" for="AddressZip_{{ form.id }}">{{ 'customer.addresses.zip' | t }}</label>
                    <input type="text" id="AddressZip_{{ form.id }}" name="address[zip]" value="{{ form.zip }}" autocapitalize="characters" autocomplete="postal-code" class="pflege-customer-login__input">
                  </div>
                  <div class="pflege-customer-account-page__select-wrap pflege-customer-account-page__form-grid--full">
                    <label class="pflege-customer-account-page__select-label" for="AddressCountry_{{ form.id }}">{{ 'customer.addresses.country' | t }}</label>
                    <select id="AddressCountry_{{ form.id }}" name="address[country]" data-address-country-select data-default="{{ form.country }}" data-form-id="{{ form.id }}" autocomplete="country" class="pflege-customer-account-page__select">
                      {{ all_country_option_tags }}
                    </select>
                  </div>
                  <div id="AddressProvinceContainer_{{ form.id }}" class="pflege-customer-account-page__select-wrap pflege-customer-account-page__form-grid--full" style="display:none">
                    <label class="pflege-customer-account-page__select-label" for="AddressProvince_{{ form.id }}">{{ 'customer.addresses.province' | t }}</label>
                    <select id="AddressProvince_{{ form.id }}" name="address[province]" data-default="{{ form.province }}" autocomplete="address-level1" class="pflege-customer-account-page__select"></select>
                  </div>
                  <div class="pflege-customer-login__field pflege-customer-account-page__form-grid--full">
                    <label class="pflege-customer-login__label" for="AddressPhone_{{ form.id }}">{{ 'customer.addresses.phone' | t }}</label>
                    <input type="tel" id="AddressPhone_{{ form.id }}" name="address[phone]" value="{{ form.phone }}" autocomplete="tel" class="pflege-customer-login__input">
                  </div>
                </div>
                <div class="pflege-customer-account-page__checkbox-row">
                  {{ form.set_as_default_checkbox }}
                  <label for="address_default_address_{{ form.id }}">{{ 'customer.addresses.set_default' | t }}</label>
                </div>
                <div class="pflege-customer-account-page__form-actions">
                  <button type="submit" class="pflege-customer-account-page__btn">{{ 'customer.addresses.update' | t }}</button>
                  <button type="reset" class="pflege-customer-account-page__btn pflege-customer-account-page__btn--secondary">{{ 'customer.addresses.cancel' | t }}</button>
                </div>
              {%- endform -%}
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pflege-customer-account-page__pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
          <ul role="list">
            {%- if paginate.previous -%}
              <li><a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">‹</a></li>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              <li>
                {%- if part.is_link -%}
                  <a href="{{ part.url }}">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}
                  <span aria-current="page">{{ part.title }}</span>
                {%- else -%}
                  <span>{{ part.title }}</span>
                {%- endif -%}
              </li>
            {%- endfor -%}
            {%- if paginate.next -%}
              <li><a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">›</a></li>
            {%- endif -%}
          </ul>
        </nav>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  window.addEventListener('load', () => {
    typeof CustomerAddresses !== 'undefined' && new CustomerAddresses();
  });
</script>
{%- endpaginate -%}

{% schema %}
{
  "name": "Pflege Adressen",
  "tag": "section",
  "class": "section-pflege-customer-addresses",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titel",
      "default": "Meine Adressen"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Untertitel",
      "default": "Verwalten Sie Ihre Liefer- und Rechnungsadressen."
    }
  ]
}
{% endschema %}

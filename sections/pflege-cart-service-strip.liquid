{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient isolate pflege-cart-service-strip-wrap section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="pflege-cart-service-strip pflege-cart-card" role="region" aria-label="{{ 'sections.cart.pflege.service_strip_label' | t }}">
      <ul class="pflege-cart-service-strip__list list-unstyled" role="list">
        <li class="pflege-cart-service-strip__item">
          <span class="pflege-cart-service-strip__ic" aria-hidden="true">
            {% render 'pflege-icon', icon: 'truck', width: 22 %}
          </span>
          <span class="pflege-cart-service-strip__text">{{ 'sections.cart.pflege.service_ship' | t }}</span>
        </li>
        <li class="pflege-cart-service-strip__item">
          <span class="pflege-cart-service-strip__ic" aria-hidden="true">
            {% render 'pflege-icon', icon: 'phone', width: 22 %}
          </span>
          <span class="pflege-cart-service-strip__text">{{ 'sections.cart.pflege.service_phone' | t }}</span>
        </li>
        <li class="pflege-cart-service-strip__item">
          <span class="pflege-cart-service-strip__ic" aria-hidden="true">
            {% render 'pflege-icon', icon: 'badge-check', width: 22 %}
          </span>
          <span class="pflege-cart-service-strip__text">{{ 'sections.cart.pflege.service_quality' | t }}</span>
        </li>
      </ul>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Pflege Service-Leiste",
  "class": "pflege-cart-section pflege-cart-section--service",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "enabled_on": {
    "templates": ["cart"]
  }
}
{% endschema %}

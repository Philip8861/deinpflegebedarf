{%- comment -%}
  Brückenseite: leitet Besucher zum Ratgeber auf alltagshilfe-sued.de.
  Template: page.pflege-ratgeber — Admin-Seite Handle z. B. „pflegeratgeber“.
{%- endcomment -%}
{{ 'section-pflege-ratgeber-bridge.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading | strip
  assign sub = section.settings.subtitle | strip
  assign url = section.settings.external_url | strip
  assign label = section.settings.button_label | strip
-%}

<section
  class="pflege-ratgeber-bridge pflege-ratgeber-bridge--page-pad"
  aria-labelledby="pflege-ratgeber-title-{{ section.id }}"
>
  {% render 'pflege-ratgeber-bridge-view',
    bridge_id: section.id,
    heading: heading,
    subtitle: sub,
    url: url,
    label: label,
    body_html: section.settings.body
  %}
</section>

{% schema %}
{
  "name": "Ratgeber (extern)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Ratgeber"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Unterzeile",
      "default": "Tipps, Orientierung und fundierte Texte rund um Pflege und Alltag – kuratiert von Ihrer Alltagshilfe Süd."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Optionaler Textblock"
    },
    {
      "type": "text",
      "id": "external_url",
      "label": "Link-Ziel (URL)",
      "default": "https://www.alltagshilfe-sued.de/ratgeber",
      "info": "Vollständige Webadresse, z. B. https://www.alltagshilfe-sued.de/ratgeber"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Zum Ratgeber"
    },
    {
      "type": "header",
      "content": "Abstand"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding oben",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding unten",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Ratgeber (extern)"
    }
  ]
}
{% endschema %}

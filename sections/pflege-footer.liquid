{% comment %} PflegeShop — eigener Footer (ersetzt Dawn footer) {% endcomment %}
{{ 'section-pflege-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}
{{ 'component-localization-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .pflege-footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }
  #shopify-section-{{ section.id }} .pflege-footer__section-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .pflege-footer {
      margin-top: {{ section.settings.margin_top }}px;
    }
    #shopify-section-{{ section.id }} .pflege-footer__section-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign has_social_icons = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign has_social_icons = false
  endif

  assign show_main = false
  if section.blocks.size > 0
    assign show_main = true
  elsif section.settings.newsletter_enable
    assign show_main = true
  elsif section.settings.show_social and has_social_icons
    assign show_main = true
  elsif section.settings.enable_follow_on_shop
    assign show_main = true
  endif

  assign lh = section.settings.legal_heading | strip
  if lh == blank
    assign lh = 'footer_pflege.legal_heading' | t
  endif

  assign url_agb = section.settings.legal_url_agb
  if url_agb == blank and shop.terms_of_service != blank and shop.terms_of_service.url != blank
    assign url_agb = shop.terms_of_service.url
  endif
  assign url_impressum = section.settings.legal_url_impressum
  assign url_widerruf = section.settings.legal_url_widerruf
  if url_widerruf == blank and shop.refund_policy != blank and shop.refund_policy.url != blank
    assign url_widerruf = shop.refund_policy.url
  endif
  assign url_versand = section.settings.legal_url_versand
  if url_versand == blank and shop.shipping_policy != blank and shop.shipping_policy.url != blank
    assign url_versand = shop.shipping_policy.url
  endif
  assign url_datenschutz = section.settings.legal_url_datenschutz
  if url_datenschutz == blank and shop.privacy_policy != blank and shop.privacy_policy.url != blank
    assign url_datenschutz = shop.privacy_policy.url
  endif
-%}

<footer
  class="pflege-footer color-{{ section.settings.color_scheme }} gradient pflege-footer__section-padding"
  role="contentinfo"
>
  <div class="pflege-footer__shell">
    {%- if show_main -%}
      <div class="pflege-footer__inner">
        {%- if section.blocks.size > 0 -%}
          <div class="pflege-footer__main pflege-footer__main--blocks">
            {%- for block in section.blocks -%}
              <div class="pflege-footer__block" {{ block.shopify_attributes }}>
                {%- case block.type -%}
                  {%- when '@app' -%}
                    {% render block %}
                  {%- when 'link_list' -%}
                    {%- if block.settings.heading != blank -%}
                      <h2 class="pflege-footer__column-heading">{{ block.settings.heading | escape }}</h2>
                    {%- endif -%}
                    {%- if block.settings.menu != blank -%}
                      <ul class="pflege-footer__menu">
                        {%- for link in block.settings.menu.links -%}
                          <li>
                            <a href="{{ link.url }}">{{ link.title | escape }}</a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  {%- when 'text' -%}
                    {%- if block.settings.heading != blank -%}
                      <h2 class="pflege-footer__column-heading">{{ block.settings.heading | escape }}</h2>
                    {%- endif -%}
                    {%- if block.settings.subtext != blank -%}
                      <div class="pflege-footer__rte rte">{{ block.settings.subtext }}</div>
                    {%- endif -%}
                {%- endcase -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.newsletter_enable or section.settings.show_social and has_social_icons -%}
          <div class="pflege-footer__newsletter-social">
            {%- if section.settings.newsletter_enable -%}
              <div class="pflege-footer__newsletter">
                {%- if section.settings.newsletter_heading != blank -%}
                  <h2 class="pflege-footer__column-heading">{{ section.settings.newsletter_heading }}</h2>
                {%- endif -%}
                {%- assign newsletter_form_id = 'ContactPflegeFooter-' | append: section.id -%}
                {%- form 'customer', id: newsletter_form_id, class: 'footer__newsletter newsletter-form' -%}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  <div class="newsletter-form__field-wrapper">
                    <div class="field">
                      <input
                        id="NewsletterPflege-{{ section.id }}"
                        type="email"
                        name="contact[email]"
                        class="field__input"
                        value="{{ form.email }}"
                        aria-required="true"
                        autocorrect="off"
                        autocapitalize="off"
                        autocomplete="email"
                        {% if form.errors %}
                          autofocus
                          aria-invalid="true"
                          aria-describedby="PflegeFooter-error"
                        {% elsif form.posted_successfully? %}
                          aria-describedby="PflegeFooter-success"
                        {% endif %}
                        placeholder="{{ 'newsletter.label' | t }}"
                        required
                      >
                      <label class="field__label" for="NewsletterPflege-{{ section.id }}">
                        {{ 'newsletter.label' | t }}
                      </label>
                      <button
                        type="submit"
                        class="newsletter-form__button field__button"
                        name="commit"
                        aria-label="{{ 'newsletter.button_label' | t }}"
                      >
                        <span class="svg-wrapper">
                          {{- 'icon-arrow.svg' | inline_asset_content -}}
                        </span>
                      </button>
                    </div>
                    {%- if form.errors -%}
                      <small class="newsletter-form__message form__message" id="PflegeFooter-error">
                        <span class="svg-wrapper">{{ 'icon-error.svg' | inline_asset_content }}</span>
                        {{- form.errors.translated_fields.email | capitalize }}
                        {{ form.errors.messages.email -}}
                      </small>
                    {%- endif -%}
                  </div>
                  {%- if form.posted_successfully? -%}
                    <h3
                      class="newsletter-form__message newsletter-form__message--success form__message"
                      id="PflegeFooter-success"
                      tabindex="-1"
                      autofocus
                    >
                      <span class="svg-wrapper">{{ 'icon-success.svg' | inline_asset_content }}</span>
                      {{- 'newsletter.success' | t }}
                    </h3>
                  {%- endif -%}
                {%- endform -%}
              </div>
            {%- endif -%}

            {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
              <div class="footer__follow-on-shop">
                {{ shop | login_button: action: 'follow' }}
              </div>
            {%- endif -%}

            {%- if section.settings.show_social and has_social_icons -%}
              <div class="pflege-footer__social">
                {%- render 'social-icons', class: 'footer__list-social' -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="pflege-footer__inner">
      <div class="pflege-footer__bottom">
        <div class="pflege-footer__localization isolate">
          {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
            <localization-form>
              {%- form 'localization', id: 'PflegeFooterCountryForm', class: 'localization-form' -%}
                <div>
                  <h2 class="caption-large text-body" id="PflegeFooterCountryLabel">
                    {{ 'localization.country_label' | t }}
                  </h2>
                  {%- render 'country-localization', localPosition: 'PflegeFooterCountry' -%}
                </div>
              {%- endform -%}
            </localization-form>
          {%- endif -%}
          {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
            <localization-form>
              {%- form 'localization', id: 'PflegeFooterLanguageForm', class: 'localization-form' -%}
                <div>
                  <h2 class="caption-large text-body" id="PflegeFooterLanguageLabel">
                    {{ 'localization.language_label' | t }}
                  </h2>
                  {%- render 'language-localization', localPosition: 'PflegeFooterLanguage' -%}
                </div>
              {%- endform -%}
            </localization-form>
          {%- endif -%}
        </div>
        {%- if section.settings.payment_enable -%}
          <div class="footer__payment">
            <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
            <ul class="list list-payment" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>

      <div class="pflege-footer__copyright-wrap">
        <div class="pflege-footer__copyright caption">
          <small class="copyright__content"
            >&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url -}}
          </small>
          <small class="copyright__content">{{ powered_by_link }}</small>
          {%- if section.settings.show_policy -%}
            <ul class="policies list-unstyled" style="margin-top: 0.5rem;">
              {%- for policy in shop.policies -%}
                {%- if policy != blank -%}
                  <li>
                    <small class="copyright__content">
                      <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
                    </small>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      </div>
    </div>

    {%- if section.settings.legal_show -%}
      <div class="pflege-footer__legal color-{{ section.settings.legal_color_scheme }} gradient">
        <div class="pflege-footer__inner pflege-footer-legal__inner">
          <p class="pflege-footer-legal__title">{{ lh | escape }}</p>
          <ul class="pflege-footer-legal__list list-unstyled" role="list">
            <li class="pflege-footer-legal__item">
              {%- if url_agb != blank -%}
                <a class="pflege-footer-legal__link" href="{{ url_agb }}">{{ 'footer_pflege.link_agb' | t | escape }}</a>
              {%- else -%}
                <span class="pflege-footer-legal__pending">{{ 'footer_pflege.link_agb' | t | escape }}</span>
              {%- endif -%}
            </li>
            <li class="pflege-footer-legal__item">
              {%- if url_impressum != blank -%}
                <a class="pflege-footer-legal__link" href="{{ url_impressum }}">{{ 'footer_pflege.link_impressum' | t | escape }}</a>
              {%- else -%}
                <span class="pflege-footer-legal__pending">{{ 'footer_pflege.link_impressum' | t | escape }}</span>
              {%- endif -%}
            </li>
            <li class="pflege-footer-legal__item">
              {%- if url_widerruf != blank -%}
                <a class="pflege-footer-legal__link" href="{{ url_widerruf }}">{{ 'footer_pflege.link_widerruf' | t | escape }}</a>
              {%- else -%}
                <span class="pflege-footer-legal__pending">{{ 'footer_pflege.link_widerruf' | t | escape }}</span>
              {%- endif -%}
            </li>
            <li class="pflege-footer-legal__item">
              {%- if url_versand != blank -%}
                <a class="pflege-footer-legal__link" href="{{ url_versand }}">{{ 'footer_pflege.link_versand' | t | escape }}</a>
              {%- else -%}
                <span class="pflege-footer-legal__pending">{{ 'footer_pflege.link_versand' | t | escape }}</span>
              {%- endif -%}
            </li>
            <li class="pflege-footer-legal__item">
              {%- if url_datenschutz != blank -%}
                <a class="pflege-footer-legal__link" href="{{ url_datenschutz }}">{{ 'footer_pflege.link_datenschutz' | t | escape }}</a>
              {%- else -%}
                <span class="pflege-footer-legal__pending">{{ 'footer_pflege.link_datenschutz' | t | escape }}</span>
              {%- endif -%}
            </li>
          </ul>
        </div>
      </div>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Pflege Footer",
  "class": "pflege-footer-section",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.margin_top.label",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.padding_top.label",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.padding_bottom.label",
      "default": 36
    },
    {
      "type": "header",
      "content": "Newsletter & Social"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "t:sections.footer.settings.newsletter_enable.label"
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_heading",
      "default": "t:sections.footer.settings.newsletter_heading.default",
      "label": "t:sections.footer.settings.newsletter_heading.label"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": true,
      "label": "t:sections.footer.settings.show_social.label",
      "info": "t:sections.footer.settings.show_social.info"
    },
    {
      "type": "checkbox",
      "id": "enable_follow_on_shop",
      "default": false,
      "label": "t:sections.footer.settings.enable_follow_on_shop.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__2.content"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": false,
      "label": "t:sections.footer.settings.enable_country_selector.label"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": false,
      "label": "t:sections.footer.settings.enable_language_selector.label"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "t:sections.footer.settings.payment_enable.label"
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": false,
      "label": "t:sections.footer.settings.show_policy.label",
      "info": "t:sections.footer.settings.show_policy.info"
    },
    {
      "type": "header",
      "content": "Rechtliches"
    },
    {
      "type": "checkbox",
      "id": "legal_show",
      "default": true,
      "label": "Rechtliches-Leiste anzeigen"
    },
    {
      "type": "text",
      "id": "legal_heading",
      "label": "Überschrift",
      "default": "Rechtliches"
    },
    {
      "type": "color_scheme",
      "id": "legal_color_scheme",
      "label": "Farbschema Rechtliches",
      "default": "scheme-1"
    },
    {
      "type": "paragraph",
      "content": "Leere Felder: Shopify-Richtlinien nutzen (wo im Admin hinterlegt). Impressum: eigene Seite verknüpfen."
    },
    {
      "type": "url",
      "id": "legal_url_agb",
      "label": "AGB"
    },
    {
      "type": "url",
      "id": "legal_url_impressum",
      "label": "Impressum"
    },
    {
      "type": "url",
      "id": "legal_url_widerruf",
      "label": "Widerrufsrecht"
    },
    {
      "type": "url",
      "id": "legal_url_versand",
      "label": "Versandrichtlinien"
    },
    {
      "type": "url",
      "id": "legal_url_datenschutz",
      "label": "Datenschutzerklärung"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.link_list.settings.heading.default",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.text.settings.heading.default",
          "label": "t:sections.footer.blocks.text.settings.heading.label"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "<p></p>",
          "label": "t:sections.footer.blocks.text.settings.subtext.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pflege Footer",
      "blocks": [
        {
          "type": "link_list",
          "settings": {
            "heading": "Quick links",
            "menu": "footer"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "Info",
            "menu": "footer"
          }
        },
        {
          "type": "text",
          "settings": {
            "heading": "Our mission",
            "subtext": "<p>Share contact information, store details, and brand content with your customers.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

{{ 'section-pflege-contact-page.css' | asset_url | stylesheet_tag }}

{% comment %}
  Öffentliche URL: /pages/kontakt — im Shop eine „Seite“ mit Handle kontakt anlegen und die Vorlage „kontakt“
  (templates/page.kontakt.json) zuweisen. Inhalt und Formular kommen aus der Vorlage, kein Theme-Editor nötig.
{% endcomment %}

{%- liquid
  assign url_privacy = routes.root_url | append: 'pages/datenschutz'

  assign url_agb = routes.root_url | append: 'pages/agb'
  assign url_widerruf = routes.root_url | append: 'pages/widerrufsbelehrung'

  assign contact_email = section.settings.email | strip
  if contact_email == blank
    assign contact_email = 'deinpflegebedarf@alltagshilfe-sued.de'
  endif
  assign mailto_subject = section.settings.email_subject | default: 'Kontaktanfrage deinPflegebedarf' | url_encode

  assign phone_href = section.settings.phone_link | strip
  if phone_href == blank
    assign phone_href = 'tel:+4983349893330'
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="pflege-contact-page color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding{% unless section.settings.show_sidebar %} pflege-contact-page--form-only{% endunless %}"
  aria-labelledby="pflege-contact-heading"
>
  <div class="pflege-contact-page__shell">
    <header class="pflege-contact-page__header">
      <h1 id="pflege-contact-heading" class="pflege-contact-page__title">
        {%- if page != blank and page.title != blank -%}
          {{ page.title | escape }}
        {%- else -%}
          {{ section.settings.title_fallback | escape }}
        {%- endif -%}
      </h1>
      {%- if section.settings.show_page_intro and page != blank and page.content != blank -%}
        <div class="pflege-contact-page__intro rte">{{ page.content }}</div>
      {%- elsif section.settings.intro_text != blank -%}
        <div class="pflege-contact-page__intro rte">{{ section.settings.intro_text }}</div>
      {%- endif -%}
    </header>

    <div class="pflege-contact-page__grid">
      {%- if section.settings.show_sidebar -%}
        <aside class="pflege-contact-page__aside" aria-label="Kontaktdaten">
          <h2 class="pflege-contact-page__aside-title">
            {{ section.settings.sidebar_title | default: 'So erreichen Sie uns' | escape }}
          </h2>

          <ul class="pflege-contact-page__info-list" role="list">
            {%- if section.settings.box_hours_text != blank -%}
              <li class="pflege-contact-page__info-item">
                <span class="pflege-contact-page__info-ic" aria-hidden="true">
                  {% render 'pflege-icon', icon: 'clock', width: 26 %}
                </span>
                <div class="pflege-contact-page__info-body">
                  <span class="pflege-contact-page__info-label">
                    {{ section.settings.box_hours_title | default: 'Erreichbarkeit' | escape }}
                  </span>
                  <span class="pflege-contact-page__info-value">{{ section.settings.box_hours_text | escape }}</span>
                </div>
              </li>
            {%- endif -%}

            {%- if section.settings.phone != blank -%}
              <li class="pflege-contact-page__info-item">
                <span class="pflege-contact-page__info-ic" aria-hidden="true">
                  {% render 'pflege-icon', icon: 'phone', width: 26 %}
                </span>
                <div class="pflege-contact-page__info-body">
                  <span class="pflege-contact-page__info-label">Telefon</span>
                  <a class="pflege-contact-page__info-value pflege-contact-page__info-link" href="{{ phone_href }}">
                    {{- section.settings.phone | escape -}}
                  </a>
                </div>
              </li>
            {%- endif -%}

            {%- if section.settings.email != blank -%}
              <li class="pflege-contact-page__info-item">
                <span class="pflege-contact-page__info-ic" aria-hidden="true">
                  {% render 'pflege-icon', icon: 'mail', width: 26 %}
                </span>
                <div class="pflege-contact-page__info-body">
                  <span class="pflege-contact-page__info-label">E-Mail</span>
                  <a class="pflege-contact-page__info-value pflege-contact-page__info-link" href="mailto:{{ section.settings.email }}">
                    {{- section.settings.email | escape -}}
                  </a>
                </div>
              </li>
            {%- endif -%}

            {%- if section.settings.address != blank -%}
              <li class="pflege-contact-page__info-item">
                <span class="pflege-contact-page__info-ic" aria-hidden="true">
                  {% render 'pflege-icon', icon: 'package', width: 26 %}
                </span>
                <div class="pflege-contact-page__info-body">
                  <span class="pflege-contact-page__info-label">Adresse</span>
                  <span class="pflege-contact-page__info-value pflege-contact-page__info-value--rte rte">
                    {{- section.settings.address -}}
                  </span>
                </div>
              </li>
            {%- endif -%}
          </ul>

          {%- if section.settings.box_hint != blank -%}
            <p class="pflege-contact-page__info-hint">
              <span class="pflege-contact-page__info-hint-ic" aria-hidden="true">
                {% render 'pflege-icon', icon: 'badge-check', width: 18 %}
              </span>
              <span>{{ section.settings.box_hint | escape }}</span>
            </p>
          {%- endif -%}
        </aside>
      {%- endif -%}

      <div class="pflege-contact-page__form-card">
        <h2 class="pflege-contact-page__form-title">{{ section.settings.form_title | escape }}</h2>
        {%- if section.settings.form_lead != blank -%}
          <p class="pflege-contact-page__form-lead">{{ section.settings.form_lead | escape }}</p>
        {%- endif -%}

        <div class="pflege-contact-page__direct" role="group" aria-label="Kontaktmöglichkeiten">
          <p class="pflege-contact-page__direct-note">
            Für allgemeine Anfragen nutzen Sie bitte E-Mail oder Telefon. Es wird dabei <strong>keine automatische Shop-E-Mail</strong> ausgelöst — nur bei einem Widerruf über die Widerrufsbelehrung.
          </p>

          <div class="pflege-contact-page__direct-actions">
            <a
              class="pflege-contact-page__submit pflege-contact-page__direct-btn"
              href="mailto:{{ contact_email }}?subject={{ mailto_subject }}"
            >
              {{ section.settings.submit_label | default: 'E-Mail schreiben' | escape }}
            </a>
            {%- if section.settings.phone != blank -%}
              <a class="pflege-contact-page__submit pflege-contact-page__direct-btn pflege-contact-page__direct-btn--secondary" href="{{ phone_href }}">
                {{ section.settings.phone | escape }}
              </a>
            {%- endif -%}
          </div>

          <p class="pflege-contact-page__widerruf-hint">
            <strong>Widerruf:</strong>
            Nur über die
            <a href="{{ url_widerruf }}">Widerrufsbelehrung</a>
            (Button „Vertrag widerrufen“) — dort erhalten Sie die Eingangsbestätigung und wir die Shop-Benachrichtigung.
          </p>
        </div>

        {%- if section.settings.show_privacy_note -%}
          <p class="pflege-contact-page__privacy-note">
            {{ section.settings.privacy_note }}
            {%- if url_privacy != blank -%}
              <a href="{{ url_privacy }}">{{ section.settings.privacy_link_text | escape }}</a>
            {%- endif -%}
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PflegeShop Kontakt",
  "tag": "section",
  "class": "pflege-contact-page-section section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Kontakt ohne Shopify-Kontaktformular (keine Shop-E-Mails). Nur die Widerrufsseite nutzt das Kontaktformular für Benachrichtigungen. Seite: Handle kontakt, Vorlage kontakt."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Seitenkopf"
    },
    {
      "type": "text",
      "id": "title_fallback",
      "label": "Titel (Fallback ohne Seite)",
      "default": "Kontakt"
    },
    {
      "type": "checkbox",
      "id": "show_page_intro",
      "label": "Einleitung aus Seiteninhalt anzeigen",
      "default": false,
      "info": "Wenn aus: Einleitung aus Theme (page.kontakt.json) oder Feld unten. Wenn an: zuerst Text aus der Seitenbearbeitung."
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Einleitung (Alternative)",
      "info": "Nur wenn kein Seiteninhalt oder oben deaktiviert."
    },
    {
      "type": "checkbox",
      "id": "show_sidebar",
      "label": "Kontaktinformationen neben dem Formular anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "sidebar_title",
      "label": "Überschrift Kontaktspalte",
      "default": "So erreichen Sie uns"
    },
    {
      "type": "header",
      "content": "Kontaktblöcke"
    },
    {
      "type": "text",
      "id": "box_hours_title",
      "label": "Karte: Überschrift (z. B. Erreichbarkeit)",
      "default": "Erreichbarkeit"
    },
    {
      "type": "textarea",
      "id": "box_hours_text",
      "label": "Karte: Öffnungszeiten / Hinweis",
      "default": "Mo.–Fr. 08:30 – 16:00 Uhr (telefonisch)"
    },
    {
      "type": "text",
      "id": "box_contact_title",
      "label": "Karte: Überschrift Kontakt",
      "default": "Direkt erreichen"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Telefon (Anzeige)",
      "default": "08334 / 9893330"
    },
    {
      "type": "text",
      "id": "phone_link",
      "label": "Telefon-Link",
      "info": "Leer = automatisch tel:+49… aus der Anzeige. Oder z. B. tel:+4983349893330",
      "default": "tel:+4983349893330"
    },
    {
      "type": "text",
      "id": "email",
      "label": "E-Mail",
      "default": "deinpflegebedarf@alltagshilfe-sued.de"
    },
    {
      "type": "richtext",
      "id": "address",
      "label": "Adresse (optional)"
    },
    {
      "type": "textarea",
      "id": "box_hint",
      "label": "Hinweis unter den Kontakt-Karten",
      "default": "Wir antworten werktags so schnell wie möglich."
    },
    {
      "type": "header",
      "content": "Formular & E-Mail"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Formularüberschrift",
      "default": "Nachricht senden"
    },
    {
      "type": "text",
      "id": "form_lead",
      "label": "Kurzer Text unter der Überschrift",
      "default": "Nutzen Sie das Formular — wir melden uns bei Ihnen."
    },
    {
      "type": "text",
      "id": "email_subject",
      "label": "Betreff der Shop-E-Mail",
      "default": "Kontaktanfrage deinPflegebedarf"
    },
    {
      "type": "text",
      "id": "message_label",
      "label": "Label Nachricht",
      "default": "Ihre Nachricht"
    },
    {
      "type": "text",
      "id": "message_placeholder",
      "label": "Platzhalter Nachricht",
      "default": "Wie können wir helfen?"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Button-Text",
      "default": "Nachricht absenden"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Erfolgsmeldung",
      "default": "Vielen Dank — Ihre Nachricht ist eingegangen. Wir melden uns schnellstmöglich."
    },
    {
      "type": "text",
      "id": "error_heading",
      "label": "Fehlerüberschrift",
      "default": "Bitte prüfen Sie die markierten Felder."
    },
    {
      "type": "checkbox",
      "id": "show_privacy_note",
      "label": "Zusätzlichen Datenschutz-Hinweis unter dem Button anzeigen",
      "default": false,
      "info": "Die Pflicht-Checkbox mit AGB- und Datenschutz-Links ist immer aktiv."
    },
    {
      "type": "textarea",
      "id": "privacy_note",
      "label": "Datenschutz-Hinweistext (vor Link)",
      "default": "Mit dem Absenden stimmen Sie der Verarbeitung Ihrer Angaben zur Bearbeitung der Anfrage zu. Details in der"
    },
    {
      "type": "text",
      "id": "privacy_link_text",
      "label": "Datenschutz-Link Text",
      "default": "Datenschutzerklärung"
    },
    {
      "type": "header",
      "content": "Abstand"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "PflegeShop Kontakt",
      "settings": {
        "box_hours_title": "Erreichbarkeit",
        "box_hours_text": "Mo.–Fr. 08:30 – 16:00 Uhr (telefonisch)",
        "box_contact_title": "Direkt erreichen",
        "phone": "08334 / 9893330",
        "phone_link": "tel:+4983349893330"
      }
    }
  ]
}
{% endschema %}

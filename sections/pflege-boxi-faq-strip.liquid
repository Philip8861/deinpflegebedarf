{% comment %}
  Häufige Fragen — global über dem Footer, einheitliche FAQ-Accordion-Optik.
{% endcomment %}

{%- liquid
  assign heading_setting = section.settings.heading | strip
  if heading_setting == blank
    assign heading_text = 'sections.pflege_boxi_faq_strip.heading' | t
  else
    assign heading_text = heading_setting
  endif

  assign intro_setting = section.settings.intro | strip
  if intro_setting == blank
    assign intro_text = 'sections.pflege_boxi_faq_strip.intro_default' | t
  else
    assign intro_text = intro_setting
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .pflege-faq-strip-wrap--{{ section.id }} .pflege-faq-accordion__inner {
    padding-top: 0;
  }
{%- endstyle -%}

<div class="pflege-faq-strip-wrap pflege-faq-strip-wrap--{{ section.id }}" id="pflege-faq-root-{{ section.id }}">
  <div class="pflege-faq-strip-wrap__arc" aria-hidden="true"></div>
  <div class="section-{{ section.id }}-padding">
    {% render 'pflege-faq-accordion',
      section_id: section.id,
      locale_root: 'pflegeboxi',
      faq_from: 1,
      faq_to: 10,
      heading: heading_text,
      intro: intro_text,
      intro_html: false,
      modifier_class: 'pflege-faq-accordion--global-strip',
      deferred_from: 11,
      deferred_to: 20
    %}
  </div>
</div>

{% schema %}
{
  "name": "Pflege: Häufige Fragen",
  "tag": "section",
  "class": "pflege-boxi-faq-strip-section section",
  "settings": [
    {
      "type": "paragraph",
      "content": "20 Antworten aus „pflegeboxi“; zuerst 10 sichtbar, Rest per Button. Gleiche Optik wie FAQ auf Kategorieseiten."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Häufige Fragen"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Untertitel",
      "default": "Antworten zum Bestellvorgang, Versand, Rückgabe und Ablauf"
    },
    {
      "type": "header",
      "content": "Abstand"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 24,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 24,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Pflege: Häufige Fragen"
    }
  ]
}
{% endschema %}

{% comment %}
  Häufige Fragen — gleiche 20 FAQ-Texte wie Pflegeboxi (Locales: pflegeboxi.faq_*).
  Global über dem Footer (layout/theme.liquid).
{% endcomment %}

{{ 'section-pflege-boxi-faq-strip.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading_setting = section.settings.heading | strip
  if heading_setting == blank
    assign heading_text = 'sections.pflege_boxi_faq_strip.heading' | t
  else
    assign heading_text = heading_setting
  endif

  assign intro_setting = section.settings.intro | strip
  if intro_setting == blank
    assign intro_text = 'sections.pflege_boxi_faq_strip.intro_default' | t
  else
    assign intro_text = intro_setting
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  id="pflege-faq-root-{{ section.id }}"
  class="pflege-boxi-faq-strip section-{{ section.id }}-padding"
  aria-labelledby="pflege-faq-strip-title-{{ section.id }}"
  data-pflege-faq-strip
>
  <div class="pflege-boxi-faq-strip__inner">
    <header class="pflege-boxi-faq-strip__head">
      <h2 class="pflege-boxi-faq-strip__title" id="pflege-faq-strip-title-{{ section.id }}">
        {{ heading_text | escape }}
      </h2>
      {%- if intro_text != blank -%}
        <p class="pflege-boxi-faq-strip__intro">{{ intro_text | escape | newline_to_br }}</p>
      {%- endif -%}
    </header>

    <div class="pflege-boxi-faq-strip__list">
      {%- for i in (1..10) -%}
        {%- assign q_key = 'pflegeboxi.faq_' | append: i | append: '_q' -%}
        {%- assign a_key = 'pflegeboxi.faq_' | append: i | append: '_a' -%}
        <details class="pflege-boxi-faq-strip__item" id="pflege-faq-strip-{{ section.id }}-{{ i }}">
          <summary class="pflege-boxi-faq-strip__summary">{{ q_key | t }}</summary>
          <div class="pflege-boxi-faq-strip__answer rte">
            <p>{{ a_key | t }}</p>
          </div>
        </details>
      {%- endfor -%}

      <button
        type="button"
        class="pflege-boxi-faq-strip__load-more"
        data-faq-load-more
        aria-expanded="false"
        aria-controls="pflege-faq-extra-{{ section.id }}"
      >
        <span class="pflege-boxi-faq-strip__load-more-icon" aria-hidden="true"></span>
        <span class="pflege-boxi-faq-strip__load-more-label">{{ 'sections.pflege_boxi_faq_strip.load_more' | t }}</span>
      </button>

      <div
        class="pflege-boxi-faq-strip__deferred"
        id="pflege-faq-extra-{{ section.id }}"
        data-faq-extra
        hidden
      >
        {%- for i in (11..20) -%}
          {%- assign q_key = 'pflegeboxi.faq_' | append: i | append: '_q' -%}
          {%- assign a_key = 'pflegeboxi.faq_' | append: i | append: '_a' -%}
          <details class="pflege-boxi-faq-strip__item" id="pflege-faq-strip-{{ section.id }}-{{ i }}">
            <summary class="pflege-boxi-faq-strip__summary">{{ q_key | t }}</summary>
            <div class="pflege-boxi-faq-strip__answer rte">
              <p>{{ a_key | t }}</p>
            </div>
          </details>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('pflege-faq-root-{{ section.id }}');
    if (!root) return;
    var btn = root.querySelector('[data-faq-load-more]');
    var extra = root.querySelector('[data-faq-extra]');
    if (!btn || !extra) return;
    btn.addEventListener('click', function () {
      extra.removeAttribute('hidden');
      btn.setAttribute('aria-expanded', 'true');
      btn.remove();
    });
  })();
</script>

{% schema %}
{
  "name": "Pflege: Häufige Fragen",
  "tag": "section",
  "class": "pflege-boxi-faq-strip-section section",
  "settings": [
    {
      "type": "paragraph",
      "content": "20 Antworten aus „pflegeboxi“; zuerst 10 sichtbar, Rest per Button. Eine Spalte, volle Breite wie der Hero."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Häufige Fragen"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Untertitel",
      "default": "Antworten zum Bestellvorgang, Versand, Rückgabe und Ablauf"
    },
    {
      "type": "header",
      "content": "Abstand"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 24,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 24,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Pflege: Häufige Fragen"
    }
  ]
}
{% endschema %}

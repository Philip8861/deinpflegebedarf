{% comment %}
  PflegeShop Produktfinder — Wizard + Ergebnisanzeige.

  Datenfluss:
  1. Liest alle Produkte aus collections['produktfinder'].
  2. Serialisiert je Produkt die finder-Metafelder als JSON in <script type="application/json" data-pflege-finder-products>.
  3. Das JS (assets/pflege-finder-quiz.js) übernimmt Wizard, Scoring, Gruppierung und Render.

  Texte (Fragen, Gruppentitel, Wunden-Hinweis) sind aktuell hartkodiert (Deutsch).
  Lokalisierung kann später nachgezogen werden.
{% endcomment %}

{{ 'section-pflege-finder-quiz.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pflege-finder-quiz.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign finder_collection = collections['produktfinder']
  assign has_collection = false
  assign product_count = 0
  if finder_collection != blank
    assign product_count = finder_collection.products_count | plus: 0
    if product_count > 0
      assign has_collection = true
    endif
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="pflege-finder-quiz section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient"
  data-pflege-finder
  data-has-collection="{{ has_collection }}"
  aria-labelledby="pflege-finder-title-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="pflege-finder-quiz__shell">
    <header class="pflege-finder-quiz__head">
      <h1 class="pflege-finder-quiz__title" id="pflege-finder-title-{{ section.id }}">
        {{ section.settings.heading | default: 'Produktfinder' | escape }}
      </h1>
      {%- if section.settings.intro != blank -%}
        <p class="pflege-finder-quiz__intro">{{ section.settings.intro | escape }}</p>
      {%- endif -%}
    </header>

    <div class="pflege-finder-quiz__progress" data-pflege-finder-progress aria-hidden="true">
      <div class="pflege-finder-quiz__progress-bar" data-pflege-finder-progress-bar></div>
    </div>

    <div class="pflege-finder-quiz__viewport" data-pflege-finder-viewport>
      <noscript>
        <p class="pflege-finder-quiz__nojs">
          Der Produktfinder benötigt JavaScript. Bitte JavaScript aktivieren oder die Produkte direkt in der
          <a href="{{ routes.all_products_collection_url }}">Übersicht</a>
          ansehen.
        </p>
      </noscript>
    </div>
  </div>

  <script type="application/json" data-pflege-finder-config>
    {
      "minScore": 15,
      "groupCaps": {
        "haupt": 3,
        "ergaenzung": 4,
        "situation": 3,
        "hygiene": 3,
        "service": 2
      },
      "hasCollection": {{ has_collection | json }},
      "productCount": {{ product_count | json }},
      "currencyCodeEnabled": {{ settings.currency_code_enabled | default: false | json }}
    }
  </script>

  <script type="application/json" data-pflege-finder-products>
    [
      {%- for product in finder_collection.products -%}
        {%- assign mf = product.metafields.finder -%}
        {%- assign price_money = product.price_min | money -%}
        {%- if settings.currency_code_enabled -%}
          {%- assign price_money = product.price_min | money_with_currency -%}
        {%- endif -%}
        {%- if product.featured_media -%}
          {%- assign img_url = product.featured_media | image_url: width: 480 -%}
          {%- assign img_alt = product.featured_media.alt | default: product.title -%}
        {%- else -%}
          {%- assign img_url = '' -%}
          {%- assign img_alt = '' -%}
        {%- endif -%}
        {
          "id": {{ product.id | json }},
          "title": {{ product.title | json }},
          "url": {{ product.url | json }},
          "available": {{ product.available | json }},
          "price_cents": {{ product.price_min | json }},
          "price_html": {{ price_money | json }},
          "image_url": {{ img_url | json }},
          "image_alt": {{ img_alt | json }},
          "vendor": {{ product.vendor | json }},
          "finder": {
            "active":            {{ mf.active.value | json }},
            "kategorie":         {{ mf.kategorie.value | json }},
            "produktrolle":      {{ mf.produktrolle.value | json }},
            "empfehlungsebene":  {{ mf.empfehlungsebene.value | json }},
            "bedarf":            {{ mf.bedarf.value | json }},
            "pflegesituation":   {{ mf.pflegesituation.value | json }},
            "mobilitaet":        {{ mf.mobilitaet.value | json }},
            "geschlecht":        {{ mf.geschlecht.value | json }},
            "inkontinenz_art":   {{ mf.inkontinenz_art.value | json }},
            "menge_urinverlust": {{ mf.menge_urinverlust.value | json }},
            "anwendung":         {{ mf.anwendung.value | json }},
            "hautzustand":       {{ mf.hautzustand.value | json }},
            "pflegeort":         {{ mf.pflegeort.value | json }},
            "abrechnung":        {{ mf.abrechnung.value | json }},
            "prioritaet":        {{ mf.prioritaet.value | json }},
            "empfehlungstext":   {{ mf.empfehlungstext.value | json }}
          }
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  </script>
</section>

{% schema %}
{
  "name": "PflegeShop Finder-Quiz",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Hauptüberschrift",
      "default": "Produktfinder"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Einleitungstext",
      "default": "Beantworten Sie ein paar kurze Fragen — wir empfehlen Ihnen passende Pflegeprodukte für Ihre Situation."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 88
    }
  ],
  "presets": [
    {
      "name": "PflegeShop Finder-Quiz"
    }
  ]
}
{% endschema %}

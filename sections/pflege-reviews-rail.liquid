{% comment %}
  Globale Kundenstimmen: horizontal wischbar / scroll-snap; darunter Bewertung per Kontaktformular (Shopify contact → E-Mail an den Shop).

  Über layout/theme.liquid als {% section 'pflege-reviews-rail' %} oberhalb des Footers eingebunden.
{% endcomment %}

{{ 'section-pflege-reviews-rail.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pflege-reviews-rail.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign rating_summary_setting = section.settings.rating_summary | strip
  if rating_summary_setting == blank
    assign rating_summary_setting = 'sections.pflege_reviews_rail.rating_summary' | t
  endif

  assign intro_body_setting = section.settings.intro_body | strip
  if intro_body_setting == blank
    assign intro_body_setting = section.settings.subheading | strip
  endif
  if intro_body_setting == blank
    assign intro_body_setting = 'sections.pflege_reviews_rail.intro_text' | t
  endif

  assign has_reviews = false
  assign card_count = 0
  if section.blocks.size > 0
    assign has_reviews = true
  endif

  assign show_demo_rail = false
  if has_reviews == false and section.settings.show_fallback_demo
    assign show_demo_rail = true
    assign card_count = 3
  endif

  if has_reviews
    for block in section.blocks
      if block.type == 'review'
        assign card_count = card_count | plus: 1
      endif
    endfor
  endif

  assign track_mode = 'grid'
  if card_count > 3
    assign track_mode = 'scroll'
  endif

  assign reviews_form_panel_id = 'pflege-reviews-form-panel-' | append: section.id
  assign reviews_toggle_id = 'pflege-reviews-form-toggle-' | append: section.id
-%}

<section
  class="pflege-reviews-rail color-{{ section.settings.color_scheme }}"
  aria-labelledby="pflege-reviews-title-{{ section.id }}"
  data-pflege-reviews-rail
>
  <div class="pflege-reviews-rail__inner">
    <header class="pflege-reviews-rail__head">
      <h2 class="pflege-reviews-rail__title" id="pflege-reviews-title-{{ section.id }}">
        {{ section.settings.heading | escape }}
      </h2>

      <div class="pflege-reviews-rail__intro-stars" role="img" aria-label="{{ 'sections.pflege_reviews_rail.intro_stars_aria' | t }}">
        {%- for s in (1..5) -%}
          <span class="pflege-reviews-rail__intro-star" aria-hidden="true">★</span>
        {%- endfor -%}
      </div>

      <p class="pflege-reviews-rail__rating-summary">{{ rating_summary_setting | escape }}</p>

      {%- if intro_body_setting != blank -%}
        <p class="pflege-reviews-rail__intro-text">{{ intro_body_setting | escape | newline_to_br }}</p>
      {%- endif -%}
    </header>

    <div class="pflege-reviews-rail__carousel-wrap">
      {%- if has_reviews or show_demo_rail -%}
        <div
          class="pflege-reviews-rail__carousel"
          {% if card_count > 3 %}
            data-reviews-carousel-many
          {% endif %}
        >
          <div class="pflege-reviews-rail__carousel-stage">
            <div
              class="pflege-reviews-rail__track pflege-reviews-rail__track--{{ track_mode }}"
              data-reviews-track
              role="region"
              {% if track_mode == 'scroll' %}
                aria-roledescription="carousel"
              {% endif %}
              aria-label="{{ 'sections.pflege_reviews_rail.carousel_label' | t }}"
            >
              {%- if has_reviews -%}
                {%- for block in section.blocks -%}
                  {%- case block.type -%}
                    {%- when 'review' -%}
                      <article
                        class="pflege-reviews-rail__card"
                        {{ block.shopify_attributes }}
                      >
                        {%- assign review_rating = block.settings.rating | default: 5 | times: 1 -%}
                        {%- if review_rating < 1 -%}
                          {%- assign review_rating = 1 -%}
                        {%- endif -%}
                        {%- if review_rating > 5 -%}
                          {%- assign review_rating = 5 -%}
                        {%- endif -%}
                        <div class="pflege-reviews-rail__stars" aria-label="{{ 'sections.pflege_reviews_rail.stars_aria' | t: count: review_rating }}">
                          {%- for i in (1..5) -%}
                            <span{% if i > review_rating %} class="pflege-reviews-rail__star--dim"{% endif %} aria-hidden="true">★</span>
                          {%- endfor -%}
                        </div>
                        <p class="pflege-reviews-rail__quote">{{ block.settings.quote | escape }}</p>
                        <div class="pflege-reviews-rail__meta">
                          <span class="pflege-reviews-rail__author">{{ block.settings.author | escape }}</span>
                          {%- if block.settings.subtitle != blank -%}
                            <span class="pflege-reviews-rail__subtitle"> — {{ block.settings.subtitle | escape }}</span>
                          {%- endif -%}
                        </div>
                      </article>
                  {%- endcase -%}
                {%- endfor -%}
              {%- else -%}
                {% render 'pflege-reviews-democards' %}
              {%- endif -%}
            </div>

            <div
              class="pflege-reviews-rail__nav"
              data-reviews-nav
              {% if card_count <= 3 %}
                hidden
              {% endif %}
              aria-label="{{ 'sections.pflege_reviews_rail.nav_label' | t }}"
            >
              <button
                type="button"
                class="pflege-reviews-rail__nav-btn"
                data-reviews-prev
                aria-label="{{ 'sections.pflege_reviews_rail.prev' | t }}"
              >
                <span aria-hidden="true">‹</span>
              </button>
              <button
                type="button"
                class="pflege-reviews-rail__nav-btn"
                data-reviews-next
                aria-label="{{ 'sections.pflege_reviews_rail.next' | t }}"
              >
                <span aria-hidden="true">›</span>
              </button>
            </div>
          </div>
        </div>
      {%- else -%}
        <p class="pflege-reviews-rail__empty">{{ section.settings.empty_state | escape }}</p>
      {%- endif -%}
    </div>

    {%- liquid
      assign prr_form_posted_ok = false
      assign reviews_success_href = section.settings.success_continue_url | strip
      if reviews_success_href == blank
        assign reviews_success_href = routes.all_products_collection_url
      endif
    -%}

    {%- if section.settings.show_form -%}
      {%- liquid
        assign reviews_form_id = 'PflegeReviewsForm-' | append: section.id
        assign reviews_form_class = 'pflege-reviews-rail__form'
      -%}
      <div class="pflege-reviews-rail__form-zone">
        <button
          type="button"
          id="{{ reviews_toggle_id }}"
          class="pflege-reviews-rail__toggle-form"
          data-reviews-toggle-form
          aria-expanded="false"
          aria-controls="{{ reviews_form_panel_id }}"
        >
          <span data-reviews-toggle-label-open>{{ 'sections.pflege_reviews_rail.toggle_form_open' | t }}</span>
          <span data-reviews-toggle-label-close hidden>{{ 'sections.pflege_reviews_rail.toggle_form_close' | t }}</span>
        </button>

        <div
          id="{{ reviews_form_panel_id }}"
          class="pflege-reviews-rail__form-collapsible"
          data-reviews-form-panel
          aria-hidden="true"
        >
          <div class="pflege-reviews-rail__form-card">
            <div class="pflege-reviews-rail__form-card-head">
              <h3 class="pflege-reviews-rail__form-title" id="pflege-reviews-form-heading-{{ section.id }}">
                {{ section.settings.form_heading | escape }}
              </h3>
              <button
                type="button"
                class="pflege-reviews-rail__form-close"
                aria-label="{{ 'sections.pflege_reviews_rail.close_form_short' | t }}"
              >
                {{ 'sections.pflege_reviews_rail.close_form_link' | t }}
              </button>
            </div>
            <p class="pflege-reviews-rail__form-hint">{{ section.settings.form_hint | escape | newline_to_br }}</p>

        {%- form 'contact', id: reviews_form_id, class: reviews_form_class -%}
          {%- if form.posted_successfully? -%}
            {%- assign prr_form_posted_ok = true -%}
          {%- endif -%}

          {%- if form.errors -%}
            <div class="pflege-reviews-rail__errors">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <input
            type="text"
            name="bewertungen-honey"
            value=""
            class="pflege-reviews-rail__hp"
            tabindex="-1"
            autocomplete="off"
            data-reviews-hp
            aria-hidden="true"
          >
          <input type="hidden" name="contact[body]" value="" data-reviews-body-out>

          <div class="pflege-reviews-rail__form-grid pflege-reviews-rail__form-grid--two">
            <div class="pflege-reviews-rail__field">
              <label for="PflegeReviews-name-{{ section.id }}">
                {{ 'templates.contact.form.name' | t }}
              </label>
              <input
                id="PflegeReviews-name-{{ section.id }}"
                class="pflege-reviews-rail__input"
                type="text"
                name="contact[name]"
                autocomplete="name"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              >
            </div>
            <div class="pflege-reviews-rail__field">
              <label for="PflegeReviews-email-{{ section.id }}">
                {{ 'templates.contact.form.email' | t }}
                <span class="pflege-reviews-rail__req" aria-hidden="true">*</span>
              </label>
              <input
                id="PflegeReviews-email-{{ section.id }}"
                class="pflege-reviews-rail__input"
                type="email"
                name="contact[email]"
                autocomplete="email"
                required
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              >
            </div>
          </div>

          <div class="pflege-reviews-rail__form-grid">
            <div class="pflege-reviews-rail__field">
              <label for="PflegeReviews-rating-{{ section.id }}">{{ 'sections.pflege_reviews_rail.label_rating' | t }}</label>
              <select
                id="PflegeReviews-rating-{{ section.id }}"
                class="pflege-reviews-rail__select"
                data-reviews-rating
                required
              >
                <option value="5">5 ★★★★★</option>
                <option value="4">4 ★★★★</option>
                <option value="3">3 ★★★</option>
                <option value="2">2 ★★</option>
                <option value="1">1 ★</option>
              </select>
            </div>
            <div class="pflege-reviews-rail__field">
              <label for="PflegeReviews-comment-{{ section.id }}">
                {{ 'sections.pflege_reviews_rail.label_comment' | t }}
                <span class="pflege-reviews-rail__req" aria-hidden="true">*</span>
              </label>
              <textarea
                id="PflegeReviews-comment-{{ section.id }}"
                class="pflege-reviews-rail__textarea"
                rows="5"
                data-reviews-comment
                placeholder="{{ 'sections.pflege_reviews_rail.comment_placeholder' | t }}"
                required
              ></textarea>
            </div>
          </div>

          <button type="submit" class="pflege-reviews-rail__submit" name="commit">
            {{ 'sections.pflege_reviews_rail.submit' | t }}
          </button>

          {%- if section.settings.privacy_note != blank -%}
            <div class="rte pflege-reviews-rail__privacy">
              {{ section.settings.privacy_note }}
            </div>
          {%- endif -%}
        {%- endform -%}
          </div>
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.show_form and prr_form_posted_ok -%}
      <dialog
        class="pflege-reviews-rail__success-dialog"
        data-reviews-success-dialog
        aria-labelledby="pflege-reviews-success-title-{{ section.id }}"
        aria-describedby="pflege-reviews-success-desc-{{ section.id }}"
      >
        <div class="pflege-reviews-rail__success-dialog-panel">
          <h3 class="pflege-reviews-rail__success-dialog-title" id="pflege-reviews-success-title-{{ section.id }}">
            {{ 'sections.pflege_reviews_rail.success_modal_title' | t }}
          </h3>
          <p class="pflege-reviews-rail__success-dialog-text" id="pflege-reviews-success-desc-{{ section.id }}">
            {{ 'sections.pflege_reviews_rail.form_success' | t }}
          </p>
          <div class="pflege-reviews-rail__success-dialog-actions">
            <a
              href="{{ reviews_success_href | escape }}"
              class="pflege-reviews-rail__success-dialog-cta"
            >
              {{ 'sections.pflege_reviews_rail.continue_shopping' | t }}
            </a>
            <button
              type="button"
              class="pflege-reviews-rail__success-dialog-dismiss"
              data-reviews-success-close
            >
              {{ 'sections.pflege_reviews_rail.success_modal_dismiss' | t }}
            </button>
          </div>
        </div>
      </dialog>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Pflege: Bewertungen",
  "tag": "section",
  "class": "pflege-reviews-rail-section",
  "blocks": [
    {
      "type": "review",
      "name": "Kundenstimme",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Sterne",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Zitat / Text",
          "default": "Sehr guter Service und schnelle Lieferung!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Name",
          "default": "Kundin/Kunde"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Zusatz (z. B. Ort)"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "paragraph",
      "content": "Karten („Kundenstimmen“-Blöcke) im Theme-Editor pflegen. Eingehende Bewertungen per Formular gehen als Kontakt-Mail an den Shop (ohne separate Bewertungs-App). Veröffentlichen Sie freigegebene Stimmen später als neue Blöcke hier."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Das sagen unsere Kundinnen und Kunden"
    },
    {
      "type": "text",
      "id": "rating_summary",
      "label": "Zeile unter den Sternen (Bewertungszusammenfassung)",
      "default": "5,0 / 5 aus Kundenbewertungen"
    },
    {
      "type": "textarea",
      "id": "intro_body",
      "label": "Kurzer Erklärungstext unter der Bewertungszeile",
      "default": "Lesen Sie Erfahrungen anderer Käuferinnen und Käufer – oder teilen Sie Ihre eigene Bewertung."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Einleitung (Fallback, falls obiger Text leer)",
      "default": "Lesen Sie Erfahrungen anderer Käuferinnen und Käufer – oder teilen Sie Ihre eigene Bewertung."
    },
    {
      "type": "checkbox",
      "id": "show_fallback_demo",
      "label": "Demo-Karten anzeigen, wenn noch keine Blöcke",
      "default": true
    },
    {
      "type": "textarea",
      "id": "empty_state",
      "label": "Text ohne Kartenblöcke",
      "default": "Hier gibt es bald die ersten Bewertungen. Nutzen Sie gern „Eigene Bewertung schreiben“."
    },
    {
      "type": "header",
      "content": "Formular"
    },
    {
      "type": "checkbox",
      "id": "show_form",
      "label": "Formular anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Überschrift Formular",
      "default": "Ihre Bewertung"
    },
    {
      "type": "textarea",
      "id": "form_hint",
      "label": "Hinweis unter Überschrift (Formular)",
      "default": "Teilen Sie Ihre Erfahrung mit uns. Ihre Bewertung wird nach Prüfung veröffentlicht."
    },
    {
      "type": "richtext",
      "id": "privacy_note",
      "label": "Datenschutz-Hinweis (optional)",
      "default": "<p>Mit dem Absenden speichern wir Ihre Angaben zur Bearbeitung Ihrer Bewertung. Weitere Informationen finden Sie in unserer Datenschutzerklärung.</p>"
    },
    {
      "type": "text",
      "id": "success_continue_url",
      "label": "Nach erfolgreicher Bewertung — Link für „Jetzt weiter shoppen“",
      "info": "Leer lassen für die Standard-Kollektion „Alle Produkte“. Sonst Pfad eingeben, z. B. „/collections/inkontinenz“ oder vollständige URL.",
      "placeholder": "/collections/all"
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "Bewertungsleiste",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "Unkomplizierte Bestellung und freundlicher Support am Telefon.",
            "author": "Marion S.",
            "subtitle": "Bayern"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "Produkte wie beschrieben, Lieferzeit hat gepasst.",
            "author": "Familie Becker"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 4,
            "quote": "Gute Auswahl rund um Pflege – gerne wieder.",
            "author": "Thomas R."
          }
        }
      ]
    }
  ]
}
{% endschema %}

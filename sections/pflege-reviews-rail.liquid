{% comment %}
  Globale Kundenstimmen — clean, mittig, eine Rezension sichtbar mit Häkchen-Indikatoren.
  Eingebunden in layout/theme.liquid als {% section 'pflege-reviews-rail' %}.
{% endcomment %}

{{ 'section-pflege-reviews-rail.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pflege-reviews-rail.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign prr_noise = 'Lesen Sie Erfahrungen anderer Käuferinnen und Käufer – oder teilen Sie Ihre eigene Bewertung.'
  assign prr_noise_dash = 'Lesen Sie Erfahrungen anderer Käuferinnen und Käufer - oder teilen Sie Ihre eigene Bewertung.'

  assign prr_heading_display = section.settings.heading | strip | remove: prr_noise | remove: prr_noise_dash | strip
  if prr_heading_display == blank
    assign prr_heading_display = 'Das sagen unsere Kundinnen und Kunden'
  endif

  assign has_reviews = false
  assign card_count = 0
  if section.blocks.size > 0
    assign has_reviews = true
  endif

  assign show_demo_rail = false
  if has_reviews == false and section.settings.show_fallback_demo
    assign show_demo_rail = true
    assign card_count = 3
  endif

  if has_reviews
    for block in section.blocks
      if block.type == 'review'
        assign card_count = card_count | plus: 1
      endif
    endfor
  endif

  assign reviews_form_panel_id = 'pflege-reviews-form-panel-' | append: section.id
  assign reviews_toggle_id = 'pflege-reviews-form-toggle-' | append: section.id
  assign reviews_all_panel_id = 'pflege-reviews-all-panel-' | append: section.id
-%}

<section
  class="pflege-reviews-rail color-{{ section.settings.color_scheme }}"
  aria-labelledby="pflege-reviews-title-{{ section.id }}"
  data-pflege-reviews-rail
>
  <div class="pflege-reviews-rail__arc-edge pflege-reviews-rail__arc-edge--top" aria-hidden="true"></div>
  <div class="pflege-reviews-rail__surf">
    <div class="pflege-reviews-rail__inner">
      <header class="pflege-reviews-rail__head">
        <h2 class="pflege-reviews-rail__title" id="pflege-reviews-title-{{ section.id }}">
          {{ prr_heading_display | escape }}
        </h2>

        <div class="pflege-reviews-rail__intro-stars" role="img" aria-label="{{ 'sections.pflege_reviews_rail.intro_stars_aria' | t }}">
          {%- for s in (1..5) -%}
            <span class="pflege-reviews-rail__intro-star" aria-hidden="true">★</span>
          {%- endfor -%}
        </div>

        {%- if section.settings.show_rating_summary_line -%}
          {%- assign rating_summary_setting = section.settings.rating_summary | strip | remove: prr_noise | remove: prr_noise_dash | strip -%}
          {%- if rating_summary_setting == blank -%}
            {%- assign rating_summary_setting = 'sections.pflege_reviews_rail.rating_summary' | t -%}
          {%- endif -%}
          {%- if rating_summary_setting != blank -%}
            <p class="pflege-reviews-rail__rating-summary">{{ rating_summary_setting | escape }}</p>
          {%- endif -%}
        {%- endif -%}
      </header>

      <div class="pflege-reviews-rail__carousel-wrap">
        {%- if has_reviews or show_demo_rail -%}
          <div class="pflege-reviews-rail__carousel" data-reviews-carousel>
            <div class="pflege-reviews-rail__carousel-stage">
              <div
                id="pflege-reviews-track-{{ section.id }}"
                class="pflege-reviews-rail__track pflege-reviews-rail__track--single"
                data-reviews-track
                role="region"
                aria-roledescription="carousel"
                aria-label="{{ 'sections.pflege_reviews_rail.carousel_label' | t }}"
                aria-live="off"
              >
                {%- if has_reviews -%}
                  {%- assign card_index = 0 -%}
                  {%- for block in section.blocks -%}
                    {%- case block.type -%}
                      {%- when 'review' -%}
                        {%- assign is_active = false -%}
                        {%- if card_index == 0 -%}
                          {%- assign is_active = true -%}
                        {%- endif -%}
                        <article
                          class="pflege-reviews-rail__card{% if is_active %} is-active{% else %} prr-slide--off{% endif %}"
                          data-reviews-card
                          data-reviews-index="{{ card_index }}"
                          {% unless is_active %}hidden{% endunless %}
                          {% unless is_active %}style="display: none !important;"{% endunless %}
                          {% unless is_active %}aria-hidden="true"{% endunless %}
                          {{ block.shopify_attributes }}
                        >
                          <p class="pflege-reviews-rail__quote">„{{ block.settings.quote | escape }}“</p>
                          <div class="pflege-reviews-rail__meta">
                            <span class="pflege-reviews-rail__author">{{ block.settings.author | escape }}</span>
                            {%- if block.settings.subtitle != blank -%}
                              <span class="pflege-reviews-rail__subtitle">{{ block.settings.subtitle | escape }}</span>
                            {%- endif -%}
                          </div>
                        </article>
                        {%- assign card_index = card_index | plus: 1 -%}
                    {%- endcase -%}
                  {%- endfor -%}
                {%- else -%}
                  {% render 'pflege-reviews-democards' %}
                {%- endif -%}
              </div>
            </div>

            {%- if card_count > 1 -%}
              <nav
                class="pflege-reviews-rail__nav"
                aria-label="{{ 'sections.pflege_reviews_rail.nav_label' | t }}"
                data-reviews-nav
              >
                <button
                  type="button"
                  class="pflege-reviews-rail__nav-btn pflege-reviews-rail__nav-btn--prev"
                  data-reviews-prev
                  aria-controls="pflege-reviews-track-{{ section.id }}"
                >
                  <span class="visually-hidden">{{ 'sections.pflege_reviews_rail.prev' | t }}</span>
                  <svg class="pflege-reviews-rail__nav-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>

                <div
                  class="pflege-reviews-rail__dots"
                  role="tablist"
                  aria-label="{{ 'sections.pflege_reviews_rail.dots_label' | t }}"
                  data-reviews-dots
                >
                  {%- for i in (1..card_count) -%}
                    {%- assign dot_index = forloop.index0 -%}
                    {%- assign dot_active = false -%}
                    {%- if dot_index == 0 -%}
                      {%- assign dot_active = true -%}
                    {%- endif -%}
                    <button
                      type="button"
                      class="pflege-reviews-rail__dot{% if dot_active %} is-active{% endif %}"
                      role="tab"
                      aria-selected="{% if dot_active %}true{% else %}false{% endif %}"
                      aria-label="{{ 'sections.pflege_reviews_rail.dot_label' | t: index: forloop.index }}"
                      data-reviews-dot="{{ dot_index }}"
                      {% unless dot_active %}tabindex="-1"{% endunless %}
                    >
                      <svg class="pflege-reviews-rail__dot-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M5 12.5l4.2 4.2L19 7" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span class="visually-hidden">{{ 'sections.pflege_reviews_rail.dot_label' | t: index: forloop.index }}</span>
                    </button>
                  {%- endfor -%}
                </div>

                <button
                  type="button"
                  class="pflege-reviews-rail__nav-btn pflege-reviews-rail__nav-btn--next"
                  data-reviews-next
                  aria-controls="pflege-reviews-track-{{ section.id }}"
                >
                  <span class="visually-hidden">{{ 'sections.pflege_reviews_rail.next' | t }}</span>
                  <svg class="pflege-reviews-rail__nav-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M9 18l6-6-6-6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </nav>
            {%- endif -%}

            {%- if card_count > 1 -%}
              <button
                type="button"
                class="pflege-reviews-rail__see-all"
                data-reviews-see-all
                aria-controls="{{ reviews_all_panel_id }}"
                aria-expanded="false"
              >
                <span data-reviews-see-all-open>{{ 'sections.pflege_reviews_rail.see_all' | t: count: card_count }}</span>
                <span data-reviews-see-all-close hidden>{{ 'sections.pflege_reviews_rail.see_all_collapse' | t }}</span>
              </button>

              {%- if has_reviews -%}
                <div
                  id="{{ reviews_all_panel_id }}"
                  class="pflege-reviews-rail__all-list"
                  data-reviews-all-list
                  hidden
                >
                  {%- for block in section.blocks -%}
                    {%- case block.type -%}
                      {%- when 'review' -%}
                        {%- assign rr_rating = block.settings.rating | default: 5 | times: 1 -%}
                        {%- if rr_rating < 1 -%}{%- assign rr_rating = 1 -%}{%- endif -%}
                        {%- if rr_rating > 5 -%}{%- assign rr_rating = 5 -%}{%- endif -%}
                        <article class="pflege-reviews-rail__all-item">
                          <div class="pflege-reviews-rail__all-stars" aria-label="{{ 'sections.pflege_reviews_rail.stars_aria' | t: count: rr_rating }}">
                            {%- for i in (1..5) -%}
                              <span{% if i > rr_rating %} class="pflege-reviews-rail__star--dim"{% endif %} aria-hidden="true">★</span>
                            {%- endfor -%}
                          </div>
                          <p class="pflege-reviews-rail__all-quote">„{{ block.settings.quote | escape }}“</p>
                          <div class="pflege-reviews-rail__all-meta">
                            <span class="pflege-reviews-rail__all-author">{{ block.settings.author | escape }}</span>
                            {%- if block.settings.subtitle != blank -%}
                              <span class="pflege-reviews-rail__all-subtitle">{{ block.settings.subtitle | escape }}</span>
                            {%- endif -%}
                          </div>
                        </article>
                    {%- endcase -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}
            {%- endif -%}
          </div>
        {%- else -%}
          <p class="pflege-reviews-rail__empty">{{ section.settings.empty_state | escape }}</p>
        {%- endif -%}
      </div>

      {%- liquid
        assign prr_form_posted_ok = false
        assign reviews_success_href = section.settings.success_continue_url | strip
        if reviews_success_href == blank
          assign reviews_success_href = routes.all_products_collection_url
        endif
      -%}

      {%- if section.settings.show_form -%}
        {%- liquid
          assign reviews_form_id = 'PflegeReviewsForm-' | append: section.id
          assign reviews_form_class = 'pflege-reviews-rail__form'
        -%}
        <div class="pflege-reviews-rail__form-zone">
          <button
            type="button"
            id="{{ reviews_toggle_id }}"
            class="pflege-reviews-rail__toggle-form"
            data-reviews-toggle-form
            aria-expanded="false"
            aria-controls="{{ reviews_form_panel_id }}"
          >
            <span data-reviews-toggle-label-open>{{ 'sections.pflege_reviews_rail.toggle_form_open' | t }}</span>
            <span data-reviews-toggle-label-close hidden>{{ 'sections.pflege_reviews_rail.toggle_form_close' | t }}</span>
          </button>

          <div class="pflege-reviews-rail__arc-edge pflege-reviews-rail__arc-edge--below-form-cta" aria-hidden="true"></div>

          <div
            id="{{ reviews_form_panel_id }}"
            class="pflege-reviews-rail__form-collapsible"
            data-reviews-form-panel
            aria-hidden="true"
          >
            <div class="pflege-reviews-rail__form-card">
              <div class="pflege-reviews-rail__form-card-head">
                <h3 class="pflege-reviews-rail__form-title" id="pflege-reviews-form-heading-{{ section.id }}">
                  {{ section.settings.form_heading | escape }}
                </h3>
                <button
                  type="button"
                  class="pflege-reviews-rail__form-close"
                  aria-label="{{ 'sections.pflege_reviews_rail.close_form_short' | t }}"
                >
                  {{ 'sections.pflege_reviews_rail.close_form_link' | t }}
                </button>
              </div>
              <p class="pflege-reviews-rail__form-hint">{{ section.settings.form_hint | escape | newline_to_br }}</p>

          {%- form 'contact', id: reviews_form_id, class: reviews_form_class -%}
            {%- if form.posted_successfully? -%}
              {%- assign prr_form_posted_ok = true -%}
            {%- endif -%}

            {%- if form.errors -%}
              <div class="pflege-reviews-rail__errors">
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <input
              type="text"
              name="bewertungen-honey"
              value=""
              class="pflege-reviews-rail__hp"
              tabindex="-1"
              autocomplete="off"
              data-reviews-hp
              aria-hidden="true"
            >
            <input type="hidden" name="contact[body]" value="" data-reviews-body-out>

            <div class="pflege-reviews-rail__form-grid pflege-reviews-rail__form-grid--two">
              <div class="pflege-reviews-rail__field">
                <label for="PflegeReviews-name-{{ section.id }}">
                  {{ 'templates.contact.form.name' | t }}
                </label>
                <input
                  id="PflegeReviews-name-{{ section.id }}"
                  class="pflege-reviews-rail__input"
                  type="text"
                  name="contact[name]"
                  autocomplete="name"
                  value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                >
              </div>
              <div class="pflege-reviews-rail__field">
                <label for="PflegeReviews-email-{{ section.id }}">
                  {{ 'templates.contact.form.email' | t }}
                  <span class="pflege-reviews-rail__req" aria-hidden="true">*</span>
                </label>
                <input
                  id="PflegeReviews-email-{{ section.id }}"
                  class="pflege-reviews-rail__input"
                  type="email"
                  name="contact[email]"
                  autocomplete="email"
                  required
                  value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                >
              </div>
            </div>

            <div class="pflege-reviews-rail__form-grid">
              <div class="pflege-reviews-rail__field">
                <label for="PflegeReviews-rating-{{ section.id }}">{{ 'sections.pflege_reviews_rail.label_rating' | t }}</label>
                <select
                  id="PflegeReviews-rating-{{ section.id }}"
                  class="pflege-reviews-rail__select"
                  data-reviews-rating
                  required
                >
                  <option value="5">5 ★★★★★</option>
                  <option value="4">4 ★★★★</option>
                  <option value="3">3 ★★★</option>
                  <option value="2">2 ★★</option>
                  <option value="1">1 ★</option>
                </select>
              </div>
              <div class="pflege-reviews-rail__field">
                <label for="PflegeReviews-comment-{{ section.id }}">
                  {{ 'sections.pflege_reviews_rail.label_comment' | t }}
                  <span class="pflege-reviews-rail__req" aria-hidden="true">*</span>
                </label>
                <textarea
                  id="PflegeReviews-comment-{{ section.id }}"
                  class="pflege-reviews-rail__textarea"
                  rows="5"
                  data-reviews-comment
                  placeholder="{{ 'sections.pflege_reviews_rail.comment_placeholder' | t }}"
                  required
                ></textarea>
              </div>
            </div>

            <button type="submit" class="pflege-reviews-rail__submit" name="commit">
              {{ 'sections.pflege_reviews_rail.submit' | t }}
            </button>

            {%- if section.settings.privacy_note != blank -%}
              <div class="rte pflege-reviews-rail__privacy">
                {{ section.settings.privacy_note }}
              </div>
            {%- endif -%}
          {%- endform -%}
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.show_form and prr_form_posted_ok -%}
        <dialog
          class="pflege-reviews-rail__success-dialog"
          data-reviews-success-dialog
          aria-labelledby="pflege-reviews-success-title-{{ section.id }}"
          aria-describedby="pflege-reviews-success-desc-{{ section.id }}"
        >
          <div class="pflege-reviews-rail__success-dialog-panel">
            <h3 class="pflege-reviews-rail__success-dialog-title" id="pflege-reviews-success-title-{{ section.id }}">
              {{ 'sections.pflege_reviews_rail.success_modal_title' | t }}
            </h3>
            <p class="pflege-reviews-rail__success-dialog-text" id="pflege-reviews-success-desc-{{ section.id }}">
              {{ 'sections.pflege_reviews_rail.form_success' | t }}
            </p>
            <div class="pflege-reviews-rail__success-dialog-actions">
              <a
                href="{{ reviews_success_href | escape }}"
                class="pflege-reviews-rail__success-dialog-cta"
              >
                {{ 'sections.pflege_reviews_rail.continue_shopping' | t }}
              </a>
              <button
                type="button"
                class="pflege-reviews-rail__success-dialog-dismiss"
                data-reviews-success-close
              >
                {{ 'sections.pflege_reviews_rail.success_modal_dismiss' | t }}
              </button>
            </div>
          </div>
        </dialog>
      {%- endif -%}
    </div>
  </div>
  <div class="pflege-reviews-rail__arc-edge pflege-reviews-rail__arc-edge--bottom" aria-hidden="true"></div>
</section>

{% schema %}
{
  "name": "Pflege: Bewertungen",
  "tag": "section",
  "class": "pflege-reviews-rail-section",
  "blocks": [
    {
      "type": "review",
      "name": "Kundenstimme",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Sterne",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Zitat / Text",
          "default": "Alles bestens, top Service."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Name (z. B. „E. A.“)",
          "default": "E. A."
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Zusatz unter dem Namen",
          "info": "z. B. „10 Rezensionen“ oder Ortsangabe — bleibt leer, wenn nichts eingetragen ist.",
          "default": ""
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "paragraph",
      "content": "Karten („Kundenstimmen“) im Theme-Editor pflegen. Im Shop ist jeweils nur eine Stimme sichtbar; sie wechselt alle 5 Sekunden oder per Pfeile/Punkten unten. Eingehende Bewertungen per Formular gehen als Kontakt-Mail an den Shop."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Das sagen unsere Kundinnen und Kunden"
    },
    {
      "type": "text",
      "id": "rating_summary",
      "label": "Zeile unter den Sternen (nur wenn unten aktiviert)",
      "default": "Google-Rezensionen · 5,0 Sterne",
      "info": "Kurzer Zusatztext. Langer Werbetext (z. B. „Lesen Sie Erfahrungen …“) ist absichtlich nicht vorgesehen — nutzen Sie dafür ggf. die Hauptüberschrift oder einen eigenen Text-Baustein."
    },
    {
      "type": "checkbox",
      "id": "show_rating_summary_line",
      "label": "Zeile unter den Sternen anzeigen",
      "default": false,
      "info": "Standard: aus (schlanker Block). Einschalten für einen kurzen Hinweis wie „Google-Rezensionen …“."
    },
    {
      "type": "checkbox",
      "id": "show_fallback_demo",
      "label": "Demo-Karten anzeigen, wenn noch keine Blöcke",
      "default": true
    },
    {
      "type": "textarea",
      "id": "empty_state",
      "label": "Text ohne Kartenblöcke",
      "default": "Hier gibt es bald die ersten Bewertungen. Nutzen Sie gern „Eigene Bewertung schreiben“."
    },
    {
      "type": "header",
      "content": "Formular"
    },
    {
      "type": "checkbox",
      "id": "show_form",
      "label": "Formular anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Überschrift Formular",
      "default": "Ihre Bewertung"
    },
    {
      "type": "textarea",
      "id": "form_hint",
      "label": "Hinweis unter Überschrift (Formular)",
      "default": "Teilen Sie Ihre Erfahrung mit uns. Ihre Bewertung wird nach Prüfung veröffentlicht."
    },
    {
      "type": "richtext",
      "id": "privacy_note",
      "label": "Datenschutz-Hinweis (optional)",
      "default": "<p>Mit dem Absenden speichern wir Ihre Angaben zur Bearbeitung Ihrer Bewertung. Weitere Informationen finden Sie in unserer Datenschutzerklärung.</p>"
    },
    {
      "type": "text",
      "id": "success_continue_url",
      "label": "Nach erfolgreicher Bewertung — Link für „Jetzt weiter shoppen“",
      "info": "Leer lassen für die Standard-Kollektion „Alle Produkte“. Sonst Pfad eingeben, z. B. „/collections/inkontinenz“ oder vollständige URL.",
      "placeholder": "/collections/all"
    }
  ],
  "max_blocks": 50,
  "presets": [
    {
      "name": "Bewertungsleiste",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "Alles bestens, top Service.",
            "author": "E. A.",
            "subtitle": "10 Rezensionen"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "Unkomplizierte Bestellung und freundlicher Support am Telefon.",
            "author": "Marion S.",
            "subtitle": "8 Rezensionen"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "Produkte wie beschrieben, Lieferzeit hat gepasst.",
            "author": "Familie Becker",
            "subtitle": "6 Rezensionen"
          }
        }
      ]
    }
  ]
}
{% endschema %}

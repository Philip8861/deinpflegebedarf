{% comment %}
  Globale Kundenstimmen: horizontal wischbar / scroll-snap; darunter Bewertung per Kontaktformular (Shopify contact → E-Mail an den Shop).

  Über layout/theme.liquid als {% section 'pflege-reviews-rail' %} oberhalb des Footers eingebunden.
{% endcomment %}

{{ 'section-pflege-reviews-rail.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pflege-reviews-rail.js' | asset_url }}" defer="defer"></script>

<section
  class="pflege-reviews-rail color-{{ section.settings.color_scheme }}"
  aria-labelledby="pflege-reviews-title-{{ section.id }}"
  data-pflege-reviews-rail
>
  <div class="pflege-reviews-rail__inner">
    <header class="pflege-reviews-rail__head">
      <h2 class="pflege-reviews-rail__title" id="pflege-reviews-title-{{ section.id }}">
        {{ section.settings.heading | escape }}
      </h2>
      {%- if section.settings.subheading != blank -%}
        <p class="pflege-reviews-rail__sub">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </header>

    {%- liquid
      assign has_reviews = false
      if section.blocks.size > 0
        assign has_reviews = true
      endif
      assign show_demo_rail = false
      if has_reviews == false and section.settings.show_fallback_demo
        assign show_demo_rail = true
      endif
    -%}

    <div class="pflege-reviews-rail__carousel-wrap">
      {%- if has_reviews or show_demo_rail -%}
        <div class="pflege-reviews-rail__nav" aria-label="{{ 'sections.pflege_reviews_rail.nav_label' | t }}">
          <button
            type="button"
            class="pflege-reviews-rail__nav-btn"
            data-reviews-prev
            aria-label="{{ 'sections.pflege_reviews_rail.prev' | t }}"
          >
            <span aria-hidden="true">‹</span>
          </button>
          <button
            type="button"
            class="pflege-reviews-rail__nav-btn"
            data-reviews-next
            aria-label="{{ 'sections.pflege_reviews_rail.next' | t }}"
          >
            <span aria-hidden="true">›</span>
          </button>
        </div>
        <div
          class="pflege-reviews-rail__track"
          data-reviews-track
          role="region"
          aria-roledescription="carousel"
          aria-label="{{ 'sections.pflege_reviews_rail.carousel_label' | t }}"
        >
          {%- if has_reviews -%}
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'review' -%}
                  <article
                    class="pflege-reviews-rail__card"
                    {{ block.shopify_attributes }}
                  >
                    {%- assign review_rating = block.settings.rating | default: 5 | times: 1 -%}
                    {%- if review_rating < 1 -%}
                      {%- assign review_rating = 1 -%}
                    {%- endif -%}
                    {%- if review_rating > 5 -%}
                      {%- assign review_rating = 5 -%}
                    {%- endif -%}
                    <div class="pflege-reviews-rail__stars" aria-label="{{ 'sections.pflege_reviews_rail.stars_aria' | t: count: review_rating }}">
                      {%- for i in (1..5) -%}
                        <span{% if i > review_rating %} style="opacity:0.22"{% endif %} aria-hidden="true">★</span>
                      {%- endfor -%}
                    </div>
                    <p class="pflege-reviews-rail__quote">{{ block.settings.quote | escape }}</p>
                    <div class="pflege-reviews-rail__meta">
                      <span class="pflege-reviews-rail__author">{{ block.settings.author | escape }}</span>
                      {%- if block.settings.subtitle != blank -%}
                        <span> — {{ block.settings.subtitle | escape }}</span>
                      {%- endif -%}
                    </div>
                  </article>
              {%- endcase -%}
            {%- endfor -%}
          {%- else -%}
            {% render 'pflege-reviews-democards' %}
          {%- endif -%}
        </div>
      {%- else -%}
        <p class="pflege-reviews-rail__sub">{{ section.settings.empty_state | escape }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.show_form -%}
      {%- liquid
        assign reviews_form_id = 'PflegeReviewsForm-' | append: section.id
        assign reviews_form_class = 'pflege-reviews-rail__form'
      -%}
      <div class="pflege-reviews-rail__form-card">
        <h3 class="pflege-reviews-rail__form-title">{{ section.settings.form_heading | escape }}</h3>
        <p class="pflege-reviews-rail__form-hint">{{ section.settings.form_hint | escape }}</p>

        {%- form 'contact', id: reviews_form_id, class: reviews_form_class -%}
          {%- if form.posted_successfully? -%}
            <p class="pflege-reviews-rail__success" tabindex="-1">
              {{ 'sections.pflege_reviews_rail.form_success' | t }}
            </p>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="pflege-reviews-rail__errors">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <input
            type="text"
            name="bewertungen-honey"
            value=""
            class="pflege-reviews-rail__hp"
            tabindex="-1"
            autocomplete="off"
            data-reviews-hp
            aria-hidden="true"
          >
          <input type="hidden" name="contact[body]" value="" data-reviews-body-out>

          <div class="pflege-reviews-rail__form-grid pflege-reviews-rail__form-grid--two">
            <div class="pflege-reviews-rail__field">
              <label for="PflegeReviews-name-{{ section.id }}">
                {{ 'templates.contact.form.name' | t }}
              </label>
              <input
                id="PflegeReviews-name-{{ section.id }}"
                class="pflege-reviews-rail__input"
                type="text"
                name="contact[name]"
                autocomplete="name"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              >
            </div>
            <div class="pflege-reviews-rail__field">
              <label for="PflegeReviews-email-{{ section.id }}">
                {{ 'templates.contact.form.email' | t }}
                <span class="pflege-reviews-rail__req" aria-hidden="true">*</span>
              </label>
              <input
                id="PflegeReviews-email-{{ section.id }}"
                class="pflege-reviews-rail__input"
                type="email"
                name="contact[email]"
                autocomplete="email"
                required
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              >
            </div>
          </div>

          <div class="pflege-reviews-rail__form-grid">
            <div class="pflege-reviews-rail__field">
              <label for="PflegeReviews-rating-{{ section.id }}">{{ 'sections.pflege_reviews_rail.label_rating' | t }}</label>
              <select
                id="PflegeReviews-rating-{{ section.id }}"
                class="pflege-reviews-rail__select"
                data-reviews-rating
                required
              >
                <option value="5">5 ★★★★★</option>
                <option value="4">4 ★★★★</option>
                <option value="3">3 ★★★</option>
                <option value="2">2 ★★</option>
                <option value="1">1 ★</option>
              </select>
            </div>
            <div class="pflege-reviews-rail__field">
              <label for="PflegeReviews-comment-{{ section.id }}">
                {{ 'sections.pflege_reviews_rail.label_comment' | t }}
                <span class="pflege-reviews-rail__req" aria-hidden="true">*</span>
              </label>
              <textarea
                id="PflegeReviews-comment-{{ section.id }}"
                class="pflege-reviews-rail__textarea"
                rows="5"
                data-reviews-comment
                placeholder="{{ 'sections.pflege_reviews_rail.comment_placeholder' | t }}"
                required
              ></textarea>
            </div>
          </div>

          <button type="submit" class="pflege-reviews-rail__submit" name="commit">
            {{ 'sections.pflege_reviews_rail.submit' | t }}
          </button>

          {%- if section.settings.privacy_note != blank -%}
            <div class="rte pflege-reviews-rail__sub" style="margin-top: 1rem; margin-bottom: 0;">
              {{ section.settings.privacy_note }}
            </div>
          {%- endif -%}
        {%- endform -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Pflege: Bewertungen",
  "tag": "section",
  "class": "pflege-reviews-rail-section",
  "blocks": [
    {
      "type": "review",
      "name": "Kundenstimme",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Sterne",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Zitat / Text",
          "default": "Sehr guter Service und schnelle Lieferung!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Name",
          "default": "Kundin/Kunde"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Zusatz (z. B. Ort)"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "paragraph",
      "content": "Die Karten im Slider tragt ihr im Theme-Editor ein. Über das Formular eingehende Bewertungen gehen als Kontakt-Mail an den Shop-Inhaber ([Kunde] ohne App). Freigeschaltete Stimmen könnt ihr später als neue Blöcke einfügen."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Das sagen unsere Kunden"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Einleitung (optional)",
      "default": "Wischen Sie horizontal durch die Bewertungen – oder schreiben Sie uns Ihre eigene!"
    },
    {
      "type": "checkbox",
      "id": "show_fallback_demo",
      "label": "Demo-Karten anzeigen, wenn noch keine Blöcke",
      "default": true
    },
    {
      "type": "textarea",
      "id": "empty_state",
      "label": "Text ohne Kartenblöcke",
      "default": "Hier gibt es bald die ersten Bewertungen. Schreiben Sie uns gern eine!"
    },
    {
      "type": "header",
      "content": "Formular"
    },
    {
      "type": "checkbox",
      "id": "show_form",
      "label": "Formular anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Überschrift Formular",
      "default": "Ihre Bewertung"
    },
    {
      "type": "textarea",
      "id": "form_hint",
      "label": "Hinweis unter Überschrift",
      "default": "Wählen Sie Sterne und Ihren kurzen Kommentar. Mit dem Absenden wird eine Nachricht über das Shopify-Kontaktformular verschickt."
    },
    {
      "type": "richtext",
      "id": "privacy_note",
      "label": "Datenschutz-Hinweis (optional)",
      "default": "<p>Mit Absenden werden Ihre Angaben zur Bearbeitung gespeichert. Siehe auch unsere Datenschutzerklärung.</p>"
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "Bewertungsleiste",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "Unkomplizierte Bestellung und freundlicher Support am Telefon.",
            "author": "Marion S.",
            "subtitle": "Bayern"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "quote": "Produkte wie beschrieben, Lieferzeit hat gepasst.",
            "author": "Familie Becker"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 4,
            "quote": "Gute Auswahl rund um Pflege – gerne wieder.",
            "author": "Thomas R."
          }
        }
      ]
    }
  ]
}
{% endschema %}

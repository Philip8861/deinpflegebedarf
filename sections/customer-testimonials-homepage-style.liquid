{% comment %}
  HomepageReviewsSection — Kundenbewertungen / Kundenstimmen (neutral, ohne Google-Bezug).
{% endcomment %}
{{ 'section-customer-testimonials-homepage-style.css' | asset_url | stylesheet_tag }}
<script src="{{ 'customer-testimonials-homepage-style.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign review_blocks = section.blocks | where: 'type', 'review'
  assign review_count = review_blocks.size

  assign average_rating = section.settings.average_rating | default: '4.5' | replace: ',', '.' | plus: 0.0
  if average_rating < 0
    assign average_rating = 0
  elsif average_rating > 5
    assign average_rating = 5
  endif

  assign display_count = section.settings.total_review_count | default: 0 | plus: 0
  if display_count == 0
    if review_count > 0
      assign display_count = review_count
    else
      assign display_count = 4
    endif
  endif

  assign rating_de = average_rating | round: 1 | replace: '.', ','

  assign summary_line = section.settings.summary_text | strip
  if summary_line == blank
    assign summary_line = 'Kundenbewertungen · ' | append: rating_de | append: ' von 5 Sternen · Basierend auf ' | append: display_count | append: ' Bewertungen'
  endif

  assign head = section.settings.heading | strip
  if head == blank
    assign head = 'Das sagen unsere Kund*innen'
  endif

  assign subline = section.settings.subheading | strip
  if subline == blank
    assign subline = 'Echte Erfahrungen mit unserem Service'
  endif

  assign btn_label_t = section.settings.button_label | strip
  if btn_label_t == blank
    assign btn_label_t = 'Alle [count] Kundenstimmen anzeigen'
  endif
  assign btn_label_t = btn_label_t | replace: '[count]', display_count

  assign pad_top = section.settings.padding_top | default: 64
  assign pad_bot = section.settings.padding_bottom | default: 64
  assign auto_on = section.settings.auto_rotate
  assign auto_sec = section.settings.auto_rotate_seconds | default: 5
  if auto_sec < 3
    assign auto_sec = 3
  elsif auto_sec > 60
    assign auto_sec = 60
  endif

  assign stars_aria = section.settings.stars_aria_label | strip
  if stars_aria == blank
    assign stars_aria = rating_de | append: ' von 5 Sternen'
  endif

  assign modal_head = section.settings.modal_heading | strip
  if modal_head == blank
    assign modal_head = 'Alle Kundenstimmen'
  endif


  assign dot_count = display_count
  if review_count > dot_count
    assign dot_count = review_count
  endif
  if dot_count > 20
    assign dot_count = 20
  endif
-%}

{%- style -%}
  #CustomerTestimonials-{{ section.id }} {
    padding-top: {{ pad_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ pad_bot | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #CustomerTestimonials-{{ section.id }} {
      padding-top: {{ pad_top }}px;
      padding-bottom: {{ pad_bot }}px;
    }
  }
{%- endstyle -%}

<section
  id="CustomerTestimonials-{{ section.id }}"
  class="ct-hp"
  data-ct-root="{{ section.id }}"
  {% if auto_on %}
    data-ct-auto="true"
    data-ct-auto-sec="{{ auto_sec }}"
  {% endif %}
  aria-labelledby="ct-title-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="ct-hp__inner">
    <header class="ct-hp__head">
      {% render 'pflege-rating-stars', rating: average_rating, max: 5, aria_label: stars_aria %}
      <p class="ct-hp__summary">{{ summary_line | escape }}</p>
      <h2 class="ct-hp__title" id="ct-title-{{ section.id }}">{{ head | escape }}</h2>
      <p class="ct-hp__subline">{{ subline | escape }}</p>
    </header>

    <div class="ct-hp__showcase">
      <div class="ct-hp__card" data-ct-card>
      <span class="ct-hp__quote-mark" aria-hidden="true">&ldquo;</span>

      <div class="ct-hp__body" aria-live="polite">
        {%- if review_count > 0 -%}
          {%- for block in review_blocks -%}
            <article
              class="ct-hp__panel{% if forloop.first %} is-active{% endif %}"
              id="ct-panel-{{ section.id }}-{{ forloop.index0 }}"
              data-ct-panel
              data-block-id="{{ block.id }}"
              aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
              {{ block.shopify_attributes }}
              {% unless forloop.first %}
                hidden
              {% endunless %}
            >
              <p class="ct-hp__quote">
                {{ block.settings.review_text | strip | escape }}
              </p>
              <div class="ct-hp__author">
                <span class="ct-hp__avatar" aria-hidden="true">
                  <svg viewBox="0 0 24 24" focusable="false">
                    <circle cx="12" cy="8.25" r="3.75"/>
                    <path d="M5.5 19.5c.65-3.05 3.05-5 6.5-5s5.85 1.95 6.5 5"/>
                  </svg>
                </span>
                <div class="ct-hp__author-meta">
                  <span class="ct-hp__name">{{ block.settings.customer_name | strip | default: 'Kundin/Kunde' | escape }}</span>
                  {% render 'ct-hp-verified-buyer' %}
                  <span class="ct-hp__source">
                    {%- render 'ct-hp-source-line', text: block.settings.source_text -%}
                  </span>
                </div>
              </div>
            </article>
          {%- endfor -%}
        {%- else -%}
          <article class="ct-hp__panel is-active" data-ct-panel aria-hidden="false">
            <p class="ct-hp__quote">{{ section.settings.fallback_quote | default: 'Sehr guter Service und schnelle Lieferung!' | escape }}</p>
            <div class="ct-hp__author">
              <span class="ct-hp__avatar" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <circle cx="12" cy="8.25" r="3.75"/>
                  <path d="M5.5 19.5c.65-3.05 3.05-5 6.5-5s5.85 1.95 6.5 5"/>
                </svg>
              </span>
              <div class="ct-hp__author-meta">
                <span class="ct-hp__name">{{ section.settings.fallback_author | default: 'Kundin/Kunde' | escape }}</span>
                {% render 'ct-hp-verified-buyer' %}
                <span class="ct-hp__source">{% render 'ct-hp-source-line' %}</span>
              </div>
            </div>
          </article>
        {%- endif -%}
      </div>
      </div>

      {%- if dot_count > 1 -%}
        <ul class="ct-hp__dots" role="list" aria-label="{{ 'sections.customer_testimonials_hp.dots_label' | t }}">
          {%- for i in (1..dot_count) -%}
            {%- assign dot_idx = forloop.index0 -%}
            <li role="listitem">
              <button
                type="button"
                class="ct-hp__dot{% if forloop.first %} is-active{% endif %}"
                data-ct-dot
                data-ct-dot-index="{{ dot_idx }}"
                aria-label="{{ 'sections.customer_testimonials_hp.dot_aria' | t: index: forloop.index }}"
                {% if forloop.first %}
                  aria-current="true"
                {% endif %}
              ></button>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <div class="ct-hp__cta-wrap">
      {%- if section.settings.button_link != blank -%}
        <a class="ct-hp__cta ct-hp__cta--primary" href="{{ section.settings.button_link }}">
          {{- btn_label_t | escape -}}
        </a>
      {%- elsif review_count > 0 -%}
        <button
          type="button"
          class="ct-hp__cta ct-hp__cta--primary ct-hp__cta--toggle"
          data-ct-toggle-expand
          aria-expanded="false"
          aria-controls="ct-expand-{{ section.id }}"
          data-ct-label-more="{{ btn_label_t | escape }}"
          data-ct-label-less="{{ 'sections.customer_testimonials_hp.show_less' | t | escape }}"
        >
          <span data-ct-expand-label>{{ btn_label_t | escape }}</span>
        </button>
      {%- else -%}
        {%- comment -%} TODO: Link zu Bewertungsübersicht einsetzen, falls keine Blocks vorhanden. {%- endcomment -%}
        <span class="ct-hp__cta ct-hp__cta--primary ct-hp__cta--inactive">{{ btn_label_t | escape }}</span>
      {%- endif -%}

      {%- unless section.settings.show_review_form == false -%}
        {%- assign review_btn = section.settings.review_submit_label | strip -%}
        {%- if review_btn == blank -%}
          {%- assign review_btn = 'sections.customer_testimonials_hp.review_submit' | t -%}
        {%- endif -%}
        <button
          type="button"
          class="ct-hp__cta ct-hp__cta--secondary"
          data-ct-review-open
          aria-haspopup="dialog"
          aria-expanded="false"
          aria-controls="ct-review-modal-{{ section.id }}"
        >
          <svg class="ct-hp__cta-star" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M12 3.2l2.55 5.17 5.7.83-4.12 4.02.97 5.68L12 16.9l-5.1 2.68.97-5.68-4.12-4.02 5.7-.83L12 3.2z"/>
          </svg>
          {{- review_btn | escape -}}
        </button>
      {%- endunless -%}
    </div>
  </div>

  {%- if review_count > 0 and section.settings.button_link == blank -%}
    <div class="ct-hp__expand-wrap" data-ct-expand-wrap aria-hidden="true">
      <div class="ct-hp__expand-inner">
        <div
          class="ct-hp__expand-panel"
          id="ct-expand-{{ section.id }}"
          role="region"
          aria-labelledby="ct-expand-title-{{ section.id }}"
        >
          <h3 class="ct-hp__expand-title" id="ct-expand-title-{{ section.id }}">{{ modal_head | escape }}</h3>
          <div class="ct-hp__expand-list">
            {%- for block in review_blocks -%}
              <article class="ct-hp__expand-review" {{ block.shopify_attributes }}>
                <p class="ct-hp__quote ct-hp__quote--expand">{{ block.settings.review_text | strip | escape }}</p>
                <div class="ct-hp__author ct-hp__author--expand">
                  <span class="ct-hp__name">{{ block.settings.customer_name | strip | escape }}</span>
                  {% render 'ct-hp-verified-buyer' %}
                  <span class="ct-hp__source">
                    {%- render 'ct-hp-source-line', text: block.settings.source_text -%}
                  </span>
                </div>
              </article>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- unless section.settings.show_review_form == false -%}
    {%- assign review_btn = section.settings.review_submit_label | strip -%}
    {%- if review_btn == blank -%}
      {%- assign review_btn = 'sections.customer_testimonials_hp.review_submit' | t -%}
    {%- endif -%}
    {%- assign review_form_id = 'CtReviewForm-' | append: section.id -%}
    <dialog
      class="ct-hp__review-modal"
      id="ct-review-modal-{{ section.id }}"
      data-ct-review-dialog
      aria-labelledby="ct-review-title-{{ section.id }}"
      aria-modal="true"
    >
      <div class="ct-hp__review-modal__panel">
        <div class="ct-hp__review-modal__head">
          <h2 class="ct-hp__review-modal__title" id="ct-review-title-{{ section.id }}">
            {{- review_btn | escape -}}
          </h2>
          <button
            type="button"
            class="ct-hp__review-modal__close"
            data-ct-review-close
            aria-label="{{ 'accessibility.close' | t }}"
          >
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        {%- form 'contact', id: review_form_id, class: 'ct-hp__review-form' -%}
          <input type="hidden" name="contact[Betreff]" value="Kundenstimme / Bewertung">
          {%- liquid
            assign ct_review_success = false
            if form.posted_successfully? and form.betreff == 'Kundenstimme / Bewertung'
              assign ct_review_success = true
            endif
          -%}
          {%- if ct_review_success -%}
            <p class="ct-hp__review-status ct-hp__review-status--success" role="status" tabindex="-1">
              {{- 'sections.customer_testimonials_hp.review_success' | t -}}
            </p>
            <button type="button" class="ct-hp__review-modal__submit" data-ct-review-close>
              {{- 'accessibility.close' | t -}}
            </button>
          {%- else -%}
            {%- if form.errors -%}
              <p class="ct-hp__review-status ct-hp__review-status--error" role="alert">
                {{- 'sections.customer_testimonials_hp.review_error' | t -}}
              </p>
            {%- endif -%}
            <p class="ct-hp__review-required-note">
              {{- 'sections.customer_testimonials_hp.review_required_note' | t -}}
            </p>
            <div class="ct-hp__review-fields">
              <div class="ct-hp__review-field">
                <label class="ct-hp__review-label" for="{{ review_form_id }}-lastname">
                  {{- 'sections.customer_testimonials_hp.review_lastname' | t -}}
                  <span class="ct-hp__review-required" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="{{ review_form_id }}-lastname"
                  class="ct-hp__review-input"
                  name="contact[Nachname]"
                  autocomplete="family-name"
                  required
                  aria-required="true"
                  value="{{ form.Nachname }}"
                >
              </div>
              <div class="ct-hp__review-field">
                <label class="ct-hp__review-label" for="{{ review_form_id }}-firstname">
                  {{- 'sections.customer_testimonials_hp.review_firstname' | t -}}
                  <span class="ct-hp__review-required" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="{{ review_form_id }}-firstname"
                  class="ct-hp__review-input"
                  name="contact[Vorname]"
                  autocomplete="given-name"
                  required
                  aria-required="true"
                  value="{{ form.Vorname }}"
                >
              </div>
              <div class="ct-hp__review-field ct-hp__review-field--full">
                <label class="ct-hp__review-label" for="{{ review_form_id }}-message">
                  {{- 'sections.customer_testimonials_hp.review_message' | t -}}
                  <span class="ct-hp__review-required" aria-hidden="true">*</span>
                </label>
                <textarea
                  id="{{ review_form_id }}-message"
                  class="ct-hp__review-input ct-hp__review-textarea"
                  name="contact[Nachricht]"
                  rows="6"
                  required
                  aria-required="true"
                >{{ form.Nachricht }}</textarea>
              </div>
              <div class="ct-hp__review-field ct-hp__review-field--full">
                <label class="ct-hp__review-label" for="{{ review_form_id }}-email">
                  {{- 'sections.customer_testimonials_hp.review_email' | t -}}
                  <span class="ct-hp__review-required" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="{{ review_form_id }}-email"
                  class="ct-hp__review-input"
                  name="contact[email]"
                  autocomplete="email"
                  spellcheck="false"
                  autocapitalize="off"
                  required
                  aria-required="true"
                  value="{% if form.email %}{{ form.email }}{% endif %}"
                  {% if form.errors contains 'email' %}
                    aria-invalid="true"
                  {% endif %}
                >
              </div>
            </div>
            <button type="submit" class="ct-hp__review-modal__submit">
              {{- 'sections.customer_testimonials_hp.review_send' | t -}}
            </button>
          {%- endif -%}
        {%- endform -%}
      </div>
    </dialog>
  {%- endunless -%}
</section>

{% schema %}
{
  "name": "Kundenstimmen (Homepage)",
  "tag": "section",
  "class": "customer-testimonials-hp-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Neutraler Kundenbewertungs-Bereich ohne Google-Bezug. Sterne und Summary-Zeile werden aus der Durchschnittsbewertung berechnet."
    },
    {
      "type": "text",
      "id": "average_rating",
      "label": "Durchschnittsbewertung (0–5)",
      "default": "4.5",
      "info": "Dezimalwerte möglich, z. B. 4.5 für 4 volle und 1 halben Stern."
    },
    {
      "type": "number",
      "id": "total_review_count",
      "label": "Anzahl Bewertungen (Anzeige)",
      "default": 4,
      "info": "Wird in Summary-Zeile und Button-Text verwendet."
    },
    {
      "type": "text",
      "id": "summary_text",
      "label": "Zeile unter den Sternen (optional)",
      "info": "Leer lassen für automatische Zeile: Kundenbewertungen · X von 5 Sternen · Basierend auf N Bewertungen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Das sagen unsere Kund*innen"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subline",
      "default": "Echte Erfahrungen mit unserem Service"
    },
    {
      "type": "text",
      "id": "stars_aria_label",
      "label": "Sterne (Barrierefreiheit, optional)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Alle [count] Kundenstimmen anzeigen",
      "info": "[count] = Anzahl Bewertungen (Anzeige)."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button-Link (z. B. Kundenstimmen-Seite)",
      "info": "Ohne Link klappt darunter ein Bereich mit allen Stimmen auf."
    },
    {
      "type": "text",
      "id": "modal_heading",
      "label": "Überschrift über der aufklappbaren Liste",
      "default": "Alle Kundenstimmen"
    },
    {
      "type": "header",
      "content": "Fallback ohne Blocks"
    },
    {
      "type": "textarea",
      "id": "fallback_quote",
      "label": "Beispiel-Zitat",
      "default": "Sehr guter Service und schnelle Lieferung!"
    },
    {
      "type": "text",
      "id": "fallback_author",
      "label": "Beispiel-Name",
      "default": "Kundin/Kunde"
    },
    {
      "type": "header",
      "content": "Bewertung einreichen"
    },
    {
      "type": "checkbox",
      "id": "show_review_form",
      "label": "Button und Formular „Bewertung abgeben“ anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "review_submit_label",
      "label": "Button-Text",
      "default": "Bewertung abgeben"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Automatisch wechseln",
      "default": true
    },
    {
      "type": "range",
      "id": "auto_rotate_seconds",
      "min": 3,
      "max": 30,
      "step": 1,
      "unit": "s",
      "label": "Wechsel alle (Sekunden)",
      "default": 5
    },
    {
      "type": "textarea",
      "id": "empty_message",
      "label": "Hinweis ohne Stimmen-Blocks",
      "default": "Fügen Sie Kundenstimmen-Blocks hinzu."
    },
    {
      "type": "header",
      "content": "Abstand"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 32,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Oben",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 32,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Unten",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Kundenstimme",
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Zitat",
          "default": "Sehr guter Service und schnelle Lieferung!"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Name",
          "default": "Kundin/Kunde"
        },
        {
          "type": "text",
          "id": "source_text",
          "label": "Quellenzeile",
          "default": "Bewertung aus dem Shop"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kundenstimmen (Homepage)",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "review_text": "Sehr guter Service und schnelle Lieferung!",
            "customer_name": "Kundin/Kunde",
            "source_text": "Bewertung aus dem Shop"
          }
        }
      ]
    }
  ]
}
{% endschema %}

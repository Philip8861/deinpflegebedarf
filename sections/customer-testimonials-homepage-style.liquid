{% comment %}
  Kundenstimmen / Google-Rezensionen — Homepage-Vorbild (clean, Blocks für Zitate).
{% endcomment %}
{{ 'section-customer-testimonials-homepage-style.css' | asset_url | stylesheet_tag }}
<script src="{{ 'customer-testimonials-homepage-style.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign review_blocks = section.blocks | where: 'type', 'review'
  assign review_count = review_blocks.size

  assign dot_count = 0
  if review_count > 0
    assign dot_count = review_count
    if dot_count > 20
      assign dot_count = 20
    endif
  endif

  assign eyebrow = section.settings.eyebrow_text | strip
  if eyebrow == blank
    assign eyebrow = 'Google-Rezensionen · 5,0 Sterne'
  endif

  assign head = section.settings.heading | strip
  if head == blank
    assign head = 'Das sagen unsere Kund*innen'
  endif

  assign btn_label_t = section.settings.button_label | strip
  if btn_label_t == blank
    assign btn_label_t = 'Alle [count] Kundenstimmen anzeigen'
  endif
  assign btn_label_t = btn_label_t | replace: '[count]', review_count

  assign pad_top = section.settings.padding_top | default: 64
  assign pad_bot = section.settings.padding_bottom | default: 68
  assign auto_on = section.settings.auto_rotate
  assign auto_sec = section.settings.auto_rotate_seconds | default: 5
  if auto_sec < 3
    assign auto_sec = 3
  elsif auto_sec > 60
    assign auto_sec = 60
  endif

  assign stars_aria = section.settings.stars_aria_label | strip
  if stars_aria == blank
    assign stars_aria = '5 von 5 Sternen'
  endif

  assign modal_head = section.settings.modal_heading | strip
  if modal_head == blank
    assign modal_head = 'Alle Kundenstimmen'
  endif
-%}

{%- style -%}
  #CustomerTestimonials-{{ section.id }} {
    padding-top: {{ pad_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ pad_bot | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #CustomerTestimonials-{{ section.id }} {
      padding-top: {{ pad_top }}px;
      padding-bottom: {{ pad_bot }}px;
    }
  }
{%- endstyle -%}

<section
  id="CustomerTestimonials-{{ section.id }}"
  class="ct-hp"
  data-ct-root="{{ section.id }}"
  {% if auto_on %}
    data-ct-auto="true"
    data-ct-auto-sec="{{ auto_sec }}"
  {% endif %}
  aria-labelledby="ct-title-{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="ct-hp__inner">
    <header class="ct-hp__head">
      <div class="ct-hp__stars" role="img" aria-label="{{ stars_aria | escape }}">
        {%- for _ in (1..5) -%}
          <span class="ct-hp__star" aria-hidden="true">★</span>
        {%- endfor -%}
      </div>
      <p class="ct-hp__eyebrow">{{ eyebrow | escape }}</p>
      <h2 class="ct-hp__title" id="ct-title-{{ section.id }}">{{ head | escape }}</h2>
    </header>

    <div class="ct-hp__body" aria-live="polite">
      {%- if review_count > 0 -%}
        {%- for block in review_blocks -%}
          <article
            class="ct-hp__panel{% if forloop.first %} is-active{% endif %}"
            id="ct-panel-{{ section.id }}-{{ forloop.index0 }}"
            data-ct-panel
            data-block-id="{{ block.id }}"
            aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
            {{ block.shopify_attributes }}
            {% unless forloop.first %}
              hidden
            {% endunless %}
          >
            <p class="ct-hp__quote">
              „{{ block.settings.review_text | strip | escape }}“
            </p>
            <span class="ct-hp__name">{{ block.settings.customer_name | strip | escape }}</span>
            {% render 'ct-hp-verified-buyer' %}
            <span class="ct-hp__source">
              {{- block.settings.source_text | strip | default: 'Rezension aus Google · 5/5' | escape -}}
            </span>
          </article>
        {%- endfor -%}
      {%- else -%}
        <p class="ct-hp__empty">{{ section.settings.empty_message | escape }}</p>
      {%- endif -%}
    </div>

    {%- if review_count > 0 -%}
      <ul class="ct-hp__dots" role="list" aria-label="{{ 'sections.customer_testimonials_hp.dots_label' | t }}">
        {%- for i in (1..dot_count) -%}
          {%- assign dot_idx = forloop.index0 -%}
          <li role="listitem">
            <button
              type="button"
              class="ct-hp__dot{% if forloop.first %} is-active{% endif %}"
              data-ct-dot
              data-ct-dot-index="{{ dot_idx }}"
              aria-label="{{ 'sections.customer_testimonials_hp.dot_aria' | t: index: forloop.index }}"
              {% if forloop.first %}
                aria-current="true"
              {% endif %}
            >
              <svg class="ct-hp__dot-svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path class="ct-hp__dot-check" d="M6 12.5L10 16.5L18 8.5"/>
              </svg>
            </button>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    <div class="ct-hp__cta-wrap">
      {%- if section.settings.button_link != blank -%}
        <a class="ct-hp__cta" href="{{ section.settings.button_link }}">
          {{- btn_label_t | escape -}}
        </a>
      {%- elsif review_count > 0 -%}
        <button
          type="button"
          class="ct-hp__cta ct-hp__cta--toggle"
          data-ct-toggle-expand
          aria-expanded="false"
          aria-controls="ct-expand-{{ section.id }}"
          data-ct-label-more="{{ btn_label_t | escape }}"
          data-ct-label-less="{{ 'sections.customer_testimonials_hp.show_less' | t | escape }}"
        >
          <span data-ct-expand-label>{{ btn_label_t | escape }}</span>
          <span class="ct-hp__cta-chevron" aria-hidden="true">{{- 'sections.customer_testimonials_hp.chevron_down' | t -}}</span>
        </button>
      {%- else -%}
        <span class="ct-hp__cta ct-hp__cta--inactive">{{ btn_label_t | escape }}</span>
      {%- endif -%}

      {%- unless section.settings.show_review_form == false -%}
        {%- assign review_btn = section.settings.review_submit_label | strip -%}
        {%- if review_btn == blank -%}
          {%- assign review_btn = 'sections.customer_testimonials_hp.review_submit' | t -%}
        {%- endif -%}
        <button
          type="button"
          class="ct-hp__cta ct-hp__cta--review"
          data-ct-review-open
          aria-haspopup="dialog"
          aria-expanded="false"
          aria-controls="ct-review-modal-{{ section.id }}"
        >
          {{- review_btn | escape -}}
        </button>
      {%- endunless -%}
    </div>
  </div>

  {%- if review_count > 0 and section.settings.button_link == blank -%}
    <div
      class="ct-hp__expand-wrap"
      data-ct-expand-wrap
      aria-hidden="true"
    >
      <div class="ct-hp__expand-inner">
        <div
          class="ct-hp__expand-panel"
          id="ct-expand-{{ section.id }}"
          role="region"
          aria-labelledby="ct-expand-title-{{ section.id }}"
        >
          <h3 class="ct-hp__expand-title" id="ct-expand-title-{{ section.id }}">{{ modal_head | escape }}</h3>
          <div class="ct-hp__expand-list">
            {%- for block in review_blocks -%}
              <article class="ct-hp__expand-review" {{ block.shopify_attributes }}>
                <p class="ct-hp__quote ct-hp__quote--expand">
                  „{{ block.settings.review_text | strip | escape }}“
                </p>
                <span class="ct-hp__name">{{ block.settings.customer_name | strip | escape }}</span>
                {% render 'ct-hp-verified-buyer' %}
                <span class="ct-hp__source">
                  {{- block.settings.source_text | strip | default: 'Rezension aus Google · 5/5' | escape -}}
                </span>
              </article>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- unless section.settings.show_review_form == false -%}
    {%- assign review_btn = section.settings.review_submit_label | strip -%}
    {%- if review_btn == blank -%}
      {%- assign review_btn = 'sections.customer_testimonials_hp.review_submit' | t -%}
    {%- endif -%}
    {%- assign review_form_id = 'CtReviewForm-' | append: section.id -%}
    <dialog
      class="ct-hp__review-modal"
      id="ct-review-modal-{{ section.id }}"
      data-ct-review-dialog
      aria-labelledby="ct-review-title-{{ section.id }}"
      aria-modal="true"
    >
      <div class="ct-hp__review-modal__panel">
        <div class="ct-hp__review-modal__head">
          <h2 class="ct-hp__review-modal__title" id="ct-review-title-{{ section.id }}">
            {{- review_btn | escape -}}
          </h2>
          <button
            type="button"
            class="ct-hp__review-modal__close"
            data-ct-review-close
            aria-label="{{ 'accessibility.close' | t }}"
          >
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        {%- form 'contact', id: review_form_id, class: 'ct-hp__review-form' -%}
          <input type="hidden" name="contact[Betreff]" value="Kundenstimme / Bewertung">
          {%- if form.posted_successfully? -%}
            <p class="ct-hp__review-status ct-hp__review-status--success" role="status" tabindex="-1">
              {{- 'sections.customer_testimonials_hp.review_success' | t -}}
            </p>
            <button type="button" class="ct-hp__review-modal__submit" data-ct-review-close>
              {{- 'accessibility.close' | t -}}
            </button>
          {%- else -%}
            {%- if form.errors -%}
              <p class="ct-hp__review-status ct-hp__review-status--error" role="alert">
                {{- 'sections.customer_testimonials_hp.review_error' | t -}}
              </p>
            {%- endif -%}
            <p class="ct-hp__review-required-note">
              {{- 'sections.customer_testimonials_hp.review_required_note' | t -}}
            </p>
            <div class="ct-hp__review-fields">
              <div class="ct-hp__review-field">
                <label class="ct-hp__review-label" for="{{ review_form_id }}-lastname">
                  {{- 'sections.customer_testimonials_hp.review_lastname' | t -}}
                  <span class="ct-hp__review-required" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="{{ review_form_id }}-lastname"
                  class="ct-hp__review-input"
                  name="contact[Nachname]"
                  autocomplete="family-name"
                  required
                  aria-required="true"
                  value="{{ form.Nachname }}"
                >
              </div>
              <div class="ct-hp__review-field">
                <label class="ct-hp__review-label" for="{{ review_form_id }}-firstname">
                  {{- 'sections.customer_testimonials_hp.review_firstname' | t -}}
                  <span class="ct-hp__review-required" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="{{ review_form_id }}-firstname"
                  class="ct-hp__review-input"
                  name="contact[Vorname]"
                  autocomplete="given-name"
                  required
                  aria-required="true"
                  value="{{ form.Vorname }}"
                >
              </div>
              <div class="ct-hp__review-field ct-hp__review-field--full">
                <label class="ct-hp__review-label" for="{{ review_form_id }}-message">
                  {{- 'sections.customer_testimonials_hp.review_message' | t -}}
                  <span class="ct-hp__review-required" aria-hidden="true">*</span>
                </label>
                <textarea
                  id="{{ review_form_id }}-message"
                  class="ct-hp__review-input ct-hp__review-textarea"
                  name="contact[Nachricht]"
                  rows="6"
                  required
                  aria-required="true"
                >{{ form.Nachricht }}</textarea>
              </div>
              <div class="ct-hp__review-field ct-hp__review-field--full">
                <label class="ct-hp__review-label" for="{{ review_form_id }}-email">
                  {{- 'sections.customer_testimonials_hp.review_email' | t -}}
                  <span class="ct-hp__review-required" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="{{ review_form_id }}-email"
                  class="ct-hp__review-input"
                  name="contact[email]"
                  autocomplete="email"
                  spellcheck="false"
                  autocapitalize="off"
                  required
                  aria-required="true"
                  value="{% if form.email %}{{ form.email }}{% endif %}"
                  {% if form.errors contains 'email' %}
                    aria-invalid="true"
                  {% endif %}
                >
              </div>
            </div>
            <button type="submit" class="ct-hp__review-modal__submit">
              {{- 'sections.customer_testimonials_hp.review_send' | t -}}
            </button>
          {%- endif -%}
        {%- endform -%}
      </div>
    </dialog>
  {%- endunless -%}
</section>

{% schema %}
{
  "name": "Kundenstimmen (Homepage)",
  "tag": "section",
  "class": "customer-testimonials-hp-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Mehrere Kundenstimmen als Blocks. Marker-Anzahl = Bewertungs-Slots; bei weniger Texten werden Zitate zyklisch zugeordnet."
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Zeile unter den Sternen",
      "default": "Google-Rezensionen · 5,0 Sterne"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Das sagen unsere Kund*innen"
    },
    {
      "type": "text",
      "id": "stars_aria_label",
      "label": "Sterne (Barrierefreiheit)",
      "default": "5 von 5 Sternen"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Alle [count] Kundenstimmen anzeigen",
      "info": "[count] wird durch die Anzahl der Kundenstimmen-Blocks ersetzt. Die orangefarbenen Marker entsprechen dieser Anzahl (höchstens 20)."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button-Link (z. B. Kundenstimmen-Seite)",
      "info": "Ohne Link klappt darunter auf der Seite ein Bereich mit allen Stimmen auf (und wieder zu)."
    },
    {
      "type": "text",
      "id": "modal_heading",
      "label": "Überschrift über der aufklappbaren Liste",
      "default": "Alle Kundenstimmen"
    },
    {
      "type": "header",
      "content": "Bewertung einreichen"
    },
    {
      "type": "checkbox",
      "id": "show_review_form",
      "label": "Button und Formular „Bewertung abgeben“ anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "review_submit_label",
      "label": "Button-Text",
      "default": "Bewertung abgeben"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Automatisch wechseln",
      "default": true,
      "info": "Wechselt Zitat und Marker (bei mehreren Stimmen)."
    },
    {
      "type": "range",
      "id": "auto_rotate_seconds",
      "min": 3,
      "max": 30,
      "step": 1,
      "unit": "s",
      "label": "Wechsel alle (Sekunden)",
      "default": 5
    },
    {
      "type": "textarea",
      "id": "empty_message",
      "label": "Hinweis ohne Stimmen-Blocks",
      "default": "Fügen Sie Kundenstimmen-Blocks hinzu."
    },
    {
      "type": "header",
      "content": "Abstand"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 32,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Oben",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 32,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Unten",
      "default": 68
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Kundenstimme",
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Zitat"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "source_text",
          "label": "Quellenzeile",
          "info": "Leer lassen für „Rezension aus Google · 5/5“."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kundenstimmen (Homepage)"
    }
  ]
}
{% endschema %}

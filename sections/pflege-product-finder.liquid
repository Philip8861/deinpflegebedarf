{{ 'section-pflege-product-finder.css' | asset_url | stylesheet_tag }}

{%- liquid
  # Button-Ziel:
  # 1. Manuell gesetzter Link aus dem Theme-Editor.
  # 2. Sonst Popup via Hash #pflege-finder-open (data-pflege-finder-open).
  assign primary_href = section.settings.primary_link | strip
  assign open_popup = false
  if primary_href == blank
    assign primary_href = '#pflege-finder-open'
    assign open_popup = true
  endif

  assign secondary_href = section.settings.secondary_link
  assign show_secondary = false
  if section.settings.secondary_label != blank and secondary_href != blank
    assign show_secondary = true
  endif

  assign finder_bg_url = 'produktfinder1.webp' | asset_url
  assign finder_bg_cb = section.settings.bg_refresh_token | strip
  if finder_bg_cb != blank
    if finder_bg_url contains '?'
      assign finder_bg_url = finder_bg_url | append: '&pflegepf=' | append: finder_bg_cb
    else
      assign finder_bg_url = finder_bg_url | append: '?pflegepf=' | append: finder_bg_cb
    endif
  endif
-%}

<section id="produktfinder" class="pflege-product-finder" {{ section.shopify_attributes }}>
  <div class="pflege-product-finder__backdrop">
    <div class="pflege-product-finder__shell">
      <div
        class="pflege-product-finder__panel"
        style="--pflege-product-finder-bg: url('{{ finder_bg_url }}');"
      >
        <div class="pflege-product-finder__inner">
          {%- if section.settings.heading != blank -%}
            <h2 class="pflege-product-finder__title-on-image">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}
          <div class="pflege-product-finder__stack">
            <div class="pflege-product-finder__lead">
              {%- if section.settings.intro != blank -%}
                <p class="pflege-product-finder__intro">{{ section.settings.intro | escape }}</p>
              {%- endif -%}
            </div>

            <div class="pflege-product-finder__actions pflege-product-finder__actions--center">
              {%- if section.settings.primary_label != blank -%}
                <a
                  class="pflege-product-finder__cta"
                  href="{{ primary_href }}"
                  {% if open_popup %}data-pflege-finder-open{% endif %}
                >
                  {{- section.settings.primary_label | escape -}}
                </a>
              {%- endif -%}
              {%- if show_secondary -%}
                <a class="pflege-product-finder__link-secondary" href="{{ secondary_href }}">
                  {{- section.settings.secondary_label | escape -}}
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PflegeShop Produktfinder",
  "tag": "section",
  "class": "pflege-product-finder-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Hintergrund: Theme-Asset assets/produktfinder1.webp. Nach Bildtausch im Theme: „Cache“-Zahl erhöhen und speichern (CDN/Browser)."
    },
    {
      "type": "text",
      "id": "bg_refresh_token",
      "label": "Hintergrundbild — Cache leeren (Zahl)",
      "default": "1",
      "info": "Nach jedem Austausch von produktfinder1.webp diese Zahl um 1 erhöhen (1→2→3…). Umgeht Browser- und CDN-Zwischenspeicher."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Hauptüberschrift",
      "default": "Nutzen Sie unseren Produktfinder"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Text im Kasten (über dem Button)",
      "default": "Beantworten Sie ein paar Fragen und erhalten Sie sofort passende Pflegeprodukte für Ihre Situation – ganz ohne langes Suchen."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primär-Button — Text",
      "default": "Jetzt das passende Produkt finden"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primär-Button — Link",
      "info": "Leer = Produktfinder-Popup öffnen."
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Sekundär — Text",
      "default": "Mehr erfahren"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Sekundär — Link",
      "info": "Ohne Link ausgefüllt wird der Textlink ausgeblendet."
    }
  ],
  "presets": [
    {
      "name": "PflegeShop Produktfinder"
    }
  ]
}
{% endschema %}

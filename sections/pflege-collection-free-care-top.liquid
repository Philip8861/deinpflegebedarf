{% comment %}
  Kategorie „Kostenfreie Pflegehilfsmittel“ — Hero (wie Startseite), Vorteile, Hinweis vor Produktliste.
{% endcomment %}
{{ 'section-pflege-hero.css' | asset_url | stylesheet_tag }}
{{ 'section-pflege-collection-free-care.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign col_handle = collection.handle | downcase
  assign show_free_care = false
  if col_handle == 'kostenfreie-pflegehilfsmittel' or col_handle == 'pflegehilfsmittel-kostenfrei'
    assign show_free_care = true
  endif
-%}
{%- unless show_free_care -%}
  {%- if request.design_mode -%}
    <div class="page-width" style="padding:1rem 0;color:#6f7f95;font-size:1.1rem;">
      Hinweis: Diese Section ist für die Kollektion „Kostenfreie Pflegehilfsmittel“ gedacht (Handle: kostenfreie-pflegehilfsmittel).
    </div>
  {%- endif -%}
{%- else -%}
  {%- liquid
    assign pfc_config_url = section.settings.configurator_link | strip
    if pfc_config_url == blank
      if pages['pflegebox-konfigurator'] != blank
        assign pfc_config_url = pages['pflegebox-konfigurator'].url
      elsif pages['pflegehilfsmittel-konfigurator'] != blank
        assign pfc_config_url = pages['pflegehilfsmittel-konfigurator'].url
      elsif pages['pflegebox-konfigurieren'] != blank
        assign pfc_config_url = pages['pflegebox-konfigurieren'].url
      else
        assign pfc_config_url = routes.root_url | append: 'pages/pflegebox-konfigurator'
      endif
    endif
    assign pfc_info_url = section.settings.info_link | strip
    if pfc_info_url == blank
      assign pfc_info_url = routes.root_url | append: '#kostenfreie-pflegehilfsmittel'
    endif
  -%}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  {%- liquid
    assign hero_badge = section.settings.badge | strip
    if hero_badge == blank
      assign hero_badge = 'sections.pflege_collection_free_care.hero_badge' | t
    endif
    assign hero_line1 = section.settings.heading_line1
    if hero_line1 == blank
      assign hero_line1 = 'sections.pflege_collection_free_care.hero_h1' | t
    endif
    assign hero_line2 = ''
    assign hero_sub = section.settings.subheading
    if hero_sub == blank
      assign hero_sub = 'sections.pflege_collection_free_care.hero_sub' | t
    endif
    assign hero_btn_label = section.settings.button_label
    if hero_btn_label == blank
      assign hero_btn_label = 'sections.pflege_collection_free_care.cta_configure' | t
    endif
    assign hero_btn_link = section.settings.button_link
    if hero_btn_link == blank
      assign hero_btn_link = pfc_config_url
    endif
    assign hero_secondary_label = section.settings.secondary_button_label
    if hero_secondary_label == blank
      assign hero_secondary_label = 'sections.pflege_collection_free_care.cta_more_info' | t
    endif
    assign hero_secondary_link = section.settings.secondary_button_link
    if hero_secondary_link == blank
      assign hero_secondary_link = pfc_info_url
    endif
    assign hero_img_alt = section.settings.hero_image_alt
    if hero_img_alt == blank
      assign hero_img_alt = 'sections.pflege_collection_free_care.hero_image_alt' | t
    endif
    assign hero_asset_file = 'kostenfreie_pflegehilfsmittel.webp'
    assign hero_title_id = 'pfc-free-care-hero-title-' | append: section.id
  -%}

  <div class="pfc-free-care" id="pfc-free-care-top-{{ section.id }}">
    <section class="pflege-hero pflege-hero--free-care" aria-labelledby="{{ hero_title_id }}">
      <div class="pflege-hero__shell">
        {% render 'pflege-hero-asset-panel',
          asset_file: hero_asset_file,
          image_alt: hero_img_alt,
          badge: hero_badge,
          heading_line1: hero_line1,
          heading_line2: hero_line2,
          subheading: hero_sub,
          button_label: hero_btn_label,
          button_link: hero_btn_link,
          secondary_button_label: hero_secondary_label,
          secondary_button_link: hero_secondary_link,
          title_id: hero_title_id
        %}
      </div>
    </section>

    <div class="pfc-free-care__below section-{{ section.id }}-padding">
      <div class="pfc-free-care__shell page-width">
        <ul class="pfc-free-care__benefits" role="list">
          <li class="pfc-free-care__benefit">
            <span class="pfc-free-care__benefit-icon" aria-hidden="true">
              {% render 'pflege-icon', icon: section.settings.benefit_1_icon, width: 24 %}
            </span>
            <h2 class="pfc-free-care__benefit-title">{{ 'sections.pflege_collection_free_care.benefit_1_title' | t }}</h2>
            <p class="pfc-free-care__benefit-text">{{ 'sections.pflege_collection_free_care.benefit_1_text' | t }}</p>
          </li>
          <li class="pfc-free-care__benefit">
            <span class="pfc-free-care__benefit-icon" aria-hidden="true">
              {% render 'pflege-icon', icon: section.settings.benefit_2_icon, width: 24 %}
            </span>
            <h2 class="pfc-free-care__benefit-title">{{ 'sections.pflege_collection_free_care.benefit_2_title' | t }}</h2>
            <p class="pfc-free-care__benefit-text">{{ 'sections.pflege_collection_free_care.benefit_2_text' | t }}</p>
          </li>
          <li class="pfc-free-care__benefit">
            <span class="pfc-free-care__benefit-icon" aria-hidden="true">
              {% render 'pflege-icon', icon: section.settings.benefit_3_icon, width: 24 %}
            </span>
            <h2 class="pfc-free-care__benefit-title">{{ 'sections.pflege_collection_free_care.benefit_3_title' | t }}</h2>
            <p class="pfc-free-care__benefit-text">{{ 'sections.pflege_collection_free_care.benefit_3_text' | t }}</p>
          </li>
          <li class="pfc-free-care__benefit">
            <span class="pfc-free-care__benefit-icon" aria-hidden="true">
              {% render 'pflege-icon', icon: section.settings.benefit_4_icon, width: 24 %}
            </span>
            <h2 class="pfc-free-care__benefit-title">{{ 'sections.pflege_collection_free_care.benefit_4_title' | t }}</h2>
            <p class="pfc-free-care__benefit-text">{{ 'sections.pflege_collection_free_care.benefit_4_text' | t }}</p>
          </li>
        </ul>

        <aside class="pfc-free-care__pregrid" aria-label="{{ 'sections.pflege_collection_free_care.pregrid_aria' | t }}">
          <p class="pfc-free-care__pregrid-text">{{ 'sections.pflege_collection_free_care.pregrid_text' | t }}</p>
          <a class="pfc-free-care__btn pfc-free-care__btn--compact" href="{{ pfc_config_url | escape }}">
            {{ 'sections.pflege_collection_free_care.cta_check_configure' | t }}
          </a>
        </aside>
      </div>
    </div>
      </div>
{%- endunless -%}

{% schema %}
{
  "name": "PHM Kopfbereich",
  "tag": "section",
  "class": "pfc-free-care-top-section",
  "limit": 1,
  "settings": [
    {
      "type": "paragraph",
      "content": "Hero-Kachel und Typografie wie Startseiten-Hero (startseite_main.webp). Bild: kostenfreie_pflegehilfsmittel.webp"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge (wie Startseiten-Hero)",
      "default": "Kostenfreie Pflegehilfsmittel ab Pflegegrad 1"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Überschrift",
      "default": "Wussten Sie schon?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Text",
      "default": "Viele Produkte aus unserem Shop müssen Sie nicht selbst bezahlen. Ab Pflegegrad 1 können Sie Pflegehilfsmittel im Wert von bis zu 42 € monatlich kostenlos über die Pflegekasse erhalten."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button primär",
      "default": "Jetzt konfigurieren"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link primärer Button",
      "info": "Leer = Pflegebox-Konfigurator"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Button sekundär",
      "default": "Weitere Infos"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Link sekundärer Button",
      "info": "Leer = Homepage-Abschnitt Mehr Infos"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Alt-Text Bild",
      "default": "Kostenfreie Pflegehilfsmittel für die häusliche Pflege"
    },
    {
      "type": "url",
      "id": "configurator_link",
      "label": "Link Pflegebox-Konfigurator"
    },
    {
      "type": "url",
      "id": "info_link",
      "label": "Link „Mehr Infos“ (Homepage-Abschnitt)",
      "info": "Leer = Startseite mit Anker #kostenfreie-pflegehilfsmittel"
    },
    {
      "type": "select",
      "id": "benefit_1_icon",
      "label": "Icon Vorteil 1",
      "options": [
        { "value": "euro", "label": "Euro" },
        { "value": "ticket", "label": "Ticket" },
        { "value": "badge-check", "label": "Häkchen" }
      ],
      "default": "euro"
    },
    {
      "type": "select",
      "id": "benefit_2_icon",
      "label": "Icon Vorteil 2",
      "options": [
        { "value": "user", "label": "Person" },
        { "value": "heart", "label": "Herz" },
        { "value": "shield", "label": "Schutz" }
      ],
      "default": "user"
    },
    {
      "type": "select",
      "id": "benefit_3_icon",
      "label": "Icon Vorteil 3",
      "options": [
        { "value": "rotate-ccw", "label": "Wiederholung" },
        { "value": "document", "label": "Dokument" },
        { "value": "clock", "label": "Uhr" }
      ],
      "default": "rotate-ccw"
    },
    {
      "type": "select",
      "id": "benefit_4_icon",
      "label": "Icon Vorteil 4",
      "options": [
        { "value": "headset", "label": "Service" },
        { "value": "package", "label": "Paket" },
        { "value": "badge-check", "label": "Häkchen" }
      ],
      "default": "headset"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Abstand unter dem Hero",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 28
    }
  ],
  "presets": [{ "name": "PHM Kopfbereich" }]
}
{% endschema %}

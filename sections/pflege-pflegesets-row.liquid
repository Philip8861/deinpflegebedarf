{{ 'section-pflege-pflegesets-row.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign ha = section.settings.handle_1 | default: 'pflegeset-grosse-s' | strip
  assign hb = section.settings.handle_2 | default: 'pflegeset-grosse-l' | strip
  assign hc = section.settings.handle_3 | default: 'pflegeset-grosse-m' | strip
  assign handle_joined = ha | append: '|||' | append: hb | append: '|||' | append: hc
  assign pflegeset_handles = handle_joined | split: '|||'
  assign badge_label = section.settings.badge_text | strip
  if badge_label == blank
    assign badge_label = shop.metafields.pflegeshop.pflegesets_badge.value | strip
  endif
  if badge_label == blank
    assign badge_label = 'Sie sparen 10%'
  endif
  assign pflege_col = section.settings.pflegesets_collection
  assign use_collection = false
  if pflege_col != blank and pflege_col.all_products_count > 0
    assign use_collection = true
  endif
-%}

<section class="pflege-pflegesets" {{ section.shopify_attributes }}>
  <div class="pflege-pflegesets__shell">
    <div class="pflege-pflegesets__panel">
      {%- if section.settings.heading != blank -%}
        <h2 class="pflege-pflegesets__title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      <div class="pflege-pflegesets__grid">
        {%- if use_collection -%}
          {%- comment -%} Zuverlässig wie Bestseller: Produkte kommen aus der Kollektion (volle Medien){%- endcomment -%}
          {%- for card_product in pflege_col.products limit: 3 -%}
            {%- capture slot_contents -%}
              {%- render 'pflege-pflegeset-resolve-contents', slot: forloop.index -%}
            {%- endcapture -%}
            {%- assign slot_contents = slot_contents | strip -%}
            {%- liquid
              assign disp_title = ''
              case forloop.index
                when 1
                  assign disp_title = section.settings.display_title_1 | strip
                when 2
                  assign disp_title = section.settings.display_title_2 | strip
                when 3
                  assign disp_title = section.settings.display_title_3 | strip
              endcase
            -%}
            {% render 'pflege-pflegeset-card',
              card_product: card_product,
              handle_fallback: card_product.handle,
              badge_label: badge_label,
              card_contents: slot_contents,
              card_title: disp_title
            %}
          {%- endfor -%}
        {%- else -%}
          {%- for handle_raw in pflegeset_handles -%}
            {%- assign handle = handle_raw | strip -%}
            {%- liquid
              assign card_product = nil
              case forloop.index
                when 1
                  if section.settings.product_1 != blank
                    assign card_product = section.settings.product_1
                  endif
                when 2
                  if section.settings.product_2 != blank
                    assign card_product = section.settings.product_2
                  endif
                when 3
                  if section.settings.product_3 != blank
                    assign card_product = section.settings.product_3
                  endif
              endcase

              if card_product == blank
                assign card_product = all_products[handle]
              endif
              if card_product == blank
                assign alt_h = handle | replace: 'grosse', 'groesse'
                if alt_h != handle
                  assign card_product = all_products[alt_h]
                endif
              endif
              if card_product == blank
                assign alt_h = handle | replace: 'groesse', 'grosse'
                if alt_h != handle
                  assign card_product = all_products[alt_h]
                endif
              endif
            -%}
            {%- capture slot_contents -%}
              {%- render 'pflege-pflegeset-resolve-contents', slot: forloop.index -%}
            {%- endcapture -%}
            {%- assign slot_contents = slot_contents | strip -%}
            {%- liquid
              assign disp_title = ''
              case forloop.index
                when 1
                  assign disp_title = section.settings.display_title_1 | strip
                when 2
                  assign disp_title = section.settings.display_title_2 | strip
                when 3
                  assign disp_title = section.settings.display_title_3 | strip
              endcase
            -%}
            {% render 'pflege-pflegeset-card',
              card_product: card_product,
              handle_fallback: handle,
              badge_label: badge_label,
              card_contents: slot_contents,
              card_title: disp_title
            %}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PflegeShop Pflegesets",
  "tag": "section",
  "class": "pflege-pflegesets-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Enthaltene Artikel: Wenn die Textfelder leer sind (z. B. nach theme push ohne index.json), erscheinen automatisch die festen Listen aus dem Theme-Snippet. Optional persistenter Text im Admin unter Einstellungen → Benutzerdefinierte Daten → Shop: Metafelder im Namensraum „pflegeshop“ mit den Schlüsseln pflegesets_contents_1, _2, _3 (mehrzeilig) und optional pflegesets_badge — die bleiben beim Theme-Upload erhalten. Bilder: veröffentlichte Produkte mit Bild / Kollektion wählen."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Sparen Sie nicht nur Zeit, sondern auch Geld! Entdecken Sie unsere 3 Pflegesets, die perfekt zu Ihrer Pflegesituation passen"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Hinweis (oben rechts auf dem Bild)",
      "default": "Sie sparen 10%",
      "info": "Leer = Shop-Metafeld pflegesets_badge (Namensraum pflegeshop) oder Standard „Sie sparen 10%“."
    },
    {
      "type": "text",
      "id": "display_title_1",
      "label": "Anzeigename — Kachel 1",
      "default": "Pflegebox Set Größe S",
      "info": "Überschreibt den Produktnamen nur auf dieser Kachel (Preis-Link bleibt zum Produkt)."
    },
    {
      "type": "text",
      "id": "display_title_2",
      "label": "Anzeigename — Kachel 2",
      "default": "Pflegebox Set Größe L"
    },
    {
      "type": "text",
      "id": "display_title_3",
      "label": "Anzeigename — Kachel 3",
      "default": "Pflegebox Set Größe M"
    },
    {
      "type": "textarea",
      "id": "contents_1",
      "label": "Enthaltene Artikel — Kachel 1 (unter dem Namen)",
      "default": "• Tiga Soft Einlagen Gr. S (16 Stück)\n• Sensiderm Barriercreme (75 ml)\n• Mildes Waschgel ohne Parfum (250 ml)\n• Nitril-Einmalhandschuhe (10 Paar)\n• All-in-One Feuchttücher (48 Stück)",
      "info": "Pro Zeile ein Artikel. Leer lassen = Shop-Metafeld (pflegeshop.pflegesets_contents_1) oder feste Theme-Vorlage."
    },
    {
      "type": "textarea",
      "id": "contents_2",
      "label": "Enthaltene Artikel — Kachel 2",
      "default": "• Comfort Plus Inkontinenzhosen Gr. L (14 Stück)\n• Pflegebad-Öl beruhigend (200 ml)\n• Hautmilch rückfettend (400 ml)\n• Zellstoff-Vliesunterlagen (30 Stück)\n• Mundhygiene-Sticks einzeln verpackt (12 Stück)",
      "info": "Pro Zeile ein Artikel. Leer = Shop-Metafeld pflegesets_contents_2 oder Theme-Vorlage."
    },
    {
      "type": "textarea",
      "id": "contents_3",
      "label": "Enthaltene Artikel — Kachel 3",
      "default": "• Super-Saugvorlagen Gr. M (18 Stück)\n• Zinkpaste für gereizte Haut (100 g)\n• Desinfektionsreiniger für Oberflächen (500 ml)\n• Betteinlage Frottee waschbar (1 Stück)\n• Körperlotion unparfümiert (300 ml)",
      "info": "Pro Zeile ein Artikel. Leer = Shop-Metafeld pflegesets_contents_3 oder Theme-Vorlage."
    },
    {
      "type": "collection",
      "id": "pflegesets_collection",
      "label": "Kollektion mit den Pflegesets (empfohlen)",
      "info": "Zeigt die ersten drei Artikel dieser Kollektion — umgeht all_products/Handle-Probleme. Leer = Handles / Produktauswahl unten."
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Produkt Kachel 1",
      "info": "Wenn keine Kollektion: Produkt wählen oder Handle unten."
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Produkt Kachel 2",
      "info": "Wenn keine Kollektion: Produkt wählen oder Handle unten."
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Produkt Kachel 3",
      "info": "Wenn keine Kollektion: Produkt wählen oder Handle unten."
    },
    {
      "type": "text",
      "id": "handle_1",
      "label": "Handle Kachel 1 (ohne Kollektion/Produkt)",
      "default": "pflegeset-grosse-s",
      "info": "Exakt wie in der Produkt-URL (z. B. pflegeset-grosse-s)."
    },
    {
      "type": "text",
      "id": "handle_2",
      "label": "Handle Kachel 2",
      "default": "pflegeset-grosse-l",
      "info": "Exakt wie in der Produkt-URL."
    },
    {
      "type": "text",
      "id": "handle_3",
      "label": "Handle Kachel 3",
      "default": "pflegeset-grosse-m",
      "info": "Exakt wie in der Produkt-URL."
    }
  ],
  "presets": [
    {
      "name": "Pflegesets (3 Kacheln)"
    }
  ]
}
{% endschema %}

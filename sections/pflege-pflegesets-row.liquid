{{ 'section-pflege-pflegesets-row.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign ha = section.settings.handle_1 | default: 'pflegeset-grosse-s' | strip
  assign hb = section.settings.handle_2 | default: 'pflegeset-grosse-l' | strip
  assign hc = section.settings.handle_3 | default: 'pflegeset-grosse-m' | strip
  assign handle_joined = ha | append: '|||' | append: hb | append: '|||' | append: hc
  assign pflegeset_handles = handle_joined | split: '|||'
  assign badge_label = section.settings.badge_text | default: 'Sie sparen 10%' | strip
-%}

<section class="pflege-pflegesets" {{ section.shopify_attributes }}>
  <div class="pflege-pflegesets__shell">
    <div class="pflege-pflegesets__panel">
      {%- if section.settings.heading != blank -%}
        <h2 class="pflege-pflegesets__title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      <div class="pflege-pflegesets__grid">
        {%- for handle_raw in pflegeset_handles -%}
          {%- assign handle = handle_raw | strip -%}
          {%- assign card_product = all_products[handle] -%}
          {%- if card_product != blank -%}
            {%- assign card_href = card_product.url -%}
            {%- assign card_label = card_product.title -%}
            {%- assign card_variant = card_product.selected_or_first_available_variant -%}
          {%- else -%}
            {%- assign card_href = '/products/' | append: handle -%}
            {%- assign card_label = handle | replace: '-', ' ' -%}
            {%- assign card_variant = nil -%}
          {%- endif -%}
          <article class="pflege-pflegesets__card">
            <a class="pflege-pflegesets__media-link" href="{{ card_href }}">
              <span class="pflege-pflegesets__media">
                {%- if badge_label != blank -%}
                  <span class="pflege-pflegesets__badge">{{ badge_label | escape }}</span>
                {%- endif -%}
                {%- liquid
                  assign pflegesets_img = nil
                  assign pflegesets_img_alt = card_label
                  if card_product != blank
                    if card_product.featured_media != blank
                      assign pflegesets_img = card_product.featured_media
                    elsif card_product.featured_image != blank
                      assign pflegesets_img = card_product.featured_image
                    elsif card_product.selected_or_first_available_variant.image != blank
                      assign pflegesets_img = card_product.selected_or_first_available_variant.image
                    endif
                  endif
                -%}
                {%- if pflegesets_img != blank -%}
                  {{
                    pflegesets_img
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      widths: '400, 600, 800',
                      sizes: '(min-width: 990px) 20vw, (min-width: 750px) 23vw, 70vw',
                      alt: pflegesets_img_alt,
                      class: 'pflege-pflegesets__img'
                  }}
                {%- else -%}
                  {{ 'product-apparel-2' | placeholder_svg_tag: 'pflege-pflegesets__placeholder' }}
                {%- endif -%}
              </span>
            </a>

            <div class="pflege-pflegesets__body">
              <a class="pflege-pflegesets__name-link" href="{{ card_href }}">{{ card_label | escape }}</a>

              {%- if card_product != blank -%}
                <div class="pflege-pflegesets__price">
                  {% if settings.currency_code_enabled %}
                    {{ card_product.price_min | money_with_currency }}
                  {% else %}
                    {{ card_product.price_min | money }}
                  {% endif %}
                </div>
                <p class="pflege-pflegesets__rating">
                  <span class="pflege-pflegesets__stars" aria-hidden="true">★★★★★</span>
                </p>
              {%- else -%}
                <div class="pflege-pflegesets__price">—</div>
                <p class="pflege-pflegesets__rating">
                  <span class="pflege-pflegesets__stars" aria-hidden="true">★★★★★</span>
                </p>
              {%- endif -%}
            </div>

            {%- if card_variant != nil and card_variant.available -%}
              <button
                type="button"
                class="pflege-pflegesets__cart"
                data-variant-id="{{ card_variant.id }}"
                aria-label="{{ 'products.product.add_to_cart' | t }} — {{ card_label | escape }}"
              >
                {% render 'pflege-icon', icon: 'cart', width: 20 %}
              </button>
            {%- elsif card_href != blank -%}
              <a
                href="{{ card_href }}"
                class="pflege-pflegesets__cart pflege-pflegesets__cart--fallback"
                aria-label="{{ 'products.product.view_full_details' | t }} — {{ card_label | escape }}"
              >
                {% render 'pflege-icon', icon: 'cart', width: 20 %}
              </a>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PflegeShop Pflegesets",
  "tag": "section",
  "class": "pflege-pflegesets-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Jetzt Sparen mit unseren Pflegesets"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Hinweis (oben rechts auf dem Bild)",
      "default": "Sie sparen 10%"
    },
    {
      "type": "text",
      "id": "handle_1",
      "label": "Produkt-Handle (Kachel 1)",
      "default": "pflegeset-grosse-s",
      "info": "Technischer Name aus der Produkt-URL, z. B. pflegeset-grosse-s"
    },
    {
      "type": "text",
      "id": "handle_2",
      "label": "Produkt-Handle (Kachel 2)",
      "default": "pflegeset-grosse-l",
      "info": "Technischer Name aus der Produkt-URL, z. B. pflegeset-grosse-l"
    },
    {
      "type": "text",
      "id": "handle_3",
      "label": "Produkt-Handle (Kachel 3)",
      "default": "pflegeset-grosse-m",
      "info": "Technischer Name aus der Produkt-URL, z. B. pflegeset-grosse-m"
    }
  ],
  "presets": [
    {
      "name": "Pflegesets (3 Kacheln)"
    }
  ]
}
{% endschema %}

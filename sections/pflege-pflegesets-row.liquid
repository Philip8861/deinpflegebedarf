{{ 'section-pflege-pflegesets-row.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign card_style = section.settings.card_style | default: 'promo'
  assign pfs_heading = section.settings.heading | strip
  assign pfs_sub = section.settings.subheading | strip
  if pfs_sub == blank and pfs_heading contains ' Entdecken Sie '
    assign pfs_heading_parts = pfs_heading | split: ' Entdecken Sie '
    assign pfs_heading = pfs_heading_parts | first | strip
    assign pfs_tail = pfs_heading_parts | last | strip
    assign pfs_sub = 'Entdecken Sie ' | append: pfs_tail
  endif
-%}

{%- if card_style == 'category' -%}
  {{ 'section-pflege-category-filtered.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<section class="pflege-pflegesets{% if card_style == 'category' %} pflege-pflegesets--category{% endif %}" {{ section.shopify_attributes }}>
  <div class="pflege-pflegesets__shell">
    <div class="pflege-pflegesets__panel">
      {%- if pfs_heading != blank or pfs_sub != blank -%}
        <header class="pflege-pflegesets__head">
          {%- if pfs_heading != blank -%}
            <h2 class="pflege-pflegesets__title">
              {{- pfs_heading | strip | escape | replace: 'sondern auch', 'sondern&nbsp;auch' | newline_to_br -}}
            </h2>
          {%- endif -%}
          {%- if pfs_sub != blank -%}
            <p class="pflege-pflegesets__sub">{{ pfs_sub | escape | newline_to_br }}</p>
          {%- endif -%}
        </header>
      {%- endif -%}

      <div class="pflege-pflegesets__grid">
        {% render 'pflege-pflegesets-grid',
          pfs_section: section,
          card_style: card_style
        %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PflegeShop Pflegesets",
  "tag": "section",
  "class": "pflege-pflegesets-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Datenquelle: Kollektion „pflegesets“ mit 3 Set-Produkten (S, L, M). Gleiche Kollektion wie auf der Pflegesets-Seite. Promo-Kacheln = Startseite mit Inhaltsliste. Kategorie-Karten = wie Kategorieseiten."
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Kachel-Stil",
      "options": [
        { "value": "promo", "label": "Promo-Kacheln (Startseite)" },
        { "value": "category", "label": "Wie Kategorieseiten" }
      ],
      "default": "promo"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Überschrift (2 Zeilen möglich: Enter = Zeilenwechsel)",
      "default": "Sparen Sie nicht nur Zeit, sondern\u00a0auch\nGeld!",
      "info": "Zweizeilig: erste Zeile bis „…auch“ (Wörter „sondern“ und „auch“ bleiben zusammen), zweite Zeile „Geld!“."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Text darunter (gedämpfter, mittig)",
      "default": "Entdecken Sie unsere 3 Pflegesets, die perfekt zu Ihrer Pflegesituation passen"
    },
    {
      "type": "collection",
      "id": "pflegesets_collection",
      "label": "Kollektion mit den 3 Pflegesets",
      "info": "Handle empfohlen: pflegesets — Pflicht für zuverlässige Produktbilder."
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Hinweis auf dem Bild (nur Promo-Kacheln)",
      "default": "Sie sparen 10%",
      "info": "Leer = Shop-Metafeld pflegesets_badge oder Standard „Sie sparen 10%“."
    },
    {
      "type": "text",
      "id": "display_title_1",
      "label": "Anzeigename — Kachel 1",
      "default": "Pflegebox Set Größe S"
    },
    {
      "type": "text",
      "id": "display_title_2",
      "label": "Anzeigename — Kachel 2",
      "default": "Pflegebox Set Größe L"
    },
    {
      "type": "text",
      "id": "display_title_3",
      "label": "Anzeigename — Kachel 3",
      "default": "Pflegebox Set Größe M"
    },
    {
      "type": "textarea",
      "id": "contents_1",
      "label": "Enthaltene Artikel — Kachel 1 (nur Promo)",
      "default": "• Tiga Soft Einlagen Gr. S (16 Stück)\n• Sensiderm Barriercreme (75 ml)\n• Mildes Waschgel ohne Parfum (250 ml)\n• Nitril-Einmalhandschuhe (10 Paar)\n• All-in-One Feuchttücher (48 Stück)"
    },
    {
      "type": "textarea",
      "id": "contents_2",
      "label": "Enthaltene Artikel — Kachel 2 (nur Promo)",
      "default": "• Comfort Plus Inkontinenzhosen Gr. L (14 Stück)\n• Pflegebad-Öl beruhigend (200 ml)\n• Hautmilch rückfettend (400 ml)\n• Zellstoff-Vliesunterlagen (30 Stück)\n• Mundhygiene-Sticks einzeln verpackt (12 Stück)"
    },
    {
      "type": "textarea",
      "id": "contents_3",
      "label": "Enthaltene Artikel — Kachel 3 (nur Promo)",
      "default": "• Super-Saugvorlagen Gr. M (18 Stück)\n• Zinkpaste für gereizte Haut (100 g)\n• Desinfektionsreiniger für Oberflächen (500 ml)\n• Betteinlage Frottee waschbar (1 Stück)\n• Körperlotion unparfümiert (300 ml)"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Produkt Kachel 1 (Fallback)"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Produkt Kachel 2 (Fallback)"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Produkt Kachel 3 (Fallback)"
    },
    {
      "type": "text",
      "id": "handle_1",
      "label": "Handle Kachel 1",
      "default": "pflegeset-grosse-s"
    },
    {
      "type": "text",
      "id": "handle_2",
      "label": "Handle Kachel 2",
      "default": "pflegeset-grosse-l"
    },
    {
      "type": "text",
      "id": "handle_3",
      "label": "Handle Kachel 3",
      "default": "pflegeset-grosse-m"
    }
  ],
  "presets": [
    {
      "name": "Pflegesets (3 Kacheln)"
    }
  ]
}
{% endschema %}

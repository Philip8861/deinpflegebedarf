{{ 'section-pflege-service-bar.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .pflege-service-bar__logo-img {
    max-height: {{ section.settings.logo_max_height }}px;
    width: auto;
    height: auto;
  }
{%- endstyle -%}

<section class="pflege-service-bar" aria-label="Service-Hinweise">
  <div class="pflege-service-bar__inner page-width">
    {%- if section.settings.show_logo -%}
      <div class="pflege-service-bar__brand">
        <a href="{{ routes.root_url }}" class="pflege-service-bar__logo-link focus-inset">
          {%- if settings.logo != blank -%}
            {%- liquid
              assign logo_alt = settings.logo.alt | default: shop.name | escape
              assign logo_h = section.settings.logo_max_height
              assign logo_w = logo_h | times: settings.logo.aspect_ratio | round
            -%}
            {{
              settings.logo
              | image_url: width: 600
              | image_tag:
                class: 'pflege-service-bar__logo-img',
                widths: '120, 180, 240, 360, 480, 600',
                height: logo_h,
                width: logo_w,
                alt: logo_alt,
                loading: 'lazy'
            }}
          {%- else -%}
            <span class="pflege-service-bar__logo-fallback">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>
    {%- endif -%}
    <div class="pflege-service-bar__track">
    {%- for block in section.blocks -%}
      <div class="pflege-service-bar__item" {{ block.shopify_attributes }}>
        <span class="pflege-service-bar__body">
          {% render 'pflege-icon', icon: block.settings.icon, width: 20 %}
          {%- if block.settings.link != blank -%}
            <a
              href="{{ block.settings.link }}"
              class="pflege-service-bar__text pflege-service-bar__link{% if block.settings.link contains 'tel:' %} pflege-service-bar__link--tel{% endif %}"
              {% if block.settings.link contains 'tel:' %}
                aria-label="{{ block.settings.text | escape }} — Anrufen"
              {% endif %}
            >
              {{- block.settings.text | escape -}}
            </a>
          {%- else -%}
            <span class="pflege-service-bar__text">{{ block.settings.text | escape }}</span>
          {%- endif -%}
        </span>
      </div>
    {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PflegeShop Service-Leiste",
  "tag": "section",
  "class": "pflege-service-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Logo in dieser Leiste",
      "default": true,
      "info": "Nutzt das Bild unter Theme-Einstellungen → Logo (gleiche Datei wie im Hauptheader). Dort oder über „Theme anpassen“ hochladen — nicht zwingend als Datei im Theme-Ordner."
    },
    {
      "type": "range",
      "id": "logo_max_height",
      "min": 22,
      "max": 52,
      "step": 2,
      "unit": "px",
      "label": "Maximale Logo-Höhe",
      "default": 34
    }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "item",
      "name": "Hinweis",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Versand" },
            { "value": "document", "label": "Dokument" },
            { "value": "star", "label": "Stern" },
            { "value": "headset", "label": "Support" },
            { "value": "shield", "label": "Schutz" },
            { "value": "package", "label": "Paket" }
          ],
          "default": "package"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Kostenloser Versand ab 150 €"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link optional",
          "info": "Telefon: z. B. tel:+4983349893330 — dann ist die Zeile antippbar zum Anrufen."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PflegeShop Service-Leiste",
      "settings": {
        "show_logo": true,
        "logo_max_height": 34
      },
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "truck",
            "text": "Kostenloser Versand ab 150 €"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "document",
            "text": "Kauf auf Rechnung"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "star",
            "text": "Über 10.000 zufriedene Kunden"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "headset",
            "text": "Persönliche Beratung 08334 / 9893330",
            "link": "tel:+4983349893330"
          }
        }
      ]
    }
  ]
}
{% endschema %}

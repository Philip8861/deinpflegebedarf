{{ 'section-pflege-service-bar.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Inline per Section-ID: höchste Spezifität, kein Safe-Area-Padding (war Hauptursache für dicken Balken auf Mobil).
{%- endcomment -%}
<style id="pflege-service-bar-critical-{{ section.id }}">
  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} .pflege-service-bar {
    margin: 0 !important;
    padding: 0 !important;
    height: 31px !important;
    max-height: 31px !important;
    min-height: 0 !important;
    overflow: hidden !important;
    box-sizing: border-box !important;
    background-color: #f0f5fb !important;
    line-height: 0 !important;
  }

  #shopify-section-{{ section.id }} .pflege-service-bar__inner.page-width {
    box-sizing: border-box !important;
    height: 30px !important;
    max-height: 30px !important;
    min-height: 0 !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    padding-left: max(1rem, env(safe-area-inset-left, 0px)) !important;
    padding-right: max(1rem, env(safe-area-inset-right, 0px)) !important;
    margin: 0 auto !important;
    display: flex !important;
    align-items: center !important;
    flex-wrap: nowrap !important;
    overflow-x: auto !important;
    overflow-y: hidden !important;
    scrollbar-width: none !important;
    line-height: normal !important;
    gap: 0.45rem clamp(0.65rem, 3vw, 1.75rem) !important;
  }

  #shopify-section-{{ section.id }} .pflege-service-bar__item {
    flex: 0 0 auto !important;
    max-height: 16px !important;
    line-height: 16px !important;
  }

  #shopify-section-{{ section.id }} .pflege-service-bar__body,
  #shopify-section-{{ section.id }} .pflege-service-bar__text,
  #shopify-section-{{ section.id }} a.pflege-service-bar__link {
    font-size: 14px !important;
    line-height: 16px !important;
    max-height: 16px !important;
    font-weight: 500 !important;
    white-space: nowrap !important;
    opacity: 1 !important;
    visibility: visible !important;
    color: rgba(11, 35, 71, 0.88) !important;
    animation: none !important;
    transform: none !important;
    filter: none !important;
  }

  #shopify-section-{{ section.id }} .pflege-service-bar__body .pflege-icon,
  #shopify-section-{{ section.id }} .pflege-service-bar__body .pflege-icon svg {
    width: 16px !important;
    height: 16px !important;
    max-height: 16px !important;
  }
</style>

<section class="pflege-service-bar" aria-label="Service-Hinweise" style="height:31px;max-height:31px;overflow:hidden;margin:0;padding:0;box-sizing:border-box;">
  <div
    class="pflege-service-bar__inner page-width"
    style="height:30px;max-height:30px;min-height:0;padding:0;margin:0 auto;overflow-x:auto;overflow-y:hidden;box-sizing:border-box;display:flex;align-items:center;flex-wrap:nowrap;line-height:normal;"
  >
    {%- for block in section.blocks -%}
      <div class="pflege-service-bar__item" {{ block.shopify_attributes }}>
        <span class="pflege-service-bar__body" style="font-size:14px;line-height:16px;display:inline-flex;align-items:center;gap:6px;white-space:nowrap;margin:0;padding:0;color:rgba(11,35,71,0.88);opacity:1;visibility:visible;">
          {% render 'pflege-icon', icon: block.settings.icon, width: 16 %}
          {%- if block.settings.subtext != blank -%}
            {%- if block.settings.link != blank -%}
              <a
                href="{{ block.settings.link }}"
                class="pflege-service-bar__copy pflege-service-bar__link{% if block.settings.link contains 'tel:' %} pflege-service-bar__link--tel{% endif %}"
                style="font-size:14px;line-height:16px;margin:0;padding:0;color:rgba(11,35,71,0.88);"
                {% if block.settings.link contains 'tel:' %}
                  aria-label="{{ block.settings.text | escape }} — {{ block.settings.subtext | escape }} — Anrufen"
                {% endif %}
              >
                <span class="pflege-service-bar__line pflege-service-bar__line--main">{{ block.settings.text | escape }}</span>
                <span class="pflege-service-bar__line pflege-service-bar__line--sub">{{ block.settings.subtext | escape }}</span>
              </a>
            {%- else -%}
              <span class="pflege-service-bar__copy" style="font-size:14px;line-height:16px;margin:0;padding:0;">
                <span class="pflege-service-bar__line pflege-service-bar__line--main">{{ block.settings.text | escape }}</span>
                <span class="pflege-service-bar__line pflege-service-bar__line--sub">{{ block.settings.subtext | escape }}</span>
              </span>
            {%- endif -%}
          {%- elsif block.settings.link != blank -%}
            <a
              href="{{ block.settings.link }}"
              class="pflege-service-bar__text pflege-service-bar__link{% if block.settings.link contains 'tel:' %} pflege-service-bar__link--tel{% endif %}"
              style="font-size:14px;line-height:16px;margin:0;padding:0;color:rgba(11,35,71,0.88);"
              {% if block.settings.link contains 'tel:' %}
                aria-label="{{ block.settings.text | escape }} — Anrufen"
              {% endif %}
            >
              {{- block.settings.text | escape -}}
            </a>
          {%- else -%}
            <span class="pflege-service-bar__text" style="font-size:14px;line-height:16px;margin:0;padding:0;color:rgba(11,35,71,0.88);">{{ block.settings.text | escape }}</span>
          {%- endif -%}
        </span>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "PflegeShop Service-Leiste",
  "tag": "section",
  "class": "pflege-service-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "max_blocks": 6,
  "blocks": [
    {
      "type": "item",
      "name": "Hinweis",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Versand" },
            { "value": "document", "label": "Dokument" },
            { "value": "rotate-ccw", "label": "Rückgabe (Pfeil)" },
            { "value": "star", "label": "Stern" },
            { "value": "headset", "label": "Support" },
            { "value": "shield", "label": "Schutz" },
            { "value": "package", "label": "Paket" }
          ],
          "default": "package"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Kostenloser Versand ab 150 €"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Unterzeile optional",
          "info": "Kleinere zweite Zeile unter dem Haupttext (z. B. „Schnell bei Ihnen“)."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link optional",
          "info": "Telefon: z. B. tel:+4977339488820 — dann ist die Zeile antippbar zum Anrufen."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PflegeShop Service-Leiste",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "truck",
            "text": "Schneller Versand in 1–2 Tagen"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "headset",
            "text": "Persönliche Beratung 07733 / 9488820",
            "link": "tel:+4977339488820"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "document",
            "text": "Kostenübernahme mit Rezept möglich"
          }
        }
      ]
    }
  ]
}
{% endschema %}

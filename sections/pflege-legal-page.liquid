{{ 'section-pflege-legal-page.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign root = routes.root_url

  assign url_agb = root | append: 'pages/agb'

  assign url_datenschutz = root | append: 'pages/datenschutzerklaerung'

  assign url_widerruf = root | append: 'pages/widerrufsbelehrung'
  assign url_impressum = root | append: 'pages/impressum'

  assign current_handle = ''
  if page != blank and page.handle != blank
    assign current_handle = page.handle
  endif

  assign legal_eyebrow = section.settings.eyebrow
  assign legal_subtitle = section.settings.subtitle
  assign legal_title_fallback = section.settings.title_fallback
  assign legal_meta_date = section.settings.meta_date
  assign legal_highlight_title = section.settings.highlight_title
  assign legal_highlight_text = section.settings.highlight_text
  assign legal_contact_title = section.settings.contact_title
  assign legal_contact_text = section.settings.contact_text
  assign legal_show_toc = section.settings.show_toc
  assign legal_show_related = section.settings.show_related
  assign legal_toc_title = section.settings.toc_title
  assign legal_related_title = section.settings.related_title
  assign legal_plain = false
  assign legal_use_impressum_defaults = false
  assign legal_use_agb_defaults = false

  if current_handle == 'impressum'
    assign legal_use_impressum_defaults = true
    assign legal_plain = true
  elsif current_handle == 'agb'
    assign legal_use_agb_defaults = true
    assign legal_plain = true
  elsif current_handle == 'widerrufsbelehrung' or current_handle == 'widerrufsrecht' or current_handle contains 'widerruf'
    assign legal_plain = true
  elsif current_handle == 'datenschutz' or current_handle contains 'datenschutz'
    assign legal_plain = true
  elsif current_handle == 'versand-zahlung' or current_handle contains 'versand'
    assign legal_plain = true
  endif

  assign url_kontakt = root | append: 'pages/kontakt'

  if legal_title_fallback == blank
    case current_handle
      when 'impressum'
        assign legal_title_fallback = 'Impressum'
      when 'agb'
        assign legal_title_fallback = 'Allgemeine Geschäftsbedingungen'
      when 'widerrufsbelehrung'
        assign legal_title_fallback = 'Widerrufsbelehrung'
      when 'widerrufsrecht'
        assign legal_title_fallback = 'Widerrufsbelehrung'
      when 'datenschutz'
        assign legal_title_fallback = 'Datenschutzerklärung'
      when 'datenschutzerklärung'
        assign legal_title_fallback = 'Datenschutzerklärung'
      when 'datenschutzerklaerung'
        assign legal_title_fallback = 'Datenschutzerklärung'
      when 'versand-zahlung'
        assign legal_title_fallback = 'Versand & Zahlung'
      when 'vertrag-widerrufen'
        assign legal_title_fallback = 'Vertrag widerrufen'
    endcase
  endif

  if current_handle == 'vertrag-widerrufen'
    assign legal_title_fallback = 'Vertrag widerrufen'
  endif

  assign legal_body_html = section.settings.body_text
  assign legal_use_impressum_body = false
  assign legal_use_agb_body = false
  assign legal_use_widerrufsbelehrung_body = false
  assign legal_use_datenschutz_body = false
  assign legal_use_versand_zahlung_body = false
  assign show_withdrawal_form = false
  assign withdrawal_standalone = false
  assign withdrawal_page_only = false
  assign shipping_standard = section.settings.shipping_standard_cost
  assign shipping_free_from = section.settings.shipping_free_from
  if legal_body_html == blank and legal_use_impressum_defaults
    assign legal_use_impressum_body = true
  endif
  if legal_body_html == blank and legal_use_agb_defaults
    assign legal_use_agb_body = true
  endif
  if current_handle == 'widerrufsbelehrung' and legal_body_html == blank
    assign legal_use_widerrufsbelehrung_body = true
  endif
  if current_handle == 'widerrufsrecht' and legal_body_html == blank
    assign legal_use_widerrufsbelehrung_body = true
  endif
  if legal_body_html == blank
    if current_handle == 'datenschutz' or current_handle == 'datenschutzerklärung' or current_handle == 'datenschutzerklaerung' or current_handle contains 'datenschutz'
      assign legal_use_datenschutz_body = true
    elsif current_handle == 'versand-zahlung'
      assign legal_use_versand_zahlung_body = true
    endif
  endif

  if current_handle == 'vertrag-widerrufen'
    assign legal_plain = true
    assign show_withdrawal_form = true
    assign withdrawal_standalone = true
    assign withdrawal_page_only = true
    assign legal_title_fallback = 'Vertrag widerrufen'
  endif

  if legal_plain
    assign legal_padding_class = 'pflege-legal--page-pad'
  else
    assign legal_padding_class = 'section-' | append: section.id | append: '-padding'
  endif
-%}

{%- unless legal_plain -%}
  <script src="{{ 'pflege-legal-page.js' | asset_url }}" defer></script>
{%- endunless -%}

{%- unless legal_plain -%}
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
{%- endunless -%}

{% render 'pflege-legal-page-view',
  padding_class: legal_padding_class,
  color_scheme: section.settings.color_scheme,
  meta_label: section.settings.meta_label,
  legal_eyebrow: legal_eyebrow,
  legal_subtitle: legal_subtitle,
  legal_title_fallback: legal_title_fallback,
  legal_meta_date: legal_meta_date,
  legal_highlight_title: legal_highlight_title,
  legal_highlight_text: legal_highlight_text,
  legal_contact_title: legal_contact_title,
  legal_contact_text: legal_contact_text,
  legal_show_toc: legal_show_toc,
  legal_show_related: legal_show_related,
  legal_toc_title: legal_toc_title,
  legal_related_title: legal_related_title,
  current_handle: current_handle,
  url_impressum: url_impressum,
  url_widerruf: url_widerruf,
  url_agb: url_agb,
  url_datenschutz: url_datenschutz,
  body_html: legal_body_html,
  use_impressum_body: legal_use_impressum_body,
  use_agb_body: legal_use_agb_body,
  use_widerrufsbelehrung_body: legal_use_widerrufsbelehrung_body,
  use_datenschutz_body: legal_use_datenschutz_body,
  use_versand_zahlung_body: legal_use_versand_zahlung_body,
  shipping_standard: shipping_standard,
  shipping_free_from: shipping_free_from,
  url_kontakt: url_kontakt,
  show_withdrawal_form: show_withdrawal_form,
  withdrawal_standalone: withdrawal_standalone,
  withdrawal_page_only: withdrawal_page_only,
  widerruf_email_webhook_url: section.settings.widerruf_email_webhook_url,
  legal_plain: legal_plain
%}

{% schema %}
{
  "name": "PflegeShop Rechtsseite",
  "tag": "section",
  "class": "pflege-legal-page-section section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Generische Vorlage für Impressum, Widerrufsrecht, AGB, Datenschutzerklärung usw. Inhalt aus dem Shopify-Admin (Online Shop → Seiten) wird automatisch übernommen. Alternativ Text unten eintragen."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Seitenkopf"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Kleine Überzeile",
      "info": "Optionale Mini-Überschrift über dem Titel, z. B. „Rechtliches“."
    },
    {
      "type": "text",
      "id": "title_fallback",
      "label": "Titel (Fallback ohne Seite)",
      "default": "Rechtliches"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Untertitel (optional)"
    },
    {
      "type": "text",
      "id": "meta_label",
      "label": "Bezeichnung Datum",
      "default": "Stand"
    },
    {
      "type": "text",
      "id": "meta_date",
      "label": "Datum / Stand",
      "info": "Wird in der Form „Stand: 20.05.2026“ angezeigt."
    },
    {
      "type": "header",
      "content": "Versand & Zahlung (Beträge)"
    },
    {
      "type": "text",
      "id": "shipping_standard_cost",
      "label": "Standardversand (€)",
      "default": "4,90",
      "info": "Nur Vorlage versand-zahlung, z. B. 4,90"
    },
    {
      "type": "text",
      "id": "shipping_free_from",
      "label": "Versandkostenfrei ab (€)",
      "default": "150,00",
      "info": "Nur Vorlage versand-zahlung, z. B. 150,00"
    },
    {
      "type": "header",
      "content": "Hinweis-Box (oberhalb Inhalt)"
    },
    {
      "type": "text",
      "id": "highlight_title",
      "label": "Überschrift der Hinweis-Box"
    },
    {
      "type": "richtext",
      "id": "highlight_text",
      "label": "Hinweis-Text"
    },
    {
      "type": "header",
      "content": "Seiten-Navigation"
    },
    {
      "type": "checkbox",
      "id": "show_toc",
      "label": "Automatisches Inhaltsverzeichnis aus Überschriften",
      "default": true,
      "info": "Erzeugt Links für jeden H2-Block im Seiteninhalt."
    },
    {
      "type": "text",
      "id": "toc_title",
      "label": "Überschrift Inhaltsverzeichnis",
      "default": "Inhalt"
    },
    {
      "type": "checkbox",
      "id": "show_related",
      "label": "Querverlinkung zu Impressum / Widerruf / AGB / Datenschutz",
      "default": true
    },
    {
      "type": "text",
      "id": "related_title",
      "label": "Überschrift Querverlinkung",
      "default": "Weitere Rechtstexte"
    },
    {
      "type": "header",
      "content": "Inhalt (Fallback)"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Inhalt",
      "info": "Wird nur angezeigt, wenn keine Seite im Admin gepflegt ist."
    },
    {
      "type": "header",
      "content": "Kontakt-Block (unter Inhalt)"
    },
    {
      "type": "text",
      "id": "contact_title",
      "label": "Überschrift Kontakt"
    },
    {
      "type": "richtext",
      "id": "contact_text",
      "label": "Kontakt-Text",
      "info": "Optional, z. B. „Fragen? Kontaktieren Sie uns unter …“"
    },
    {
      "type": "header",
      "content": "Widerruf — Kunden-E-Mail (kostenlos)"
    },
    {
      "type": "text",
      "id": "widerruf_email_webhook_url",
      "label": "Webhook-URL für Kunden-Eingangsbestätigung",
      "info": "Optional. Dauerhaft kostenlos: Google Apps Script — Anleitung scripts/widerruf-email-kostenlos-apps-script.md"
    },
    {
      "type": "header",
      "content": "Abstand"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "PflegeShop Rechtsseite",
      "settings": {
        "eyebrow": "Rechtliches"
      }
    }
  ]
}
{% endschema %}

{% comment %}
  Kategorie „Kostenfreie Pflegehilfsmittel“ — FAQ
{% endcomment %}

{%- liquid
  assign col_handle = collection.handle | downcase
  assign show_free_care = false
  if col_handle == 'kostenfreie-pflegehilfsmittel' or col_handle == 'pflegehilfsmittel-kostenfrei'
    assign show_free_care = true
  endif
-%}
{%- if show_free_care -%}
  {%- liquid
    assign pfc_faq_heading = 'sections.pflege_collection_free_care.faq_heading' | t
    assign pfc_faq_intro = 'sections.pflege_collection_free_care.faq_intro' | t
  -%}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <div class="pfc-free-care pfc-free-care--bottom section-{{ section.id }}-padding" id="pfc-free-care-bottom-{{ section.id }}">
    {% render 'pflege-faq-accordion',
      section_id: section.id,
      locale_root: 'sections.pflege_collection_free_care',
      faq_from: 1,
      faq_to: 14,
      heading: pfc_faq_heading,
      intro: pfc_faq_intro,
      intro_html: false
    %}

  </div>

  {% render 'pflege-free-care-faq-schema',
    locale_root: 'sections.pflege_collection_free_care',
    faq_count: 14
  %}
{%- endif -%}

{% schema %}
{
  "name": "PHM FAQ",
  "tag": "section",
  "class": "pfc-free-care-bottom-section",
  "limit": 1,
  "settings": [
    {
      "type": "paragraph",
      "content": "14 FAQs zur 42-Euro-Pauschale (Texte in Locales: pflege_collection_free_care). Abschluss-CTA im Section „PHM Kopfbereich“."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 48
    }
  ],
  "presets": [{ "name": "PHM FAQ" }]
}
{% endschema %}

{% comment %}
  Kategorie „Kostenfreie Pflegehilfsmittel“ — FAQ + Abschluss-CTA
{% endcomment %}

{%- liquid
  assign col_handle = collection.handle | downcase
  assign show_free_care = false
  if col_handle == 'kostenfreie-pflegehilfsmittel' or col_handle == 'pflegehilfsmittel-kostenfrei'
    assign show_free_care = true
  endif
-%}
{%- if show_free_care -%}
  {%- liquid
    assign pfc_config_url = section.settings.configurator_link | strip
    if pfc_config_url == blank
      if pages['pflegebox-konfigurator'] != blank
        assign pfc_config_url = pages['pflegebox-konfigurator'].url
      elsif pages['pflegehilfsmittel-konfigurator'] != blank
        assign pfc_config_url = pages['pflegehilfsmittel-konfigurator'].url
      elsif pages['pflegebox-konfigurieren'] != blank
        assign pfc_config_url = pages['pflegebox-konfigurieren'].url
      else
        assign pfc_config_url = routes.root_url | append: 'pages/pflegebox-konfigurator'
      endif
    endif
    assign pfc_info_url = section.settings.info_link | strip
    if pfc_info_url == blank
      assign pfc_info_url = routes.root_url | append: '#kostenfreie-pflegehilfsmittel'
    endif
  -%}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <div class="pfc-free-care pfc-free-care--bottom section-{{ section.id }}-padding" id="pfc-free-care-bottom-{{ section.id }}">
    <div class="pfc-free-care__shell page-width">
      <section class="pfc-free-care__faq" aria-labelledby="pfc-free-care-faq-title-{{ section.id }}">
        <h2 id="pfc-free-care-faq-title-{{ section.id }}" class="pfc-free-care__faq-title">
          {{ 'sections.pflege_collection_free_care.faq_heading' | t }}
        </h2>
        <div class="pfc-free-care__faq-list">
          {%- for i in (1..14) -%}
            {%- assign q_key = 'faq_' | append: i | append: '_q' -%}
            {%- assign a_key = 'faq_' | append: i | append: '_a' -%}
            <details class="pfc-free-care__faq-item" id="pfc-faq-{{ section.id }}-{{ i }}">
              <summary class="pfc-free-care__faq-summary">
                {{ 'sections.pflege_collection_free_care.' | append: q_key | t }}
              </summary>
              <div class="pfc-free-care__faq-answer rte">
                <p>{{ 'sections.pflege_collection_free_care.' | append: a_key | t }}</p>
              </div>
            </details>
          {%- endfor -%}
        </div>
      </section>

      <section class="pfc-free-care__closing" aria-labelledby="pfc-free-care-closing-title-{{ section.id }}">
        <div class="pfc-free-care__closing-card">
          <h2 id="pfc-free-care-closing-title-{{ section.id }}" class="pfc-free-care__closing-title">
            {{ 'sections.pflege_collection_free_care.closing_title' | t }}
          </h2>
          <p class="pfc-free-care__closing-text">{{ 'sections.pflege_collection_free_care.closing_text' | t }}</p>
          <div class="pfc-free-care__actions pfc-free-care__actions--closing">
            <a class="pfc-free-care__btn pfc-free-care__btn--primary" href="{{ pfc_config_url | escape }}">
              {{ 'sections.pflege_collection_free_care.cta_configure_box' | t }}
            </a>
            <a class="pfc-free-care__btn pfc-free-care__btn--secondary" href="{{ pfc_info_url | escape }}">
              {{ 'sections.pflege_collection_free_care.cta_more_info_view' | t }}
            </a>
          </div>
        </div>
      </section>
    </div>
  </div>

  {% render 'pflege-free-care-faq-schema', section_id: section.id %}
{%- endif -%}

{% schema %}
{
  "name": "PHM FAQ & CTA",
  "tag": "section",
  "class": "pfc-free-care-bottom-section",
  "limit": 1,
  "settings": [
    {
      "type": "url",
      "id": "configurator_link",
      "label": "Link Pflegebox-Konfigurator"
    },
    {
      "type": "url",
      "id": "info_link",
      "label": "Link „Mehr Infos“"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 48
    }
  ],
  "presets": [{ "name": "PHM FAQ & CTA" }]
}
{% endschema %}

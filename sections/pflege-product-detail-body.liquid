{% comment %}
  PflegeShop — Unterer Produktbereich (Beschreibung, Metafields, Fakten, Vertrauen).
  Liegt AUSSERHALB von <product-info>: statisch nach erstem Laden; keine variantenabhängigen Felder hier (SKU bleibt in der Kaufspalte).

  Erwartete Metafields im Namespace „custom“ (Auszug): application, ingredients,
  features, content_volume, skin_type, product_type_label, pzn, delivery_time,
  free_shipping_threshold. Für Schnell‑USPs in der Kaufspalte ebenfalls „usps“.
{% endcomment %}
{{ 'section-pflege-product-detail-body.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign dm_breadcrumb = true
  if section.settings.show_breadcrumb == false
    assign dm_breadcrumb = false
  endif
  assign dm_trust = true
  if section.settings.show_trust_strip == false
    assign dm_trust = false
  endif
  assign dm_facts = true
  if section.settings.show_facts_card == false
    assign dm_facts = false
  endif

  assign mf_app = product.metafields.custom.application
  assign mf_ing = product.metafields.custom.ingredients
  assign mf_feat = product.metafields.custom.features
  assign mf_vol = product.metafields.custom.content_volume
  assign mf_pzn = product.metafields.custom.pzn
  assign mf_ptype = product.metafields.custom.product_type_label
  assign mf_skin = product.metafields.custom.skin_type
  assign mf_del = product.metafields.custom.delivery_time
  assign mf_fs = product.metafields.custom.free_shipping_threshold

  assign has_desc = false
  if product.description != blank
    assign has_desc = true
  endif

  assign has_app = false
  if mf_app.value != blank
    assign has_app = true
  elsif mf_app != blank and mf_app != empty
    assign _ta = mf_app | metafield_text | strip
    if _ta != blank
      assign has_app = true
    endif
  endif

  assign has_ing = false
  if mf_ing.value != blank
    assign has_ing = true
  elsif mf_ing != blank and mf_ing != empty
    assign _ti = mf_ing | metafield_text | strip
    if _ti != blank
      assign has_ing = true
    endif
  endif

  assign has_feat = false
  if mf_feat.value != blank
    assign has_feat = true
  elsif mf_feat != blank and mf_feat != empty
    assign _tf = mf_feat | metafield_text | strip
    if _tf != blank
      assign has_feat = true
    endif
  endif

  assign has_content_tabs = false
  if has_desc or has_app or has_ing or has_feat
    assign has_content_tabs = true
  endif

  assign reviews_count_disp = nil
  if product.metafields.reviews.rating_count.value != blank
    assign reviews_count_disp = product.metafields.reviews.rating_count.value | plus: 0
  elsif product.metafields.reviews.rating_count != blank and product.metafields.reviews.rating_count != empty
    assign reviews_count_disp = product.metafields.reviews.rating_count | metafield_text | strip
  endif

  assign reviews_show_tab = false
  if product.metafields.reviews.rating.value != blank
    assign reviews_show_tab = true
  elsif reviews_count_disp != blank
    assign review_num = reviews_count_disp | plus: 0
    if review_num > 0
      assign reviews_show_tab = true
    endif
  endif

  assign has_any_tab = false
  if has_content_tabs or reviews_show_tab
    assign has_any_tab = true
  endif
  assign show_facts_panel = dm_facts

  assign show_section_inner = false
  if dm_breadcrumb or dm_trust or dm_facts or has_any_tab
    assign show_section_inner = true
  endif

  assign bc_coll = section.settings.collection_for_breadcrumb
  if bc_coll == blank and product.collections.size > 0
    assign bc_coll = product.collections.first
  endif
-%}

{%- style -%}
  .pflege-pdp-detail.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .pflege-pdp-detail.section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- unless show_section_inner -%}
  {% comment %} Nichts anzuzeigen — Section minimal halten {% endcomment %}
{%- else -%}
  <section
    class="pflege-pdp-detail section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}"
    aria-label="{{ section.settings.section_aria_label | escape }}"
    {{ section.shopify_attributes }}
  >
    <div class="page-width pflege-pdp-detail__shell">
      {%- if dm_breadcrumb -%}
        <nav class="pflege-pdp-detail__breadcrumb caption" aria-label="{{ section.settings.breadcrumb_aria_label | escape }}">
          <ol class="pflege-pdp-detail__breadcrumb-list list-unstyled">
            <li class="pflege-pdp-detail__breadcrumb-item">
              <a href="{{ routes.root_url }}">{{ section.settings.breadcrumb_home | escape }}</a>
            </li>
            <li class="pflege-pdp-detail__breadcrumb-sep" aria-hidden="true">{{ section.settings.breadcrumb_sep | escape }}</li>
            {%- if bc_coll != blank -%}
              <li class="pflege-pdp-detail__breadcrumb-item">
                <a href="{{ bc_coll.url }}">{{ bc_coll.title | escape }}</a>
              </li>
              <li class="pflege-pdp-detail__breadcrumb-sep" aria-hidden="true">{{ section.settings.breadcrumb_sep | escape }}</li>
            {%- endif -%}
            <li class="pflege-pdp-detail__breadcrumb-item pflege-pdp-detail__breadcrumb-item--current" aria-current="page">
              {{ product.title | escape }}
            </li>
          </ol>
        </nav>
      {%- endif -%}

      {%- if dm_trust -%}
        <div class="pflege-pdp-detail__trust-strip">
          {% render 'pflege-icon', icon: 'shield', width: 22 %}
          <span>{{ section.settings.trust_line_1 | escape }}</span>
          {% render 'pflege-icon', icon: 'truck', width: 22 %}
          <span>{{ section.settings.trust_line_2 | escape }}</span>
          {% render 'pflege-icon', icon: 'badge-check', width: 22 %}
          <span>{{ section.settings.trust_line_3 | escape }}</span>
        </div>
      {%- endif -%}

      <div class="pflege-pdp-detail__layout{% unless has_any_tab %} pflege-pdp-detail__layout--facts-only{% endunless %}">
        <div class="pflege-pdp-detail__main-col">
          {%- if has_any_tab -%}
            {% render 'pflege-product-body-tabs',
              section_id: section.id,
              product: product,
              has_desc: has_desc,
              has_app: has_app,
              has_ing: has_ing,
              has_feat: has_feat,
              mf_app: mf_app,
              mf_ing: mf_ing,
              mf_feat: mf_feat,
              label_desc: section.settings.tab_description,
              label_app: section.settings.tab_application,
              label_ing: section.settings.tab_ingredients,
              label_feat: section.settings.tab_features,
              reviews_show_tab: reviews_show_tab,
              reviews_count: reviews_count_disp,
              label_reviews: section.settings.tab_reviews
            %}
          {%- endif -%}
        </div>

        {%- if show_facts_panel -%}
          <aside
            class="pflege-pdp-detail__aside{% unless has_any_tab %} pflege-pdp-detail__aside--full{% endunless %}"
            aria-labelledby="PflegePDP-{{ section.id }}-facts"
          >
            {% render 'pflege-product-body-facts',
              section_id: section.id,
              product: product,
              mf_pzn: mf_pzn,
              mf_vol: mf_vol,
              mf_ptype: mf_ptype,
              mf_skin: mf_skin,
              mf_del: mf_del,
              mf_fs: mf_fs,
              heading: section.settings.facts_heading,
              lbl_pzn: section.settings.lbl_pzn,
              lbl_type: section.settings.lbl_type,
              lbl_skin: section.settings.lbl_skin,
              lbl_del: section.settings.lbl_delivery,
              lbl_fs: section.settings.lbl_shipping_hint,
              lbl_brand: section.settings.lbl_brand,
              lbl_content: section.settings.lbl_content
            %}
          </aside>
        {%- endif -%}
      </div>
    </div>
    {% render 'pflege-pdp-service-foot' %}
  </section>
  {%- if has_any_tab -%}
    <script src="{{ 'pflege-pdp-horizontal-tabs.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
{%- endunless -%}

{% schema %}
{
  "name": "Pflege PDP-Detail",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Inhalt über Shopify: product.description sowie optionale Produktmetafields im Namespace „custom“. Keine Änderung an Kaufen/Varianten (bleiben in Haupt-Section)."
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Breadcrumb anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "breadcrumb_home",
      "label": "Breadcrumb Start",
      "default": "Start"
    },
    {
      "type": "text",
      "id": "breadcrumb_sep",
      "label": "Breadcrumb Trenner",
      "default": "›"
    },
    {
      "type": "text",
      "id": "breadcrumb_aria_label",
      "label": "Breadcrumb ARIA-Label",
      "default": "Brotkrumen"
    },
    {
      "type": "collection",
      "id": "collection_for_breadcrumb",
      "label": "Sammlung im Breadcrumb (optional)",
      "info": "Wenn leer: erste Produktkollektion"
    },
    {
      "type": "checkbox",
      "id": "show_trust_strip",
      "label": "Vertrauens-Leiste unter Breadcrumb",
      "default": true
    },
    {
      "type": "text",
      "id": "trust_line_1",
      "label": "Vertrauen Zeile 1",
      "default": "Persönlicher Kundenservice"
    },
    {
      "type": "text",
      "id": "trust_line_2",
      "label": "Vertrauen Zeile 2",
      "default": "Sicherer Versand"
    },
    {
      "type": "text",
      "id": "trust_line_3",
      "label": "Vertrauen Zeile 3",
      "default": "Qualitätsprodukte"
    },
    {
      "type": "text",
      "id": "intro_heading",
      "label": "Überschrift über Kurzbeschreibung",
      "default": "Alle Infos zum Produkt"
    },
    {
      "type": "text",
      "id": "section_aria_label",
      "label": "Section ARIA",
      "default": "Produktdetail und Merkmale"
    },
    {
      "type": "text",
      "id": "tab_description",
      "label": "Tab Beschreibung",
      "default": "Beschreibung"
    },
    {
      "type": "text",
      "id": "tab_application",
      "label": "Tab Anwendung",
      "default": "Anwendung"
    },
    {
      "type": "text",
      "id": "tab_ingredients",
      "label": "Tab Inhaltsstoffe",
      "default": "Inhaltsstoffe"
    },
    {
      "type": "text",
      "id": "tab_features",
      "label": "Tab Merkmale",
      "default": "Merkmale & Hinweise"
    },
    {
      "type": "text",
      "id": "tab_reviews",
      "label": "Tab Bewertungen (vor Anzahl)",
      "default": "Bewertungen"
    },
    {
      "type": "checkbox",
      "id": "show_facts_card",
      "label": "Rechte Faktenkarte anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "facts_heading",
      "label": "Faktenkarte Überschrift",
      "default": "Auf einen Blick"
    },
    {
      "type": "text",
      "id": "lbl_pzn",
      "label": "Label PZN",
      "default": "PZN"
    },
    {
      "type": "text",
      "id": "lbl_type",
      "label": "Label Produkttyp",
      "default": "Produkttyp"
    },
    {
      "type": "text",
      "id": "lbl_skin",
      "label": "Label Hauttyp",
      "default": "Hauttyp"
    },
    {
      "type": "text",
      "id": "lbl_content",
      "label": "Label Inhalt (Metafeld custom.content_volume)",
      "default": "Inhalt"
    },
    {
      "type": "text",
      "id": "lbl_delivery",
      "label": "Label Lieferzeit",
      "default": "Lieferzeit"
    },
    {
      "type": "text",
      "id": "lbl_shipping_hint",
      "label": "Label Versandhint",
      "default": "Versand"
    },
    {
      "type": "text",
      "id": "lbl_brand",
      "label": "Label Marke/Hersteller",
      "default": "Hersteller"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Pflege PDP-Detail",
      "settings": {}
    }
  ]
}
{% endschema %}

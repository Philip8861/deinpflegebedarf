{{ 'section-pflege-category-cards.css' | asset_url | stylesheet_tag }}

<section class="pflege-category">
  <div class="pflege-category__grid">
    {%- for block in section.blocks -%}
      {%- assign card_link = block.settings.link | default: routes.collections_url -%}
      <a class="pflege-category-card" href="{{ card_link }}" {{ block.shopify_attributes }}>
        <div class="pflege-category-card__main">
          <div class="pflege-category-card__icon-wrap">
            {% render 'pflege-icon', icon: block.settings.icon, width: 22 %}
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="pflege-category-card__title">{{ block.settings.title | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="pflege-category-card__desc">{{ block.settings.description | escape }}</p>
          {%- endif -%}
          <span class="pflege-category-card__link-text">{{ block.settings.link_label | default: 'Jetzt entdecken' | escape }} →</span>
        </div>
        <div class="pflege-category-card__thumb">
          {%- if block.settings.image != blank -%}
            {%- assign c_alt = block.settings.image.alt | default: block.settings.title | escape -%}
            {{
              block.settings.image
              | image_url: width: 360
              | image_tag: loading: 'lazy', widths: '180, 360', sizes: '120px', alt: c_alt
            }}
          {%- else -%}
            {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "PflegeShop Kategorien",
  "tag": "section",
  "class": "pflege-category-section",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "category",
      "name": "Kategorie",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "package", "label": "Paket" },
            { "value": "droplet", "label": "Tropfen" },
            { "value": "shield", "label": "Schutz" },
            { "value": "sparkles", "label": "Plus" }
          ],
          "default": "package"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Kategorie"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Kurzbeschreibung",
          "default": "Ausgewählte Pflegeprodukte für Ihren Bedarf."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link-Text",
          "default": "Jetzt entdecken"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link Ziel (Collection)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PflegeShop Kategorien",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Inkontinenzversorgung",
            "description": "Diskreter Schutz und Pflege für den Alltag.",
            "icon": "droplet",
            "link": "shopify://collections/inkontinenzversorgung"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Hautpflege",
            "description": "Schonende Reinigung und sensible Pflege.",
            "icon": "droplet"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Mobilität",
            "description": "Mehr Bewegungsfreiheit und Alltagssicherheit.",
            "icon": "sparkles"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Hilfsmittel",
            "description": "Mehr Sicherheit und Komfort im Alltag.",
            "icon": "package"
          }
        }
      ]
    }
  ]
}
{% endschema %}

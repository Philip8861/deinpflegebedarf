{{ 'section-pflege-pflegesets-row.css' | asset_url | stylesheet_tag }}
{{ 'section-pflege-category-filtered.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign slot_handles = section.settings.handle_1 | default: 'pflegeset-grosse-s' | append: '|||'
  assign slot_handles = slot_handles | append: section.settings.handle_2 | default: 'pflegeset-grosse-l' | append: '|||'
  assign slot_handles = slot_handles | append: section.settings.handle_3 | default: 'pflegeset-grosse-m'
  assign slot_handles = slot_handles | split: '|||'

  assign pflege_col = section.settings.pflegesets_collection
  if pflege_col == blank and collection != blank and collection.handle == 'pflegesets' and collection.all_products_count > 0
    assign pflege_col = collection
  endif
  if pflege_col == blank and collections['pflegesets'] != blank and collections['pflegesets'].all_products_count > 0
    assign pflege_col = collections['pflegesets']
  endif

  assign pfs_heading = section.settings.heading | strip
  assign pfs_sub = section.settings.subheading | strip
-%}

<section class="pflege-pflegesets pflege-pflegesets--category" {{ section.shopify_attributes }}>
  <div class="pflege-pflegesets__shell">
    <div class="pflege-pflegesets__panel">
      {%- if pfs_heading != blank or pfs_sub != blank -%}
        <header class="pflege-pflegesets__head">
          {%- if pfs_heading != blank -%}
            <h1 class="pflege-pflegesets__title">{{ pfs_heading | escape | newline_to_br }}</h1>
          {%- endif -%}
          {%- if pfs_sub != blank -%}
            <p class="pflege-pflegesets__sub">{{ pfs_sub | escape | newline_to_br }}</p>
          {%- endif -%}
        </header>
      {%- endif -%}

      <div class="pflege-pflegesets__grid">
        {%- for handle_raw in slot_handles -%}
          {%- assign handle = handle_raw | strip -%}
          {%- liquid
            assign card_product = nil
            assign slot_index = forloop.index

            case slot_index
              when 1
                if section.settings.product_1 != blank
                  assign card_product = section.settings.product_1
                endif
                assign disp_title = section.settings.display_title_1 | strip
              when 2
                if section.settings.product_2 != blank
                  assign card_product = section.settings.product_2
                endif
                assign disp_title = section.settings.display_title_2 | strip
              when 3
                if section.settings.product_3 != blank
                  assign card_product = section.settings.product_3
                endif
                assign disp_title = section.settings.display_title_3 | strip
            endcase

            if card_product == blank and pflege_col != blank
              for col_product in pflege_col.products
                if col_product.handle == handle
                  assign card_product = col_product
                  break
                endif
              endfor
            endif

            if card_product == blank and pflege_col != blank
              for col_product in pflege_col.products limit: 3
                if forloop.index == slot_index
                  assign card_product = col_product
                  break
                endif
              endfor
            endif

            if card_product == blank
              assign card_product = all_products[handle]
            endif

            if card_product == blank
              assign alt_h = handle | replace: 'grosse', 'groesse'
              if alt_h != handle
                assign card_product = all_products[alt_h]
              endif
            endif

            if card_product == blank
              assign alt_h = handle | replace: 'groesse', 'grosse'
              if alt_h != handle
                assign card_product = all_products[alt_h]
              endif
            endif
          -%}

          {%- if card_product != blank -%}
            {% render 'pflege-cat-card',
              card_product: card_product,
              list_item: false,
              card_title_override: disp_title
            %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pflegesets Seite",
  "tag": "section",
  "class": "pflege-pflegesets-page-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Zeigt die 3 Pflegesets als Kategorie-Karten (wie Hautpflege, Körperpflege). Kollektion „pflegesets“ mit allen 3 Produkten wählen — sonst fehlen Karten."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Pflegesets"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Text darunter",
      "default": "Entdecken Sie unsere 3 Pflegesets, die perfekt zu Ihrer Pflegesituation passen."
    },
    {
      "type": "collection",
      "id": "pflegesets_collection",
      "label": "Kollektion mit den 3 Pflegesets",
      "info": "Empfohlen: Kollektion „pflegesets“ mit Set S, L und M."
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Produkt Kachel 1 (optional)"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Produkt Kachel 2 (optional)"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Produkt Kachel 3 (optional)"
    },
    {
      "type": "text",
      "id": "display_title_1",
      "label": "Anzeigename Kachel 1",
      "default": "Pflegebox Set Größe S"
    },
    {
      "type": "text",
      "id": "display_title_2",
      "label": "Anzeigename Kachel 2",
      "default": "Pflegebox Set Größe L"
    },
    {
      "type": "text",
      "id": "display_title_3",
      "label": "Anzeigename Kachel 3",
      "default": "Pflegebox Set Größe M"
    },
    {
      "type": "text",
      "id": "handle_1",
      "label": "Handle Kachel 1",
      "default": "pflegeset-grosse-s"
    },
    {
      "type": "text",
      "id": "handle_2",
      "label": "Handle Kachel 2",
      "default": "pflegeset-grosse-l"
    },
    {
      "type": "text",
      "id": "handle_3",
      "label": "Handle Kachel 3",
      "default": "pflegeset-grosse-m"
    }
  ],
  "presets": [
    {
      "name": "Pflegesets Seite"
    }
  ]
}
{% endschema %}

{% comment %}
  Produktgitter wie Kategorieseiten (4 Spalten Desktop).

  Parameter:
  - title
  - intro
  - collection
  - products_limit
{% endcomment %}
{%- liquid
  assign _limit = products_limit | default: 11
  assign _collection = collection
-%}
{%- if _collection != blank and _collection.all_products_count > 0 -%}
  <div class="pfc-free-care__product-grid">
    <div class="pflege-cat-filtered__shell pfc-free-care__product-grid-shell">
      {%- if title != blank or intro != blank -%}
        <header class="pfc-free-care__product-grid-head">
          {%- if title != blank -%}
            <h2 class="pflege-bestseller__title">{{ title | escape }}</h2>
          {%- endif -%}
          {%- if intro != blank -%}
            <p class="pflege-bestseller__intro">{{ intro | escape | newline_to_br }}</p>
          {%- endif -%}
        </header>
      {%- endif -%}
      <ul class="pflege-cat-filtered__grid" role="list">
        {%- for card_product in _collection.products limit: _limit -%}
          {% render 'pflege-cat-card', card_product: card_product %}
        {%- endfor -%}
      </ul>
    </div>
  </div>
{%- endif -%}

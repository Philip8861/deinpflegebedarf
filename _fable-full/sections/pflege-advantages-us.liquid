{{ 'section-pflege-advantages-us.css' | asset_url | stylesheet_tag }}

{% render 'pflege-advantages-us-block',
  heading: section.settings.heading,
  subtitle: section.settings.subtitle,
  section_id: section.id
%}

{% schema %}
{
  "name": "Ihre Vorteile bei uns",
  "tag": "section",
  "class": "pflege-advantages-us-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Ihre Vorteile bei uns"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Untertitel",
      "default": "Schneller Versand & unkomplizierte Bestellung. Unsere Artikel bieten eine echte Unterstützung im Alltag."
    }
  ],
  "presets": [
    {
      "name": "Ihre Vorteile bei uns"
    }
  ]
}
{% endschema %}

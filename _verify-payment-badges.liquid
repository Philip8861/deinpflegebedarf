{% comment %}
  Zahlungsarten-Logos (Visa, Mastercard, PayPal, Google Pay, Klarna).
  Accepts: compact (boolean) — kleinere Darstellung für PDP-Kaufbox
{% endcomment %}
{% liquid
  assign compact = compact | default: false
  assign badge_class = 'pflege-pay-badges'
  if compact
    assign badge_class = badge_class | append: ' pflege-pay-badges--compact'
  endif
%}
<div class="{{ badge_class }}">
  <ul class="pflege-pay-badges__list" role="list">
    <li class="pflege-pay-badges__item">
      <img
        src="{{ 'Visa_logo.webp' | asset_url }}"
        alt="Visa"
        class="pflege-pay-badges__logo"
        width="65"
        height="40"
        loading="lazy"
        decoding="async"
      >
    </li>
    <li class="pflege-pay-badges__item">
      <img
        src="{{ 'Mastercard.webp' | asset_url }}"
        alt="Mastercard"
        class="pflege-pay-badges__logo"
        width="65"
        height="40"
        loading="lazy"
        decoding="async"
      >
    </li>
    <li class="pflege-pay-badges__item">
      <a
        href="https://www.paypal.com/de/webapps/mpp/paypal-popup"
        target="_blank"
        rel="noopener noreferrer"
        title="So funktioniert PayPal"
        aria-label="PayPal — So funktioniert PayPal (neues Fenster)"
        class="pflege-pay-badges__link"
      >
        <img
          src="{{ 'paypal-logo.png' | asset_url }}"
          alt="PayPal"
          class="pflege-pay-badges__logo pflege-pay-badges__logo--wide"
          width="100"
          height="26"
          loading="lazy"
          decoding="async"
        >
      </a>
    </li>
    <li class="pflege-pay-badges__item">
      <img
        src="{{ 'google-pay.svg' | asset_url }}"
        alt="Google Pay"
        class="pflege-pay-badges__logo pflege-pay-badges__logo--wide"
        width="82"
        height="34"
        loading="lazy"
        decoding="async"
      >
    </li>
    <li class="pflege-pay-badges__item">
      <img
        src="{{ 'klarna.svg' | asset_url }}"
        alt="Klarna"
        class="pflege-pay-badges__logo pflege-pay-badges__logo--wide"
        width="90"
        height="38"
        loading="lazy"
        decoding="async"
      >
    </li>
  </ul>
</div>
